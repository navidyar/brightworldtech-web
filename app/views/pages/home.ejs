<%- include('../partials/layout-start', {
  pageTitle: 'BWTDallas Dashboard',
  topbarTitle: 'Portal Hub',
  activeNav: 'portal'
}) %>

<header class="page-header">
  <h1>BWTDallas Dashboard</h1>
  <p>Portal overview for Bright World Technologies operations.</p>
</header>

<section>
  <h2>Inventory Summary</h2>

  <div class="stats-grid">
    <div class="stat-card">
      <h3>Total Units</h3>
      <p><%= stats.total_units %></p>
    </div>

    <div class="stat-card">
      <h3>Total Quantity</h3>
      <p><%= stats.total_quantity %></p>
    </div>

    <div class="stat-card">
      <h3>Total Categories</h3>
      <p><%= stats.total_categories %></p>
    </div>
  </div>
</section>

<section>
  <h2>Category Summary</h2>

  <% if (!categorySummary.length) { %>
    <div class="detail-card">
      <p>No category summary available.</p>
    </div>
  <% } else { %>
    <div class="category-summary-list">
      <% categorySummary.forEach((row) => { %>
        <div class="category-summary-card">
          <h3><%= row.category %></h3>
          <p><strong>Units:</strong> <%= row.unit_count %></p>
          <p><strong>Total Quantity:</strong> <%= row.total_quantity %></p>
        </div>
      <% }) %>
    </div>
  <% } %>
</section>

<section>
  <h2>Recent Units</h2>

  <% if (!recentUnits.length) { %>
    <div class="detail-card">
      <p>No recent units found.</p>
    </div>
  <% } else { %>
    <div class="recent-units-list">
      <% recentUnits.forEach((unit) => { %>
        <a class="recent-unit-card" href="/units/<%= unit.id %>">
          <h3><%= unit.name %></h3>
          <p><strong>Category:</strong> <%= unit.category %></p>
          <p><strong>Quantity:</strong> <%= unit.quantity %></p>
          <p><strong>Price:</strong> <%= formatPrice(unit.price) %></p>
        </a>
      <% }) %>
    </div>
  <% } %>
</section>

<section>
  <h2>Quick Links</h2>
  <div class="dashboard-links">
    <a class="dashboard-card" href="/units">
      <h3>Tech</h3>
      <p>View, search, add, edit, and delete technology units.</p>
    </a>
  </div>
</section>

<%- include('../partials/layout-end') %>