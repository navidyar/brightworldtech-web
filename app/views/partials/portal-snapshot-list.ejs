<div class="snapshot-panel">
  <h3><%= title %></h3>
  <% if (!rows.length) { %>
    <p class="muted"><%= emptyText %></p>
  <% } else { %>
    <div class="bar-list">
      <% const maxValue = Math.max(...rows.map((row) => Number(row[valueKey] || 0)), 1); %>
      <% rows.forEach((row) => { %>
        <% const value = Number(row[valueKey] || 0); %>
        <div class="bar-row">
          <div class="bar-row-header">
            <span><%= row[labelKey] || 'Unknown' %></span>
            <strong><%= value %> <%= valueLabel %></strong>
          </div>
          <div class="bar-track">
            <div class="bar-fill" style="width: <%= Math.max((value / maxValue) * 100, value > 0 ? 8 : 0) %>%"></div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
