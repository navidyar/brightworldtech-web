<div class="snapshot-panel">
  <h3>Recent Assignments</h3>
  <% if (!rows.length) { %>
    <p class="muted">No recent unit assignments are available yet.</p>
  <% } else { %>
    <div class="table-wrap">
      <table class="items-table">
        <thead>
          <tr>
            <th>Unit</th>
            <th>Type</th>
            <th>Technician</th>
          </tr>
        </thead>
        <tbody>
          <% rows.forEach((row) => { %>
            <tr>
              <td><%= row.unit_serial || `Unit #${row.id}` %></td>
              <td><%= row.unit_type || 'Unknown' %></td>
              <td><%= row.technician || 'Unassigned' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
