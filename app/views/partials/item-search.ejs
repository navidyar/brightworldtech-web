<section>
  <h2>Items</h2>

  <form id="search-form" class="search-form" hx-get="/items/table" hx-target="#items-container" hx-swap="innerHTML">
    <input type="hidden" id="page-input" name="page" value="<%= currentFilters ? currentFilters.page : 1 %>" />

    <label for="search-input">Search and Filter</label>
    <input type="text" id="search-input" name="search" placeholder="Type something like Dell or Laptop" value="<%= currentFilters ? currentFilters.search : '' %>" />

    <select id="category-select" name="category">
      <option value="">All Categories</option>
      <% categories.forEach((category) => { %>
        <option value="<%= category %>" <%= currentFilters && currentFilters.category === category ? 'selected' : '' %>><%= category %></option>
      <% }) %>
    </select>

    <select id="sort-select" name="sort">
      <option value="newest" <%= currentFilters && currentFilters.sort === 'newest' ? 'selected' : '' %>>Newest First</option>
      <option value="oldest" <%= currentFilters && currentFilters.sort === 'oldest' ? 'selected' : '' %>>Oldest First</option>
      <option value="name_asc" <%= currentFilters && currentFilters.sort === 'name_asc' ? 'selected' : '' %>>Name A to Z</option>
      <option value="name_desc" <%= currentFilters && currentFilters.sort === 'name_desc' ? 'selected' : '' %>>Name Z to A</option>
      <option value="price_asc" <%= currentFilters && currentFilters.sort === 'price_asc' ? 'selected' : '' %>>Price Low to High</option>
      <option value="price_desc" <%= currentFilters && currentFilters.sort === 'price_desc' ? 'selected' : '' %>>Price High to Low</option>
      <option value="quantity_asc" <%= currentFilters && currentFilters.sort === 'quantity_asc' ? 'selected' : '' %>>Quantity Low to High</option>
      <option value="quantity_desc" <%= currentFilters && currentFilters.sort === 'quantity_desc' ? 'selected' : '' %>>Quantity High to Low</option>
    </select>

    <select id="page-size-select" name="pageSize">
      <option value="5" <%= currentFilters && currentFilters.pageSize === 5 ? 'selected' : '' %>>5 per page</option>
      <option value="10" <%= currentFilters && currentFilters.pageSize === 10 ? 'selected' : '' %>>10 per page</option>
      <option value="25" <%= currentFilters && currentFilters.pageSize === 25 ? 'selected' : '' %>>25 per page</option>
      <option value="50" <%= currentFilters && currentFilters.pageSize === 50 ? 'selected' : '' %>>50 per page</option>
    </select>

    <button type="submit">Apply</button>
    <button type="button" id="clear-search">Clear</button>
  </form>

  <div id="items-container" hx-get="/items/table" hx-trigger="load, item-saved from:body" hx-swap="innerHTML">
    Loading items...
  </div>
</section>