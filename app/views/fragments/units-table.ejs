<section class="content-card table-card">
  <div class="table-toolbar">
    <div>
      <p class="section-kicker">Technology Units</p>
      <h2>Registry Results</h2>
    </div>

    <div class="fragment-status">
      <% if (!units.length) { %>
        <% if (searchTerm) { %>
          No units found for "<%= searchTerm %>".
        <% } else { %>
          No units found.
        <% } %>
      <% } else { %>
        Showing page <%= page %> of <%= totalPages %> · <%= totalCount %> unit(s) · <%= pageSize %> per page
      <% } %>
    </div>
  </div>

  <% if (units.length) { %>
    <div class="table-scroll">
      <table class="units-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Unit Name</th>
            <th>Category</th>
            <th>Quantity</th>
            <th>Price</th>
            <th>Created</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% units.forEach((unit) => { %>
            <tr>
              <td><%= unit.id %></td>
              <td><a class="unit-link" href="/units/<%= unit.id %>"><%= unit.name %></a></td>
              <td><span class="category-badge"><%= unit.category %></span></td>
              <td><%= unit.quantity %></td>
              <td><%= formatPrice(unit.price) %></td>
              <td><%= unit.created_at ? new Date(unit.created_at).toLocaleDateString() : '' %></td>
              <td>
                <div class="actions-cell">
                  <button type="button" class="edit-button" data-open-modal="unit-modal" data-form-url="/units/form" data-id="<%= unit.id %>" data-name="<%= unit.name %>" data-category="<%= unit.category %>" data-quantity="<%= unit.quantity %>" data-price="<%= unit.price %>">Edit</button>
                  <button type="button" class="delete-button" hx-delete="/units/<%= unit.id %>" hx-target="#unit-modal-content" hx-swap="innerHTML" hx-confirm="Are you sure you want to delete this unit?">Delete</button>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="pagination-bar">
      <div class="pagination-summary">
        Showing <%= units.length %> row(s) on this page
      </div>

      <div class="pagination-controls">
        <button type="button" hx-get="/units/table" hx-target="#units-container" hx-swap="innerHTML" hx-include="#search-form" hx-vals='{"page": <%= page - 1 %>}' <%= page <= 1 ? 'disabled' : '' %>>
          Previous
        </button>

        <span class="page-pill active"><%= page %></span>

        <button type="button" hx-get="/units/table" hx-target="#units-container" hx-swap="innerHTML" hx-include="#search-form" hx-vals='{"page": <%= page + 1 %>}' <%= page >= totalPages ? 'disabled' : '' %>>
          Next
        </button>
      </div>
    </div>
  <% } else { %>
    <div class="empty-state">
      <h3>No matching units</h3>
      <p>Try clearing filters or adding a new unit.</p>
    </div>
  <% } %>
</section>