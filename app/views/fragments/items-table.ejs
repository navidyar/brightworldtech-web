<div class="items-fragment">
  <div class="fragment-status">
    <% if (!items.length) { %>
      <% if (searchTerm) { %>
        No items found for "<%= searchTerm %>".
      <% } else { %>
        No items found.
      <% } %>
    <% } else { %>
      Showing page <%= page %> of <%= totalPages %> (<%= totalCount %> total item(s), <%= pageSize %> per page).
    <% } %>
  </div>

  <% if (items.length) { %>
    <table class="items-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>Category</th>
          <th>Quantity</th>
          <th>Price</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% items.forEach((item) => { %>
          <tr>
            <td><%= item.id %></td>
            <td><a href="/items/<%= item.id %>"><%= item.name %></a></td>
            <td><%= item.category %></td>
            <td><%= item.quantity %></td>
            <td><%= formatPrice(item.price) %></td>
            <td class="actions-cell">
              <button type="button" class="edit-button" data-id="<%= item.id %>" data-name="<%= item.name %>" data-category="<%= item.category %>" data-quantity="<%= item.quantity %>" data-price="<%= item.price %>">Edit</button>
              <button type="button" class="delete-button" hx-delete="/items/<%= item.id %>" hx-target="#item-form-section" hx-swap="outerHTML" hx-confirm="Are you sure you want to delete this item?">Delete</button>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <div class="pagination-controls">
      <button type="button" hx-get="/items/table" hx-target="#items-container" hx-swap="innerHTML" hx-include="#search-form" hx-vals='{"page": <%= page - 1 %>}' <%= page <= 1 ? 'disabled' : '' %>>
        Previous
      </button>

      <span>Page <%= page %> of <%= totalPages %></span>

      <button type="button" hx-get="/items/table" hx-target="#items-container" hx-swap="innerHTML" hx-include="#search-form" hx-vals='{"page": <%= page + 1 %>}' <%= page >= totalPages ? 'disabled' : '' %>>
        Next
      </button>
    </div>
  <% } %>
</div>