<section id="item-form-section">
  <h2 id="form-title"><%= formMode === 'edit' ? `Edit Item #${formValues.item_id}` : 'Add Item' %></h2>

  <% if (formMessage) { %>
    <div class="<%= formMessage.type === 'error' ? 'error-box' : 'success-box' %>">
      <%= formMessage.text %>
    </div>
  <% } %>

  <form id="item-form" class="item-form" hx-post="/items/form" hx-target="#item-form-section" hx-swap="outerHTML">
    <input type="hidden" id="item-id" name="item_id" value="<%= formValues.item_id || '' %>" />

    <div class="form-row">
      <label for="name">Name</label>
      <input type="text" id="name" name="name" value="<%= formValues.name || '' %>" required />
      <% if (fieldErrors.name) { %>
        <div class="field-error"><%= fieldErrors.name %></div>
      <% } %>
    </div>

    <div class="form-row">
      <label for="category">Category</label>
      <input type="text" id="category" name="category" value="<%= formValues.category || '' %>" required />
      <% if (fieldErrors.category) { %>
        <div class="field-error"><%= fieldErrors.category %></div>
      <% } %>
    </div>

    <div class="form-row">
      <label for="quantity">Quantity</label>
      <input type="number" id="quantity" name="quantity" min="0" value="<%= formValues.quantity ?? '' %>" required />
      <% if (fieldErrors.quantity) { %>
        <div class="field-error"><%= fieldErrors.quantity %></div>
      <% } %>
    </div>

    <div class="form-row">
      <label for="price">Price</label>
      <input type="number" id="price" name="price" min="0" step="0.01" value="<%= formValues.price ?? '' %>" required />
      <% if (fieldErrors.price) { %>
        <div class="field-error"><%= fieldErrors.price %></div>
      <% } %>
    </div>

    <div class="form-actions">
      <button type="submit" id="save-button"><%= formMode === 'edit' ? 'Update Item' : 'Add Item' %></button>
      <button type="button" id="cancel-edit" class="secondary-button" <%= formMode === 'edit' ? '' : 'style="display:none;"' %>>Cancel Edit</button>
    </div>
  </form>
</section>