<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { pageTitle }) %>

  <body>
    <div class="app-shell">
      <%- include('../partials/sidebar', { currentNav }) %>

      <div class="app-main">
        <%- include('../partials/topbar', { pageTitle }) %>

        <main class="content-shell">
          <section class="dashboard-hero accent-blue">
            <div>
              <p class="eyebrow">Step 4f</p>
              <h2>Dashboard</h2>
              <p>
                Review the current operational snapshot, live chart summaries, and available dashboard areas. The dashboard now includes filters and drilldowns into filtered Unit Browser views.
              </p>
            </div>

            <div class="hero-badge">
              <span>Available</span>
              <strong><%= formatNumber(dashboards.length) %></strong>
            </div>
          </section>

          <%- include('../fragments/dashboard-live-region', { dashboardData, dashboardFilters, dashboardFilterOptions, dashboardFilterConfig }) %>

          <section class="content-card">
            <div class="content-header">
              <div>
                <p class="eyebrow">Available Dashboards</p>
                <h2>Dashboard Access</h2>
              </div>
            </div>

            <% if (dashboards.length === 0) { %>
              <div class="message error">
                <p>No dashboards are currently available for your user account.</p>
                <p>Ask an Admin or Management user to review your roles.</p>
              </div>
            <% } else { %>
              <div class="dashboard-access-grid">
                <% dashboards.forEach((dashboard) => { %>
                  <a class="role-dashboard-card accent-<%= dashboard.accent %>" href="/dashboards/<%= dashboard.key %>">
                    <p><%= dashboard.menuLabel || dashboard.title %></p>
                    <h3><%= dashboard.title %></h3>
                    <span><%= dashboard.description %></span>
                  </a>
                <% }) %>
              </div>
            <% } %>
          </section>
        </main>
      </div>
    </div>
  </body>
</html>
