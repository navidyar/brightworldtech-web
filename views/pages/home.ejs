<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { pageTitle }) %>

  <body>
    <div class="app-shell">
      <%- include('../partials/sidebar', { currentNav }) %>

      <div class="app-main">
        <%- include('../partials/topbar', { pageTitle }) %>

        <main class="content-shell">
          <section class="dashboard-hero">
            <div>
              <p class="eyebrow">Step 1f</p>
              <h2>Role-Aware Dashboard Access</h2>
              <p>
                Your navigation now supports submenus and role-based dashboard access.
                Admin users can access every area. Management can access department dashboards
                and operational menus except Admin-only tools.
              </p>
            </div>

            <div class="hero-badge">
              <span>Logged in as</span>
              <strong><%= currentUser.first_name %> <%= currentUser.last_name %></strong>
            </div>
          </section>

          <section class="dashboard-grid">
            <article class="dashboard-card">
              <p class="card-label">Database</p>
              <h3><%= status.database.connected ? 'Connected' : 'Disconnected' %></h3>

              <% if (status.database.connected) { %>
                <p>
                  Using <strong><%= status.database.connectionInfo.database_name %></strong>
                </p>
              <% } else { %>
                <p><%= status.database.error %></p>
              <% } %>
            </article>

            <article class="dashboard-card">
              <p class="card-label">Schema</p>
              <h3><%= status.schema.ok ? 'Ready' : 'Needs Attention' %></h3>
              <p>
                <strong><%= formatNumber(status.schema.tableCount) %></strong> tables
                and <strong><%= formatNumber(status.schema.viewCount || 0) %></strong> views found.
              </p>
            </article>

            <article class="dashboard-card">
              <p class="card-label">Current Roles</p>
              <h3><%= currentRoles.length %></h3>
              <p><%= currentRoles.join(', ') || 'No roles assigned' %></p>
            </article>
          </section>

          <section class="content-card">
            <div class="content-header">
              <div>
                <p class="eyebrow">Available Dashboards</p>
                <h2>Your Dashboard Access</h2>
              </div>
            </div>

            <div class="role-dashboard-grid">
              <% getAccessibleDashboards().forEach((dashboard) => { %>
                <a href="/dashboards/<%= dashboard.key %>" class="role-dashboard-card accent-<%= dashboard.accent %>">
                  <p><%= dashboard.kicker %></p>
                  <h3><%= dashboard.title %></h3>
                  <span><%= dashboard.description %></span>
                </a>
              <% }) %>
            </div>
          </section>

          <section class="content-card">
            <div class="content-header">
              <div>
                <p class="eyebrow">Build Progress</p>
                <h2>Phase 1 Foundation</h2>
              </div>
            </div>

            <div class="workflow-list">
              <div class="workflow-item complete">
                <span></span>
                <div>
                  <strong>Step 1a</strong>
                  <p>Docker, MySQL, Traefik, and blank app foundation.</p>
                </div>
              </div>

              <div class="workflow-item complete">
                <span></span>
                <div>
                  <strong>Step 1b</strong>
                  <p>Database connection layer and schema verification.</p>
                </div>
              </div>

              <div class="workflow-item complete">
                <span></span>
                <div>
                  <strong>Step 1c</strong>
                  <p>Login, sessions, password setup links, and first admin user.</p>
                </div>
              </div>

              <div class="workflow-item complete">
                <span></span>
                <div>
                  <strong>Step 1d</strong>
                  <p>Protected Dashboard and logged-in layout shell.</p>
                </div>
              </div>

              <div class="workflow-item complete">
                <span></span>
                <div>
                  <strong>Step 1e</strong>
                  <p>Management user creation and setup-link generation from the UI.</p>
                </div>
              </div>

              <div class="workflow-item active">
                <span></span>
                <div>
                  <strong>Step 1f</strong>
                  <p>Role-aware submenus, dashboard access rules, and improved visual status accents.</p>
                </div>
              </div>
            </div>
          </section>
        </main>
      </div>
    </div>
  </body>
</html>