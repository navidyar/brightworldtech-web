<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { pageTitle }) %>
  <link rel="stylesheet" href="/css/tech.css" />
  <script defer src="/js/tech-unit-form.js"></script>

  <body>
    <%
      const isEditMode = mode === 'edit';
    %>

    <div class="app-shell">
      <%- include('../partials/sidebar', { currentNav }) %>

      <div class="app-main">
        <%- include('../partials/topbar', { pageTitle }) %>

        <main class="content-shell">
          <section class="dashboard-hero accent-green">
            <div>
              <p class="eyebrow">Step 2i.4</p>
              <h2><%= isEditMode ? 'Edit Unit' : 'Create Unit' %></h2>
              <p>
                This is the full-page fallback. The normal Tech Units page uses a modal create/edit flow.
              </p>
            </div>

            <div class="hero-badge">
              <span>Mode</span>
              <strong><%= isEditMode ? 'Edit' : 'Create' %></strong>
            </div>
          </section>

          <section class="content-card">
            <div class="content-header">
              <div>
                <p class="eyebrow">Tech</p>
                <h2><%= isEditMode ? 'Edit Unit Record' : 'New Unit Record' %></h2>
              </div>

              <a class="secondary-button" href="/tech/units">Back to Units</a>
            </div>

            <%- include('../fragments/tech-unit-form', {
              mode,
              formAction,
              formOptions,
              formData,
              errorMessages,
              isModal: false
            }) %>
          </section>
        </main>
      </div>
    </div>
  </body>
</html>