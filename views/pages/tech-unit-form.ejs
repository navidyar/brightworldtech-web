<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { pageTitle }) %>
  <link rel="stylesheet" href="/css/tech-units-clean.css?v=20260708-stage-f5-2" />
  <script defer src="/js/tech-unit-form.js"></script>

  <body>
    <%
      const isEditMode = mode === 'edit';
    %>

    <div class="app-shell">
      <%- include('../partials/sidebar', { currentNav }) %>

      <div class="app-main">
        <%- include('../partials/topbar', { pageTitle }) %>

        <main class="content-shell tech-unit-form-clean-page">
          <section class="tech-unit-form-clean-page-heading">
            <h1><%= isEditMode ? 'Edit Unit' : 'Create Unit' %></h1>
            <a class="secondary-button" href="/tech/units">Back to Units</a>
          </section>

          <%- include('../fragments/tech-unit-form', {
              mode,
              formAction,
              formOptions,
              formData,
              errorMessages,
              duplicateMatches: typeof duplicateMatches !== 'undefined' ? duplicateMatches : [],
              duplicateCheckPerformed: typeof duplicateCheckPerformed !== 'undefined' ? duplicateCheckPerformed : false,
              canRequestIntentionalDuplicate: typeof canRequestIntentionalDuplicate !== 'undefined' ? canRequestIntentionalDuplicate : false,
              isModal: false
            }) %>
        </main>
      </div>
    </div>
  </body>
</html>