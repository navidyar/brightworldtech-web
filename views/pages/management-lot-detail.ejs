<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { pageTitle }) %>
  <link rel="stylesheet" href="/css/lots.css" />
  <link rel="stylesheet" href="/css/modal.css" />
  <script defer src="/js/modal.js"></script>
  <script defer src="/js/lot-form.js"></script>
  <script defer src="/js/lot-requirements.js"></script>

  <body>
    <div class="app-shell">
      <%- include('../partials/sidebar', { currentNav }) %>

      <div class="app-main">
        <%- include('../partials/topbar', { pageTitle }) %>

        <main class="content-shell lot-detail-page">
          <nav class="lot-breadcrumbs" aria-label="Lot breadcrumb">
            <a href="/management/lots">Lots</a>

            <% lotRelationships.breadcrumbs.forEach((breadcrumbLot, index) => { %>
              <span aria-hidden="true">›</span>

              <% if (index === lotRelationships.breadcrumbs.length - 1) { %>
                <strong><%= breadcrumbLot.lot_name %></strong>
              <% } else { %>
                <a href="/management/lots/<%= breadcrumbLot.lot_id %>"><%= breadcrumbLot.lot_name %></a>
              <% } %>
            <% }) %>
          </nav>

          <section class="page-heading lot-detail-page-heading">
            <div>
              <h1><%= lot.lot_name %></h1>
            </div>

            <div class="lot-detail-action-bar site-clean-actions">
              <a class="secondary-button" href="/management/lots<%= Number(lot.is_active) === 1 ? '' : '?showHidden=1' %>">Back to Lots</a>
              <a class="primary-button" href="/management/lots/<%= lot.lot_id %>/edit/modal" hx-get="/management/lots/<%= lot.lot_id %>/edit/modal" hx-target="#modal-root" hx-swap="innerHTML">Edit Lot</a>
              <a class="secondary-button" href="/management/lots/<%= lot.lot_id %>/requirements/modal" hx-get="/management/lots/<%= lot.lot_id %>/requirements/modal" hx-target="#modal-root" hx-swap="innerHTML">Requirements</a>
              <a class="secondary-button" href="/management/lots/<%= lot.lot_id %>/enforcement/modal" hx-get="/management/lots/<%= lot.lot_id %>/enforcement/modal" hx-target="#modal-root" hx-swap="innerHTML">Enforcement Preview</a>
              <% if (Number(lot.is_closed) === 1) { %>
                <a class="secondary-button" href="/management/lots/<%= lot.lot_id %>/reopen/modal" hx-get="/management/lots/<%= lot.lot_id %>/reopen/modal" hx-target="#modal-root" hx-swap="innerHTML">Reopen Lot</a>
              <% } else { %>
                <a class="secondary-button" href="/management/lots/<%= lot.lot_id %>/close/modal" hx-get="/management/lots/<%= lot.lot_id %>/close/modal" hx-target="#modal-root" hx-swap="innerHTML">Close Lot</a>
              <% } %>
              <% if (Number(lot.is_active) === 1) { %>
                <a class="secondary-button" href="/management/lots/<%= lot.lot_id %>/hide/modal" hx-get="/management/lots/<%= lot.lot_id %>/hide/modal" hx-target="#modal-root" hx-swap="innerHTML">Hide Lot</a>
              <% } else { %>
                <a class="secondary-button" href="/management/lots/<%= lot.lot_id %>/unhide/modal" hx-get="/management/lots/<%= lot.lot_id %>/unhide/modal" hx-target="#modal-root" hx-swap="innerHTML">Unhide Lot</a>
              <% } %>
              <% if (Number(lot.unitCount || 0) === 0 && lotRelationships.directChildLots.length === 0) { %>
                <a class="secondary-button danger-button" href="/management/lots/<%= lot.lot_id %>/delete/modal" hx-get="/management/lots/<%= lot.lot_id %>/delete/modal" hx-target="#modal-root" hx-swap="innerHTML">Delete Lot</a>
              <% } %>
            </div>
          </section>

          <% if (Number(lot.is_closed) === 1) { %>
            <div class="message warning">
              This lot is closed. Existing units remain available for review, but the lot cannot receive new, moved, or override-handoff units until reopened.
            </div>
          <% } %>

          <% if (Number(lot.is_active) !== 1) { %>
            <div class="message warning">
              This lot is hidden from normal lot browsers and assignment dropdowns, but remains available here for history and review.
            </div>
          <% } %>

          <% if (successMessage) { %>
            <div class="message success">
              <%= successMessage %>
            </div>
          <% } %>

          <% if (errorMessages.length > 0) { %>
            <div class="message error">
              <% errorMessages.forEach((errorMessage) => { %>
                <p><%= errorMessage %></p>
              <% }) %>
            </div>
          <% } %>

          <section class="lot-summary-panel lot-detail-summary-panel lot-state-context-panel" aria-label="Lot detail totals">
            <div class="lot-state-main">
              <div class="lot-state-overview">
                <div class="lot-summary-primary">
                  <span>Lot state</span>
                  <strong><%= Number(lot.is_closed) === 1 ? 'Closed' : 'Open' %></strong>
                  <small><%= enforcementSummary.policyLabel %></small>
                </div>

                <div class="lot-summary-stats">
                  <article>
                    <span class="lot-summary-icon" aria-hidden="true">◉</span>
                    <span><small>Visibility</small><strong><%= Number(lot.is_active) === 1 ? 'Visible' : 'Hidden' %></strong></span>
                  </article>

                  <article>
                    <span class="lot-summary-icon" aria-hidden="true">▤</span>
                    <span><small>Lot type</small><strong><%= lot.lot_type_label || '—' %></strong></span>
                  </article>

                  <article>
                    <span class="lot-summary-icon" aria-hidden="true">#</span>
                    <span><small>Units</small><strong><%= formatNumber(lot.unitCount) %></strong></span>
                  </article>

                  <article>
                    <span class="lot-summary-icon" aria-hidden="true">%</span>
                    <span>
                      <small>Progress</small>
                      <strong>
                        <% if (lot.isUnlimited) { %>
                          Open
                        <% } else { %>
                          <%= formatNumber(lot.progressPercent) %>%
                        <% } %>
                      </strong>
                    </span>
                  </article>

                  <article>
                    <span class="lot-summary-icon" aria-hidden="true">×</span>
                    <span>
                      <small>Default weight</small>
                      <strong>
                        <% if (lot.resolved_default_production_weight !== null && lot.resolved_default_production_weight !== undefined) { %>
                          <%= formatWeight(lot.resolved_default_production_weight) %>
                        <% } else { %>
                          Category
                        <% } %>
                      </strong>
                    </span>
                  </article>

                  <article>
                    <span class="lot-summary-icon" aria-hidden="true">＋</span>
                    <span><small>Created</small><strong><%= formatDate(lot.created_at) %></strong></span>
                  </article>
                </div>
              </div>

              <div class="lot-validation-check-row" aria-label="Validation check">
                <div class="lot-validation-check-label">
                  <span>Validation Check</span>
                  <small>
                    <%= formatNumber(validationReport.requirementCount) %> active requirements ·
                    <%= formatNumber(validationReport.unitsChecked) %> units checked
                  </small>
                </div>

                <div class="lot-validation-check-stats">
                  <span class="accepted"><small>Accepted</small><strong><%= formatNumber(validationReport.acceptedCount) %></strong></span>
                  <span class="rejected"><small>Rejected</small><strong><%= formatNumber(validationReport.rejectedCount) %></strong></span>
                  <span class="review"><small>Needs Review</small><strong><%= formatNumber(validationReport.needsReviewCount) %></strong></span>
                  <span class="open"><small>Open</small><strong><%= formatNumber(validationReport.openCount) %></strong></span>
                </div>
              </div>
            </div>

            <aside class="lot-state-context" aria-label="Lot context">
              <h2>Lot Context</h2>
              <dl>
                <div>
                  <dt>Parent Lot</dt>
                  <dd>
                    <% if (lotRelationships.parentLot) { %>
                      <a href="/management/lots/<%= lotRelationships.parentLot.lot_id %>">
                        <%= lotRelationships.parentLot.lot_name %>
                      </a>
                    <% } else { %>
                      Root lot
                    <% } %>
                  </dd>
                </div>

                <div>
                  <dt>Child Lots</dt>
                  <dd><%= formatNumber(lotRelationships.directChildLots.length) %></dd>
                </div>

                <div>
                  <dt>Sibling Lots</dt>
                  <dd><%= formatNumber(lotRelationships.siblingLots.length) %></dd>
                </div>
              </dl>
            </aside>
          </section>

          <% if (lotRelationships.directChildLots.length > 0) { %>
            <section class="site-clean-section lot-detail-section">
              <div class="site-clean-section-heading">
                <h2>Direct Child Lots</h2>
              </div>

              <div class="compact-lot-list">
                <% lotRelationships.directChildLots.forEach((childLot) => { %>
                  <a href="/management/lots/<%= childLot.lot_id %>" class="compact-lot-item">
                    <strong class="lot-display-name"><%= childLot.lot_name %></strong>
                    <span><%= childLot.lot_type_label || 'No type' %><%= Number(childLot.is_active) === 1 ? '' : ' · Hidden' %></span>
                  </a>
                <% }) %>
              </div>
            </section>
          <% } %>

          <section class="site-clean-section lot-detail-section">
            <div class="site-clean-section-heading">
              <h2>Units Inside This Lot</h2>
            </div>

            <% if (!validationReport.supported) { %>
              <div class="message error">
                <p><%= validationReport.message %></p>
              </div>
            <% } else if (validationReport.unitsChecked === 0) { %>
              <div class="message success">
                <p>No units are currently assigned to this lot.</p>
              </div>
            <% } else { %>
              <div class="unit-validation-list">
                <% validationReport.units.forEach((unit) => { %>
                  <details class="unit-validation-item">
                    <summary>
                      <span class="unit-validation-main">
                        <strong><%= unit.label %></strong>
                        <small><%= unit.subLabel %></small>
                      </span>

                      <span class="validation-badge <%= unit.status %>">
                        <%= unit.statusLabel %>
                      </span>
                    </summary>

                    <% if (validationReport.requirementCount === 0) { %>
                      <div class="unit-validation-empty">
                        No active requirements exist for this lot.
                      </div>
                    <% } else { %>
                      <div class="table-card unit-check-table">
                        <table>
                          <thead>
                            <tr>
                              <th>Requirement</th>
                              <th>Rule</th>
                              <th>Required</th>
                              <th>Actual</th>
                              <th>Result</th>
                              <th>Notes</th>
                            </tr>
                          </thead>

                          <tbody>
                            <% unit.checks.forEach((check) => { %>
                              <tr>
                                <td><%= check.requirementKey %></td>
                                <td><%= check.operatorCode %></td>
                                <td><%= check.requiredValue || '—' %></td>
                                <td>
                                  <%= check.actualValue || '—' %>
                                  <% if (check.sourceColumn && check.sourceColumn !== '—') { %>
                                    <br />
                                    <span class="table-muted-line">Column: <%= check.sourceColumn %></span>
                                  <% } %>
                                </td>
                                <td>
                                  <span class="validation-badge <%= check.status %>">
                                    <%= check.statusLabel %>
                                  </span>
                                </td>
                                <td><%= check.message %></td>
                              </tr>
                            <% }) %>
                          </tbody>
                        </table>
                      </div>
                    <% } %>
                  </details>
                <% }) %>
              </div>

              <% if (validationReport.unitsChecked >= validationReport.unitLimit) { %>
                <div class="message error">
                  <p>
                    Validation is currently limited to the first <%= formatNumber(validationReport.unitLimit) %> units
                    for safety. We can add pagination later if needed.
                  </p>
                </div>
              <% } %>
            <% } %>
          </section>


        </main>

        <div id="modal-root"></div>
      </div>
    </div>
  </body>
</html>