<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { pageTitle }) %>
  <link rel="stylesheet" href="/css/lots.css" />
  <link rel="stylesheet" href="/css/modal.css" />
  <script defer src="/js/modal.js"></script>
  <script defer src="/js/lot-form.js"></script>
  <script defer src="/js/lot-requirements.js"></script>

  <body>
    <div class="app-shell">
      <%- include('../partials/sidebar', { currentNav }) %>

      <div class="app-main">
        <%- include('../partials/topbar', { pageTitle }) %>

        <main class="content-shell">
          <nav class="lot-breadcrumbs" aria-label="Lot breadcrumb">
            <a href="/management/lots">Lots</a>

            <% lotRelationships.breadcrumbs.forEach((breadcrumbLot, index) => { %>
              <span aria-hidden="true">›</span>

              <% if (index === lotRelationships.breadcrumbs.length - 1) { %>
                <strong><%= breadcrumbLot.lot_name %></strong>
              <% } else { %>
                <a href="/management/lots/<%= breadcrumbLot.lot_id %>"><%= breadcrumbLot.lot_name %></a>
              <% } %>
            <% }) %>
          </nav>

          <section class="dashboard-hero accent-green">
            <div>
              <p class="eyebrow">Lot Details</p>
              <h2 class="lot-detail-title"><%= lot.lot_name %></h2>
              <p>
                Review lot details, requirements, attached units, and validation previews from a cleaner Management view.
              </p>
            </div>

            <div class="hero-badge">
              <span>Enforcement</span>
              <strong><%= enforcementSummary.policyLabel %></strong>
            </div>
          </section>

          <div class="lot-detail-action-bar">
            <a class="secondary-button" href="/management/lots">Back to Lots</a>
            <a class="primary-button" href="/management/lots/<%= lot.lot_id %>/edit/modal" hx-get="/management/lots/<%= lot.lot_id %>/edit/modal" hx-target="#modal-root" hx-swap="innerHTML">Edit Lot</a>
            <% if (Number(lot.unitCount || 0) === 0 && lotRelationships.directChildLots.length === 0) { %>
              <a class="secondary-button danger-button" href="/management/lots/<%= lot.lot_id %>/delete/modal" hx-get="/management/lots/<%= lot.lot_id %>/delete/modal" hx-target="#modal-root" hx-swap="innerHTML">Delete Lot</a>
            <% } %>
          </div>

          <section class="dashboard-grid lot-detail-summary-grid">
            <article class="dashboard-card">
              <p class="card-label">Lot Type</p>
              <h3><%= lot.lot_type_label || '—' %></h3>
              <p>Lot profile and planning details.</p>
            </article>

            <article class="dashboard-card">
              <p class="card-label">Units</p>
              <h3><%= formatNumber(lot.unitCount) %></h3>
              <p>
                <% if (lot.isUnlimited) { %>
                  Open / unlimited lot.
                <% } else { %>
                  Goal: <%= formatNumber(lot.unitGoal) %> units.
                <% } %>
              </p>
            </article>

            <article class="dashboard-card">
              <p class="card-label">Progress</p>
              <h3>
                <% if (lot.isUnlimited) { %>
                  Open
                <% } else { %>
                  <%= formatNumber(lot.progressPercent) %>%
                <% } %>
              </h3>
              <p>
                <% if (lot.isFull) { %>
                  This lot has reached its unit goal.
                <% } else { %>
                  This lot can still accept more units.
                <% } %>
              </p>
            </article>
          </section>

          <section class="content-card">
            <div class="content-header">
              <div>
                <p class="eyebrow">Enforcement</p>
                <h2>Requirement Enforcement Preview</h2>
              </div>
            </div>

            <div class="enforcement-banner <%= enforcementSummary.policyStatus %>">
              <div>
                <span><%= enforcementSummary.enforcementModeLabel %></span>
                <strong><%= enforcementSummary.policyLabel %></strong>
                <p><%= enforcementSummary.policyMessage %></p>
              </div>
            </div>

            <div class="validation-note">
              <strong>Important:</strong>
              <%= enforcementSummary.enforcementModeMessage %>
            </div>

            <div class="enforcement-summary-grid">
              <article class="enforcement-summary-card allowed">
                <span>Would Allow</span>
                <strong><%= formatNumber(enforcementSummary.allowedCount) %></strong>
              </article>

              <article class="enforcement-summary-card blocked">
                <span>Would Block</span>
                <strong><%= formatNumber(enforcementSummary.blockedCount) %></strong>
              </article>

              <article class="enforcement-summary-card review">
                <span>Needs Review</span>
                <strong><%= formatNumber(enforcementSummary.reviewCount) %></strong>
              </article>

              <article class="enforcement-summary-card override">
                <span>Override Needed</span>
                <strong><%= formatNumber(enforcementSummary.overrideRequiredCount) %></strong>
              </article>
            </div>

            <% if (enforcementSummary.unitDecisions.length > 0) { %>
              <h2 class="section-title">Unit Enforcement Decisions</h2>

              <div class="table-card validation-table-card">
                <table>
                  <thead>
                    <tr>
                      <th>Unit</th>
                      <th>Validation</th>
                      <th>Decision</th>
                      <th>Override</th>
                      <th>Reason</th>
                    </tr>
                  </thead>

                  <tbody>
                    <% enforcementSummary.unitDecisions.forEach((unitDecision) => { %>
                      <tr>
                        <td>
                          <strong><%= unitDecision.label %></strong>
                          <br />
                          <span class="table-muted-line"><%= unitDecision.subLabel %></span>
                        </td>

                        <td>
                          <span class="validation-badge <%= unitDecision.validationStatus %>">
                            <%= unitDecision.validationStatusLabel %>
                          </span>
                        </td>

                        <td>
                          <span class="enforcement-badge <%= unitDecision.decision %>">
                            <%= unitDecision.decisionLabel %>
                          </span>
                        </td>

                        <td>
                          <% if (unitDecision.requiresOverride) { %>
                            <span class="pill bad">Required</span>
                          <% } else { %>
                            <span class="pill good">Not needed</span>
                          <% } %>
                        </td>

                        <td><%= unitDecision.message %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } else { %>
              <div class="message success">
                <p>No unit enforcement decisions are available yet because this lot currently has no units to check.</p>
              </div>
            <% } %>
          </section>

          <section class="content-card">
            <div class="content-header">
              <div>
                <p class="eyebrow">Relationship</p>
                <h2>Lot Context</h2>
              </div>
            </div>

            <div class="lot-context-grid">
              <article class="lot-context-card">
                <span>Parent Lot</span>

                <% if (lotRelationships.parentLot) { %>
                  <strong>
                    <a href="/management/lots/<%= lotRelationships.parentLot.lot_id %>">
                      <%= lotRelationships.parentLot.lot_name %>
                    </a>
                  </strong>
                  <small>
                    This lot is a child/sub-lot under the parent shown above.
                  </small>
                <% } else { %>
                  <strong>No parent</strong>
                  <small>This is a top-level parent lot.</small>
                <% } %>
              </article>

              <article class="lot-context-card">
                <span>Child Lots</span>
                <strong><%= formatNumber(lotRelationships.directChildLots.length) %></strong>
                <small>Direct sub-lots under this lot.</small>
              </article>

              <article class="lot-context-card">
                <span>Sibling Lots</span>
                <strong><%= formatNumber(lotRelationships.siblingLots.length) %></strong>
                <small>Other lots under the same parent.</small>
              </article>
            </div>

            <% if (lotRelationships.directChildLots.length > 0) { %>
              <h2 class="section-title">Direct Child Lots</h2>

              <div class="compact-lot-list">
                <% lotRelationships.directChildLots.forEach((childLot) => { %>
                  <a href="/management/lots/<%= childLot.lot_id %>" class="compact-lot-item">
                    <strong class="lot-display-name"><%= childLot.lot_name %></strong>
                      <span><%= childLot.lot_type_label || 'No type' %></span>
                  </a>
                <% }) %>
              </div>
            <% } %>
          </section>

          <section class="content-card">
            <div class="content-header">
              <div>
                <p class="eyebrow">Validation</p>
                <h2>Unit-to-Lot Validation Summary</h2>
              </div>
            </div>

            <div class="validation-note">
              <strong>Read-only preview:</strong>
              <%= validationReport.message %>
            </div>

            <div class="validation-summary-grid">
              <article class="validation-summary-card accepted">
                <span>Accepted</span>
                <strong><%= formatNumber(validationReport.acceptedCount) %></strong>
              </article>

              <article class="validation-summary-card rejected">
                <span>Rejected</span>
                <strong><%= formatNumber(validationReport.rejectedCount) %></strong>
              </article>

              <article class="validation-summary-card review">
                <span>Needs Review</span>
                <strong><%= formatNumber(validationReport.needsReviewCount) %></strong>
              </article>

              <article class="validation-summary-card open">
                <span>Open</span>
                <strong><%= formatNumber(validationReport.openCount) %></strong>
              </article>
            </div>

            <% if (requirementValidationSummary.length > 0) { %>
              <h2 class="section-title">Requirement Pass / Fail Summary</h2>

              <div class="table-card validation-table-card">
                <table>
                  <thead>
                    <tr>
                      <th>Requirement</th>
                      <th>Rule</th>
                      <th>Required Value</th>
                      <th>Passed</th>
                      <th>Rejected</th>
                      <th>Needs Review</th>
                    </tr>
                  </thead>

                  <tbody>
                    <% requirementValidationSummary.forEach((summaryRow) => { %>
                      <tr>
                        <td>
                          <strong><%= summaryRow.requirementLabel %></strong>
                          <% if (summaryRow.notes) { %>
                            <br />
                            <span class="table-muted-line"><%= summaryRow.notes %></span>
                          <% } %>
                        </td>
                        <td><%= summaryRow.operatorLabel %></td>
                        <td><%= summaryRow.requiredValue || '—' %></td>
                        <td><span class="validation-mini-count accepted"><%= formatNumber(summaryRow.acceptedCount) %></span></td>
                        <td><span class="validation-mini-count rejected"><%= formatNumber(summaryRow.rejectedCount) %></span></td>
                        <td><span class="validation-mini-count review"><%= formatNumber(summaryRow.needsReviewCount) %></span></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } %>
          </section>

          <section class="content-card">
            <div class="content-header">
              <div>
                <p class="eyebrow">Units</p>
                <h2>Units Inside This Lot</h2>
              </div>
            </div>

            <% if (!validationReport.supported) { %>
              <div class="message error">
                <p><%= validationReport.message %></p>
              </div>
            <% } else if (validationReport.unitsChecked === 0) { %>
              <div class="message success">
                <p>No units are currently assigned to this lot.</p>
              </div>
            <% } else { %>
              <div class="unit-validation-list">
                <% validationReport.units.forEach((unit) => { %>
                  <details class="unit-validation-item">
                    <summary>
                      <span class="unit-validation-main">
                        <strong><%= unit.label %></strong>
                        <small><%= unit.subLabel %></small>
                      </span>

                      <span class="validation-badge <%= unit.status %>">
                        <%= unit.statusLabel %>
                      </span>
                    </summary>

                    <% if (validationReport.requirementCount === 0) { %>
                      <div class="unit-validation-empty">
                        No active requirements exist for this lot.
                      </div>
                    <% } else { %>
                      <div class="table-card unit-check-table">
                        <table>
                          <thead>
                            <tr>
                              <th>Requirement</th>
                              <th>Rule</th>
                              <th>Required</th>
                              <th>Actual</th>
                              <th>Result</th>
                              <th>Notes</th>
                            </tr>
                          </thead>

                          <tbody>
                            <% unit.checks.forEach((check) => { %>
                              <tr>
                                <td><%= check.requirementKey %></td>
                                <td><%= check.operatorCode %></td>
                                <td><%= check.requiredValue || '—' %></td>
                                <td>
                                  <%= check.actualValue || '—' %>
                                  <% if (check.sourceColumn && check.sourceColumn !== '—') { %>
                                    <br />
                                    <span class="table-muted-line">Column: <%= check.sourceColumn %></span>
                                  <% } %>
                                </td>
                                <td>
                                  <span class="validation-badge <%= check.status %>">
                                    <%= check.statusLabel %>
                                  </span>
                                </td>
                                <td><%= check.message %></td>
                              </tr>
                            <% }) %>
                          </tbody>
                        </table>
                      </div>
                    <% } %>
                  </details>
                <% }) %>
              </div>

              <% if (validationReport.unitsChecked >= validationReport.unitLimit) { %>
                <div class="message error">
                  <p>
                    Validation is currently limited to the first <%= formatNumber(validationReport.unitLimit) %> units
                    for safety. We can add pagination later if needed.
                  </p>
                </div>
              <% } %>
            <% } %>
          </section>

          <section class="content-card">
            <div class="content-header">
              <div>
                <p class="eyebrow">Requirements</p>
                <h2>Lot Requirement Rules</h2>
              </div>

              <a class="primary-button" href="/management/lots/<%= lot.lot_id %>/requirements/new/modal" hx-get="/management/lots/<%= lot.lot_id %>/requirements/new/modal" hx-target="#modal-root" hx-swap="innerHTML">Add Requirement</a>
            </div>

            <% if (successMessage) { %>
              <div class="message success">
                <%= successMessage %>
              </div>
            <% } %>

            <% if (errorMessages.length > 0) { %>
              <div class="message error">
                <% errorMessages.forEach((errorMessage) => { %>
                  <p><%= errorMessage %></p>
                <% }) %>
              </div>
            <% } %>

            <div class="table-card" style="margin-top: 20px;">
              <table>
                <thead>
                  <tr>
                    <th>Requirement</th>
                    <th>Rule</th>
                    <th>Required Value</th>
                    <th>Status</th>
                    <th>Notes</th>
                    <th>Actions</th>
                  </tr>
                </thead>

                <tbody>
                  <% if (requirements.length === 0) { %>
                    <tr>
                      <td colspan="6">No requirements have been added to this lot yet.</td>
                    </tr>
                  <% } %>

                  <% requirements.forEach((requirement) => { %>
                    <tr>
                      <td><%= requirement.requirement_key || '—' %></td>
                      <td><%= requirement.operator_code || 'equals' %></td>
                      <td><%= requirement.required_value || '—' %></td>
                      <td>
                        <% if (Number(requirement.is_active) === 1) { %>
                          <span class="pill good">Active</span>
                        <% } else { %>
                          <span class="pill bad">Inactive</span>
                        <% } %>
                      </td>
                      <td><%= requirement.notes || '—' %></td>
                      <td>
                        <a class="secondary-button" href="/management/lots/<%= lot.lot_id %>/requirements/<%= requirement.lot_requirement_id %>/edit/modal" hx-get="/management/lots/<%= lot.lot_id %>/requirements/<%= requirement.lot_requirement_id %>/edit/modal" hx-target="#modal-root" hx-swap="innerHTML">Edit</a>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </section>

          <section class="content-card">
            <div class="content-header">
              <div>
                <p class="eyebrow">Next</p>
                <h2>Step 2i Preview</h2>
              </div>
            </div>

            <div class="workflow-list">
              <div class="workflow-item active">
                <span></span>
                <div>
                  <strong>Tech unit creation/editing foundation</strong>
                  <p>
                    Next we can start the Tech workflow where users create or edit units and see lot validation
                    feedback before saving.
                  </p>
                </div>
              </div>

              <div class="workflow-item slate">
                <span></span>
                <div>
                  <strong>Management override workflow</strong>
                  <p>
                    After unit creation is connected, we can add override request and approval tracking.
                  </p>
                </div>
              </div>
            </div>
          </section>
        </main>

        <div id="modal-root"></div>
      </div>
    </div>
  </body>
</html>