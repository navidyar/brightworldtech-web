<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { pageTitle }) %>

  <body>
    <main class="page-shell">
      <section class="content-card narrow">
        <p class="eyebrow">500</p>
        <h1>Application Error</h1>
        <p><%= message %></p>

        <% if (error) { %>
          <pre><%= error.stack || error.message %></pre>
        <% } %>

        <a class="primary-button" href="/">Go Home</a>
      </section>
    </main>
  </body>
</html>