<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { pageTitle }) %>

  <body>
    <div class="app-shell">
      <%- include('../partials/sidebar', { currentNav }) %>

      <div class="app-main">
        <%- include('../partials/topbar', { pageTitle }) %>

        <main class="content-shell">
          <section class="dashboard-hero accent-<%= dashboard.accent %>">
            <div>
              <p class="eyebrow">Step 4f</p>
              <h2><%= dashboard.title %></h2>
              <p><%= dashboard.description %></p>
            </div>

            <div class="hero-badge">
              <span>Area</span>
              <strong><%= dashboard.menuLabel || dashboard.key %></strong>
            </div>
          </section>

          <%- include('../fragments/dashboard-live-region', { dashboardData, dashboardFilters, dashboardFilterOptions, dashboardFilterConfig }) %>

          <% if (dashboard.key === 'management') { %>
            <section class="content-card">
              <div class="content-header">
                <div>
                  <p class="eyebrow">Management Tools</p>
                  <h2>Current Management Areas</h2>
                </div>
              </div>

              <div class="dashboard-access-grid">
                <a class="role-dashboard-card accent-blue" href="/management/users">
                  <p>Management</p>
                  <h3>Users</h3>
                  <span>Create users, edit users, assign roles, deactivate employees, and manage pending setup accounts.</span>
                </a>

                <a class="role-dashboard-card accent-green" href="/management/lots">
                  <p>Management</p>
                  <h3>Lots</h3>
                  <span>Review lots, create lots, and manage lot requirements.</span>
                </a>

                <a class="role-dashboard-card accent-red" href="/management/overrides">
                  <p>Management</p>
                  <h3>Overrides</h3>
                  <span>Review pending unit/lot override requests.</span>
                </a>

                <a class="role-dashboard-card accent-slate" href="/management/config">
                  <p>Management</p>
                  <h3>Config Values</h3>
                  <span>Review selectable values used across the application.</span>
                </a>
              </div>
            </section>
          <% } %>
        </main>
      </div>
    </div>
  </body>
</html>
