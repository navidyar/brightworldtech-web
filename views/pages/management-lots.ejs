<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { pageTitle }) %>
  <link rel="stylesheet" href="/css/lots.css" />
  <link rel="stylesheet" href="/css/modal.css" />
  <script defer src="/js/modal.js"></script>
  <script defer src="/js/lot-form.js"></script>
  <script defer src="/js/lot-browser-tree.js"></script>

  <body>
    <%
      const lotsById = new Map();
      const childLotsByParentId = new Map();

      lots.forEach((lot) => {
        lotsById.set(String(lot.lot_id), lot);
      });

      lots.forEach((lot) => {
        const parentId = lot.parent_lot_id ? String(lot.parent_lot_id) : '';

        if (parentId && lotsById.has(parentId)) {
          if (!childLotsByParentId.has(parentId)) {
            childLotsByParentId.set(parentId, []);
          }

          childLotsByParentId.get(parentId).push(lot);
        }
      });

      function sortLotsByName(a, b) {
        return String(a.lot_name || '').localeCompare(String(b.lot_name || ''), undefined, {
          numeric: true,
          sensitivity: 'base'
        });
      }

      const rootLots = lots
        .filter((lot) => {
          const parentId = lot.parent_lot_id ? String(lot.parent_lot_id) : '';
          return !parentId || !lotsById.has(parentId);
        })
        .sort(sortLotsByName);

      const orderedLots = [];
      const visitedLotIds = new Set();

      function addLotAndChildren(lot, level) {
        const lotId = String(lot.lot_id);

        if (visitedLotIds.has(lotId)) {
          return;
        }

        visitedLotIds.add(lotId);

        orderedLots.push({
          ...lot,
          hierarchyLevel: level
        });

        const childLots = (childLotsByParentId.get(lotId) || []).slice().sort(sortLotsByName);

        childLots.forEach((childLot) => {
          addLotAndChildren(childLot, level + 1);
        });
      }

      rootLots.forEach((rootLot) => {
        addLotAndChildren(rootLot, 0);
      });

      lots.forEach((lot) => {
        if (!visitedLotIds.has(String(lot.lot_id))) {
          addLotAndChildren(lot, 0);
        }
      });

      function getChildLots(lot) {
        return childLotsByParentId.get(String(lot.lot_id)) || [];
      }

      function getParentLot(lot) {
        if (!lot.parent_lot_id) {
          return null;
        }

        return lotsById.get(String(lot.parent_lot_id)) || null;
      }
    %>

    <div class="app-shell">
      <%- include('../partials/sidebar', { currentNav }) %>

      <div class="app-main">
        <%- include('../partials/topbar', { pageTitle }) %>

        <main class="content-shell lot-management-page">
          <section class="page-heading lot-management-page-heading">
            <h1>Lot Management</h1>
          </section>

          <section class="lot-summary-panel" aria-label="Lot totals">
            <div class="lot-summary-primary">
              <span>Total lots</span>
              <strong><%= formatNumber(summary.lotCount) %></strong>
              <small>All lot records currently available to Management</small>
            </div>

            <div class="lot-summary-stats">
              <article>
                <span class="lot-summary-icon" aria-hidden="true">◉</span>
                <span><small>Visible lots</small><strong><%= formatNumber(summary.activeLotCount) %></strong></span>
              </article>

              <article>
                <span class="lot-summary-icon" aria-hidden="true">◌</span>
                <span><small>Closed lots</small><strong><%= formatNumber(summary.closedLotCount || 0) %></strong></span>
              </article>

              <article>
                <span class="lot-summary-icon" aria-hidden="true">◒</span>
                <span><small>Hidden lots</small><strong><%= formatNumber(summary.hiddenLotCount || 0) %></strong></span>
              </article>

              <article>
                <span class="lot-summary-icon" aria-hidden="true">▤</span>
                <span><small>Units in lots</small><strong><%= formatNumber(summary.totalUnits) %></strong></span>
              </article>

              <article>
                <span class="lot-summary-icon" aria-hidden="true">✓</span>
                <span><small>Requirements</small><strong><%= formatNumber(summary.totalRequirements) %></strong></span>
              </article>
            </div>
          </section>

          <section class="site-clean-section lot-browser-section">
            <div class="site-clean-section-heading lot-browser-header">
              <div>
                <h2>Lot Browser</h2>
              </div>

              <div class="lot-browser-header-actions site-clean-actions">
                <% if (showHidden) { %>
                  <a class="secondary-button" href="/management/lots">Hide Hidden Lots</a>
                <% } else { %>
                  <a class="secondary-button" href="/management/lots?showHidden=1">Show Hidden Lots</a>
                <% } %>
                <a class="primary-button" href="/management/lots/new/modal" hx-get="/management/lots/new/modal" hx-target="#modal-root" hx-swap="innerHTML">Create Lot</a>
              </div>
            </div>

            <% if (successMessage) { %>
              <div class="message success">
                <%= successMessage %>
              </div>
            <% } %>

            <div class="table-card">
              <table class="management-lots-table">
                <thead>
                  <tr>
                    <th>Lot</th>
                    <th>Created</th>
                    <th>Type</th>
                    <th>Default Grade</th>
                    <th>Default Weight</th>
                    <th>Units</th>
                    <th>Goal</th>
                    <th>Progress</th>
                    <th>Requirements</th>
                    <th>Deadline</th>
                    <th>Status</th>
                    <th>Label Format</th>
                    <th>Actions</th>
                  </tr>
                </thead>

                <tbody>
                  <% if (orderedLots.length === 0) { %>
                    <tr>
                      <td colspan="13">No lots found.</td>
                    </tr>
                  <% } %>

                  <% orderedLots.forEach((lot) => { %>
                    <%
                      const parentLot = getParentLot(lot);
                      const childLots = getChildLots(lot);
                      const hierarchyLevel = Math.min(Number(lot.hierarchyLevel || 0), 6);
                    %>

                    <tr class="<%= ['lot-clickable-row', hierarchyLevel > 0 ? 'lot-child-row lot-tree-child-row' : 'lot-parent-row lot-tree-root-row', `lot-level-${Math.min(hierarchyLevel, 6)}`, Number(lot.is_active) === 1 ? '' : 'lot-hidden-row', Number(lot.is_closed) === 1 ? 'lot-closed-row' : ''].filter(Boolean).join(' ') %>" data-lot-id="<%= lot.lot_id %>" data-parent-lot-id="<%= parentLot ? parentLot.lot_id : '' %>" data-lot-level="<%= hierarchyLevel %>" data-view-href="/management/lots/<%= lot.lot_id %>" tabindex="0" role="link" aria-label="View <%= lot.lot_name %>">
                      <td class="lot-hierarchy-cell" style="--lot-level: <%= hierarchyLevel %>;">
                        <div class="lot-hierarchy-wrap">
                          <% if (childLots.length > 0) { %>
                            <button class="lot-tree-toggle" type="button" aria-expanded="false" aria-label="Show child lots for <%= lot.lot_name %>">
                              <span class="lot-tree-toggle-visual" aria-hidden="true">
                                <span class="lot-tree-toggle-icon" aria-hidden="true">▸</span>
                              </span>
                            </button>
                          <% } else { %>
                            <span class="lot-tree-toggle-spacer" aria-hidden="true"></span>
                          <% } %>

                          <div class="lot-hierarchy-main">
                            <strong class="lot-display-name"><%= lot.lot_name %></strong>


                            <% if (parentLot) { %>
                              <br />
                              <span class="table-muted-line">
                                Parent:
                                <a href="/management/lots/<%= parentLot.lot_id %>"><%= parentLot.lot_name %></a>
                              </span>
                            <% } else if (childLots.length > 0) { %>
                              <br />
                              <span class="table-muted-line">
                                Parent lot · <%= childLots.length %> child lot<%= childLots.length === 1 ? '' : 's' %>
                              </span>
                            <% } else { %>
                              <br />
                              <span class="table-muted-line">No parent lot</span>
                            <% } %>
                          </div>
                        </div>
                      </td>

                      <td>
                        <strong><%= formatDate(lot.created_at) %></strong>
                        <br />
                        <span class="table-muted-line"><%= formatTime(lot.created_at) %></span>
                      </td>
                      <td><%= lot.lot_type_label || '—' %></td>
                      <td><%= lot.default_grade_label || '—' %></td>
                      <td>
                        <% if (lot.resolved_default_production_weight !== null && lot.resolved_default_production_weight !== undefined) { %>
                          <strong><%= formatWeight(lot.resolved_default_production_weight) %></strong>
                          <br />
                          <% if (lot.default_production_weight !== null && lot.default_production_weight !== undefined) { %>
                            <span class="table-muted-line">Custom lot default</span>
                          <% } else if (lot.default_production_weight_label) { %>
                            <span class="table-muted-line">Preset: <%= lot.default_production_weight_label %></span>
                          <% } %>
                        <% } else { %>
                          <span class="table-muted-line">Unit category default</span>
                        <% } %>
                      </td>
                      <td><%= formatNumber(lot.unitCount) %></td>

                      <td>
                        <% if (lot.isUnlimited) { %>
                          Unlimited
                        <% } else { %>
                          <%= formatNumber(lot.unitGoal) %>
                        <% } %>
                      </td>

                      <td>
                        <% if (lot.isUnlimited) { %>
                          —
                        <% } else { %>
                          <%= formatNumber(lot.progressPercent) %>%
                          <% if (lot.isFull) { %>
                            <br />
                            <span class="pill good">Full</span>
                          <% } %>
                        <% } %>
                      </td>

                      <td><%= formatNumber(lot.requirement_count) %></td>
                      <td><%= formatDateTime(lot.deadline) %></td>

                      <td>
                        <% if (Number(lot.is_closed) === 1) { %>
                          <span class="pill bad">Closed</span>
                        <% } else { %>
                          <span class="pill good">Open</span>
                        <% } %>
                        <% if (Number(lot.is_active) !== 1) { %>
                          <br />
                          <span class="pill bad">Hidden</span>
                        <% } %>
                      </td>

                      <td><%= lot.label_format || '—' %></td>

                      <td>
                        <div class="lot-row-actions">
                          <a class="secondary-button" href="/management/lots/<%= lot.lot_id %>/edit/modal" hx-get="/management/lots/<%= lot.lot_id %>/edit/modal" hx-target="#modal-root" hx-swap="innerHTML">Edit</a>
                          <% if (Number(lot.is_closed) === 1) { %>
                            <a class="secondary-button" href="/management/lots/<%= lot.lot_id %>/reopen/modal" hx-get="/management/lots/<%= lot.lot_id %>/reopen/modal" hx-target="#modal-root" hx-swap="innerHTML">Reopen</a>
                          <% } else { %>
                            <a class="secondary-button" href="/management/lots/<%= lot.lot_id %>/close/modal" hx-get="/management/lots/<%= lot.lot_id %>/close/modal" hx-target="#modal-root" hx-swap="innerHTML">Close</a>
                          <% } %>
                          <% if (Number(lot.is_active) === 1) { %>
                            <a class="secondary-button" href="/management/lots/<%= lot.lot_id %>/hide/modal" hx-get="/management/lots/<%= lot.lot_id %>/hide/modal" hx-target="#modal-root" hx-swap="innerHTML">Hide</a>
                          <% } else { %>
                            <a class="secondary-button" href="/management/lots/<%= lot.lot_id %>/unhide/modal" hx-get="/management/lots/<%= lot.lot_id %>/unhide/modal" hx-target="#modal-root" hx-swap="innerHTML">Unhide</a>
                          <% } %>
                          <% if (Number(lot.unitCount || 0) === 0 && childLots.length === 0) { %>
                            <a class="secondary-button danger-button" href="/management/lots/<%= lot.lot_id %>/delete/modal" hx-get="/management/lots/<%= lot.lot_id %>/delete/modal" hx-target="#modal-root" hx-swap="innerHTML">Delete</a>
                          <% } %>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </section>
        </main>

        <div id="modal-root"></div>
      </div>
    </div>
  </body>
</html>