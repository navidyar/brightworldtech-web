<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { pageTitle }) %>

  <body>
    <div class="app-shell">
      <%- include('../partials/sidebar', { currentNav }) %>

      <div class="app-main">
        <%- include('../partials/topbar', { pageTitle }) %>

        <main class="content-shell">
          <section class="dashboard-hero">
            <div>
              <p class="eyebrow">Step 2f.1</p>
              <h2>User Management</h2>
              <p>
                Create users, assign roles, and generate one-time setup or reset links for account access.
              </p>
            </div>

            <div class="hero-badge">
              <span>Access</span>
              <strong>Admin / Management</strong>
            </div>
          </section>

          <section class="content-card">
            <div class="content-header">
              <div>
                <p class="eyebrow">Users</p>
                <h2>Application Users</h2>
              </div>

              <a class="primary-button" href="/management/users/new">Create User</a>
            </div>

            <% if (successMessage) { %>
              <div class="message success"><%= successMessage %></div>
            <% } %>

            <% if (errorMessages.length > 0) { %>
              <div class="message error">
                <% errorMessages.forEach((errorMessage) => { %>
                  <p><%= errorMessage %></p>
                <% }) %>
              </div>
            <% } %>

            <div class="table-card" style="margin-top: 20px;">
              <table>
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th>Roles</th>
                    <th>Password</th>
                    <th>Last Login</th>
                    <th>Actions</th>
                  </tr>
                </thead>

                <tbody>
                  <% if (users.length === 0) { %>
                    <tr>
                      <td colspan="7">No users found.</td>
                    </tr>
                  <% } %>

                  <% users.forEach((user) => { %>
                    <tr>
                      <td><%= user.first_name %> <%= user.last_name %></td>
                      <td><%= user.email %></td>
                      <td>
                        <% if (user.account_status_code === 'active') { %>
                          <span class="pill good">Active</span>
                        <% } else { %>
                          <span class="pill bad"><%= user.account_status_label || user.account_status_code || 'Unknown' %></span>
                        <% } %>
                      </td>
                      <td><%= user.role_names || 'No roles' %></td>
                      <td><%= user.has_password ? 'Created' : 'Pending setup' %></td>
                      <td><%= formatDateTime(user.last_login_at) %></td>
                      <td>
                        <form method="post" action="/management/users/<%= user.user_id %>/setup-link">
                          <button type="submit" class="logout-button">
                            <%= user.has_password ? 'Generate Reset Link' : 'Generate Setup Link' %>
                          </button>
                        </form>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </section>

          <section class="content-card">
            <div class="content-header">
              <div>
                <p class="eyebrow">Account Recovery</p>
                <h2>How Reset Links Work</h2>
              </div>
            </div>

            <div class="workflow-list">
              <div class="workflow-item active">
                <span></span>
                <div>
                  <strong>Initial setup links</strong>
                  <p>
                    Users without passwords receive a one-time setup link so they can create their first password.
                  </p>
                </div>
              </div>

              <div class="workflow-item slate">
                <span></span>
                <div>
                  <strong>Password reset links</strong>
                  <p>
                    Users who already have passwords receive a one-time reset link so they can set a new password.
                  </p>
                </div>
              </div>
            </div>
          </section>
        </main>
      </div>
    </div>
  </body>
</html>