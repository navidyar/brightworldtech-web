<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { pageTitle, stylesheets: ['/css/modal.css?v=step5e-config-crud'] }) %>

  <body>
    <div class="app-shell">
      <%- include('../partials/sidebar', { currentNav }) %>

      <div class="app-main">
        <%- include('../partials/topbar', { pageTitle }) %>

        <main class="content-shell">
          <section class="dashboard-hero accent-slate">
            <div>
              <p class="eyebrow">Step 5e</p>
              <h2>Configuration Values</h2>
              <p>
                Review, create, edit, activate, and deactivate app configuration values. Active/inactive
                status replaces hard deletion so existing unit and lot history stays intact.
              </p>
            </div>

            <div class="hero-badge">
              <span>Active Values</span>
              <strong><%= formatNumber(summary.activeValueCount || 0) %></strong>
            </div>
          </section>

          <section class="dashboard-grid">
            <article class="dashboard-card">
              <p class="card-label">Categories</p>
              <h3><%= formatNumber(summary.categoryCount) %></h3>
              <p>Config groups found in the database.</p>
            </article>

            <article class="dashboard-card">
              <p class="card-label">Active Values</p>
              <h3><%= formatNumber(summary.activeValueCount || 0) %></h3>
              <p>Selectable values currently available to the application.</p>
            </article>

            <article class="dashboard-card">
              <p class="card-label">Inactive Values</p>
              <h3><%= formatNumber(summary.inactiveValueCount || 0) %></h3>
              <p><%= includeInactiveValues ? 'Inactive values are currently visible.' : 'Inactive values are hidden by default.' %></p>
            </article>
          </section>

          <section class="content-card config-values-control-card">
            <div class="content-header config-values-control-header">
              <div>
                <p class="eyebrow">Management</p>
                <h2>Configuration Controls</h2>
                <p>
                  Admin users can now create and edit config values. Use active/inactive for normal lifecycle
                  changes instead of deleting values that may be referenced by existing records.
                </p>
              </div>

              <div class="config-values-actions">
                <a class="primary-button" href="/management/config/values/new/modal?includeInactive=<%= includeInactiveValues ? '1' : '0' %>" hx-get="/management/config/values/new/modal?includeInactive=<%= includeInactiveValues ? '1' : '0' %>" hx-target="#modal-root" hx-swap="innerHTML">Create Config Value</a>

                <% if (includeInactiveValues) { %>
                  <a class="secondary-button" href="/management/config">Hide inactive values</a>
                <% } else { %>
                  <a class="secondary-button" href="/management/config?includeInactive=1">Show inactive values</a>
                <% } %>
              </div>
            </div>
          </section>

          <section class="content-card">
            <div class="content-header">
              <div>
                <p class="eyebrow">Configuration</p>
                <h2>Configuration Groups</h2>
              </div>
            </div>

            <div class="config-section-list">
              <% if (categorySections.length === 0) { %>
                <div class="workflow-item warning">
                  <span></span>
                  <div>
                    <strong>No config categories found</strong>
                    <p>The config tables exist, but no categories were returned.</p>
                  </div>
                </div>
              <% } %>

              <% categorySections.forEach((section) => { %>
                <section class="config-section">
                  <div class="config-section-header">
                    <div>
                      <p class="eyebrow">Configuration Group</p>
                      <h3><%= section.label %></h3>
                      <p><%= section.description %></p>
                    </div>

                    <div class="config-section-stats">
                      <span><strong><%= formatNumber(section.categoryCount) %></strong> categories</span>
                      <span><strong><%= formatNumber(section.activeValueCount) %></strong> active</span>
                      <span><strong><%= formatNumber(section.inactiveValueCount) %></strong> inactive</span>
                    </div>
                  </div>

                  <div class="workflow-list">
                    <% section.categories.forEach((category) => { %>
                      <div class="workflow-item slate config-category-card">
                        <span></span>
                        <div class="config-category-content">
                          <div class="config-category-title-row">
                            <div>
                              <strong><%= category.label || category.code %></strong>
                              <p>
                                <code><%= category.code %></code>
                                ·
                                <%= formatNumber(category.activeValueCount) %> active
                                <% if (category.inactiveValueCount > 0) { %>
                                  · <%= formatNumber(category.inactiveValueCount) %> inactive
                                <% } %>
                                <% if (!category.isActive) { %>
                                  · inactive category
                                <% } %>
                              </p>
                            </div>

                            <div class="config-category-pills">
                              <% if (category.isActive) { %>
                                <span class="pill good">Active</span>
                              <% } else { %>
                                <span class="pill bad">Inactive</span>
                              <% } %>

                              <% if (category.hiddenInactiveValueCount > 0) { %>
                                <span class="pill muted"><%= formatNumber(category.hiddenInactiveValueCount) %> hidden</span>
                              <% } %>

                              <a class="secondary-button config-inline-action" href="/management/config/values/new/modal?categoryId=<%= category.config_category_id %>&includeInactive=<%= includeInactiveValues ? '1' : '0' %>" hx-get="/management/config/values/new/modal?categoryId=<%= category.config_category_id %>&includeInactive=<%= includeInactiveValues ? '1' : '0' %>" hx-target="#modal-root" hx-swap="innerHTML">Add Value</a>
                            </div>
                          </div>

                          <% if (category.description) { %>
                            <p><%= category.description %></p>
                          <% } %>

                          <div class="table-card config-values-table-card">
                            <table>
                              <thead>
                                <tr>
                                  <th>Label</th>
                                  <th>Code</th>
                                  <th>Value</th>
                                  <th>Status</th>
                                  <th>Description</th>
                                  <th>Actions</th>
                                </tr>
                              </thead>

                              <tbody>
                                <% if (category.values.length === 0) { %>
                                  <tr>
                                    <td colspan="6">
                                      <% if (category.inactiveValueCount > 0 && !includeInactiveValues) { %>
                                        This category only has inactive values. Use Show inactive values to review them.
                                      <% } else { %>
                                        No values in this category.
                                      <% } %>
                                    </td>
                                  </tr>
                                <% } %>

                                <% category.values.forEach((value) => { %>
                                  <tr class="<%= value.isActive ? '' : 'config-value-row--inactive' %>">
                                    <td><%= value.label || value.code %></td>
                                    <td><code><%= value.code %></code></td>
                                    <td><%= value.value || '—' %></td>
                                    <td>
                                      <% if (value.isActive) { %>
                                        <span class="pill good">Active</span>
                                      <% } else { %>
                                        <span class="pill bad">Inactive</span>
                                      <% } %>
                                    </td>
                                    <td><%= value.description || '—' %></td>
                                    <td>
                                      <div class="config-value-row-actions">
                                        <a class="secondary-button" href="/management/config/values/<%= value.config_value_id %>/edit/modal?includeInactive=<%= includeInactiveValues ? '1' : '0' %>" hx-get="/management/config/values/<%= value.config_value_id %>/edit/modal?includeInactive=<%= includeInactiveValues ? '1' : '0' %>" hx-target="#modal-root" hx-swap="innerHTML">Edit</a>

                                        <% if (value.isActive) { %>
                                          <a class="secondary-button danger-button" href="/management/config/values/<%= value.config_value_id %>/deactivate/modal?includeInactive=<%= includeInactiveValues ? '1' : '0' %>" hx-get="/management/config/values/<%= value.config_value_id %>/deactivate/modal?includeInactive=<%= includeInactiveValues ? '1' : '0' %>" hx-target="#modal-root" hx-swap="innerHTML">Deactivate</a>
                                        <% } else { %>
                                          <a class="secondary-button" href="/management/config/values/<%= value.config_value_id %>/activate/modal?includeInactive=<%= includeInactiveValues ? '1' : '0' %>" hx-get="/management/config/values/<%= value.config_value_id %>/activate/modal?includeInactive=<%= includeInactiveValues ? '1' : '0' %>" hx-target="#modal-root" hx-swap="innerHTML">Activate</a>
                                        <% } %>
                                      </div>
                                    </td>
                                  </tr>
                                <% }) %>
                              </tbody>
                            </table>
                          </div>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                </section>
              <% }) %>
            </div>
          </section>
        </main>

        <div id="modal-root"></div>
      </div>
    </div>

    <script defer src="/js/modal.js"></script>
  </body>
</html>
