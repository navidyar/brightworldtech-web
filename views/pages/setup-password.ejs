<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { pageTitle }) %>

  <body class="auth-body">
    <main class="auth-shell">
      <section class="auth-panel">
        <%
          const isResetLink = link && link.link_type_code === 'password_reset';
          const headingText = isResetLink ? 'Reset Password' : 'Set Password';
          const buttonText = isResetLink ? 'Reset Password' : 'Create Password';
          const introText = isResetLink
            ? 'Create a new password for your account.'
            : 'Create your first password for your account.';
        %>

        <div class="auth-brand">
          <div class="auth-logo-mark">BWT</div>
          <div>
            <p class="auth-kicker">Bright World Technologies</p>
            <h1><%= headingText %></h1>
          </div>
        </div>

        <% if (!link) { %>
          <div class="message error">
            This password link is invalid, expired, used, or revoked.
          </div>

          <div class="auth-actions">
            <a class="secondary-button" href="/login">Back to Sign In</a>
          </div>
        <% } else { %>
          <p class="auth-copy">
            <%= introText %>
            <br />
            Account:
            <strong><%= link.first_name %> <%= link.last_name %></strong>
            using
            <strong><%= link.email %></strong>.
          </p>

          <% if (errorMessages.length > 0) { %>
            <div class="message error">
              <% errorMessages.forEach((errorMessage) => { %>
                <p><%= errorMessage %></p>
              <% }) %>
            </div>
          <% } %>

          <form class="auth-form" method="post" action="/setup-password" autocomplete="off">
            <input type="hidden" name="token" value="<%= token %>" />

            <label class="form-field">
              <span>New Password</span>
              <input
                type="password"
                name="password"
                autocomplete="new-password"
                minlength="10"
                maxlength="25"
                required
              />
            </label>

            <label class="form-field">
              <span>Confirm Password</span>
              <input
                type="password"
                name="confirmPassword"
                autocomplete="new-password"
                minlength="10"
                maxlength="25"
                required
              />
            </label>

            <button class="auth-submit" type="submit"><%= buttonText %></button>
          </form>

          <p class="auth-footnote">
            Password must be 10 to 25 characters. This link can only be used once.
          </p>
        <% } %>
      </section>
    </main>
  </body>
</html>