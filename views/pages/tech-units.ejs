<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { pageTitle }) %>
  <link rel="stylesheet" href="/css/modal.css" />
  <link rel="stylesheet" href="/css/tech.css" />
  <script defer src="/js/modal.js"></script>
  <script defer src="/js/tech-units.js"></script>
  <script defer src="/js/tech-unit-form.js"></script>

  <body>
    <div class="app-shell">
      <%- include('../partials/sidebar', { currentNav }) %>

      <div class="app-main">
        <%- include('../partials/topbar', { pageTitle }) %>

        <main class="content-shell">
          <section class="dashboard-hero accent-green">
            <div>
              <p class="eyebrow">Step 2i.5</p>
              <h2>Tech Units</h2>
              <p>
                Create, edit, search, and review unit records. Units can only be assigned to lots that do not have child lots.
              </p>
            </div>

            <div class="hero-badge">
              <span>Loaded</span>
              <strong id="tech-units-loaded-count"><%= result.supported ? formatNumber(result.units.length) : '—' %></strong>
            </div>
          </section>

          <section class="content-card">
            <div class="content-header">
              <div>
                <p class="eyebrow">Tech</p>
                <h2>Unit Browser</h2>
              </div>

              <a class="primary-button" href="/tech/units/new" hx-get="/tech/units/new/modal" hx-target="#modal-root" hx-swap="innerHTML">
                Create Unit
              </a>
            </div>

            <% if (successMessage) { %>
              <div class="message success"><%= successMessage %></div>
            <% } %>

            <% if (!result.supported) { %>
              <div class="message error">
                <p><%= result.message %></p>
              </div>
            <% } else { %>
              <form class="tech-filter-form" method="get" action="/tech/units">
                <label class="form-field tech-filter-search-field">
                  <span>Search</span>
                  <textarea
                    name="search"
                    rows="4"
                    placeholder="Scan or paste asset tags, BIOS serials, or unit serials — one per line"
                  ><%= filters.search %></textarea>
                  <small class="field-hint">
                    Search one unit or several units at a time. Asset tags work with or without the <%= result.assetTagPrefix || 'BWT' %> prefix.
                  </small>
                </label>

                <label class="form-field">
                  <span>Assignable Lot</span>
                  <select name="lotId">
                    <option value="">All assignable lots</option>
                    <% result.lots.forEach((lot) => { %>
                      <option value="<%= lot.lot_id %>" <%= String(filters.lotId) === String(lot.lot_id) ? 'selected' : '' %>>
                        <%= lot.lot_name %>
                        <% if (lot.lot_number) { %>
                          - Lot #<%= lot.lot_number %>
                        <% } %>
                      </option>
                    <% }) %>
                  </select>
                  <small class="field-hint">
                    Lots with child lots are containers and are not assignable.
                  </small>
                </label>

                <div class="tech-filter-actions">
                  <button class="primary-button" type="submit">Apply Filters</button>
                  <a class="secondary-button" href="/tech/units">Clear</a>
                </div>
              </form>

              <div class="tech-table-shell" id="tech-units-list" hx-get="<%= tableUrl %>" hx-trigger="load, unit-saved from:body" hx-swap="innerHTML">
                <div class="tech-loading-card">
                  Loading units...
                </div>
              </div>
            <% } %>
          </section>

          <section class="content-card">
            <div class="content-header">
              <div>
                <p class="eyebrow">Next</p>
                <h2>Step 2j Preview</h2>
              </div>
            </div>

            <div class="workflow-list">
              <div class="workflow-item active">
                <span></span>
                <div>
                  <strong>Management override workflow</strong>
                  <p>
                    Next we can add override requests, approval tracking, and override reason history.
                  </p>
                </div>
              </div>

              <div class="workflow-item slate">
                <span></span>
                <div>
                  <strong>Enforcement integration</strong>
                  <p>
                    After the override foundation exists, we can connect lot validation to unit save actions.
                  </p>
                </div>
              </div>
            </div>
          </section>
        </main>

        <div id="modal-root"></div>
      </div>
    </div>
  </body>
</html>