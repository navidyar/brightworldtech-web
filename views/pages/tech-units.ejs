<%
  const formatTechUnitsPickerDate = (value) => {
    const normalized = String(value || '').slice(0, 10);
    if (!/^\d{4}-\d{2}-\d{2}$/.test(normalized)) {
      return 'Select date';
    }

    const date = new Date(`${normalized}T00:00:00.000Z`);
    return Number.isNaN(date.getTime()) ? 'Select date' : new Intl.DateTimeFormat('en-US', {
      month: 'short',
      day: 'numeric',
      year: 'numeric',
      timeZone: 'UTC'
    }).format(date);
  };
%>
<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { pageTitle }) %>
  <link rel="stylesheet" href="/css/modal.css" />
  <link rel="stylesheet" href="/css/tech.css" />
  <link rel="stylesheet" href="/css/tech-units-stage-a.css?v=20260708-stage-c" />
  <script defer src="/js/modal.js"></script>
  <script defer src="/js/tech-units.js"></script>
  <script defer src="/js/tech-units-date-picker.js"></script>
  <script defer src="/js/tech-unit-form.js"></script>

  <body>
    <div class="app-shell">
      <%- include('../partials/sidebar', { currentNav }) %>

      <div class="app-main">
        <%- include('../partials/topbar', { pageTitle }) %>

        <main class="content-shell">
          <section class="tech-units-stage-a-page-heading">
            <div>
              <p class="eyebrow">Tech Unit Registry</p>
              <h1>Tech Units</h1>
              <p>
                Create, edit, search, and review unit records from the shared Unit Browser.
              </p>
            </div>

            <a class="primary-button tech-units-stage-a-create-button" href="/tech/units/new" hx-get="/tech/units/new/modal" hx-target="#modal-root" hx-swap="innerHTML">
              Create Unit
            </a>
          </section>

          <section class="content-card tech-units-stage-a-browser-card">
            <div class="content-header tech-units-stage-a-browser-header">
              <div>
                <h2>Unit Browser</h2>
              </div>

              <p class="tech-units-stage-a-loaded-count" aria-live="polite">
                <span>Loaded</span>
                <strong id="tech-units-loaded-count"><%= result.supported ? formatNumber(result.units.length) : '—' %></strong>
              </p>
            </div>

            <% if (successMessage) { %>
              <div class="message success"><%= successMessage %></div>
            <% } %>

            <% if (!result.supported) { %>
              <div class="message error">
                <p><%= result.message %></p>
              </div>
            <% } else { %>
              <%
                const unitCategoryOptions = Array.isArray(result.unitCategories) ? result.unitCategories : [];
                const overallGradeOptions = Array.isArray(result.overallGradeOptions) ? result.overallGradeOptions : [];
                const techUserOptions = Array.isArray(result.techUserOptions) ? result.techUserOptions : [];
                const pageRoleCodes = Array.isArray(currentRoles) ? currentRoles : [];
                const isRegularTechBrowserUser = pageRoleCodes.includes('tech') && !pageRoleCodes.some((roleCode) => ['admin', 'management', 'tech_lead'].includes(roleCode));
                const canViewParkedUnits = pageRoleCodes.some((roleCode) => ['admin', 'management', 'tech_lead'].includes(roleCode));
                const isLast24HourDrilldown = filters.createdWindow === '24h';
              %>
              <form class="tech-filter-form tech-filter-panel tech-filter-panel--stage-a" method="get" action="/tech/units">
                <div class="tech-filter-panel-header">
                  <div>
                    <h3>Search &amp; Filters</h3>
                    <p>Scan or paste several Asset Tags, BIOS serials, or unit serials.</p>
                  </div>

                  <% if (canViewParkedUnits || isLast24HourDrilldown || filters.unitState === 'parked' || filters.categoryId || filters.lotId || filters.gradeFilter || filters.techUserId || filters.createdStartDate || filters.createdEndDate || filters.search) { %>
                    <div class="tech-filter-panel-header-actions">
                      <% if (canViewParkedUnits) { %>
                        <label class="tech-unit-state-toggle">
                          <span class="tech-unit-state-toggle-label">Show Parked Units</span>
                          <span class="tech-unit-state-toggle-control">
                            <input
                              type="checkbox"
                              name="unitState"
                              value="parked"
                              data-unit-state-toggle
                              data-tech-filter-auto-submit
                              <%= filters.unitState === 'parked' ? 'checked' : '' %>
                            />
                            <span class="tech-unit-state-toggle-track" aria-hidden="true"></span>
                          </span>
                        </label>
                      <% } %>

                      <% if (isLast24HourDrilldown || filters.unitState === 'parked' || filters.categoryId || filters.lotId || filters.gradeFilter || filters.techUserId || filters.createdStartDate || filters.createdEndDate || filters.search) { %>
                        <span class="tech-filter-active-pill">Filtered View</span>
                      <% } %>
                    </div>
                  <% } %>
                </div>

                <div class="tech-filter-layout">
                  <label class="form-field tech-filter-search-field">
                    <span>Search Units</span>
                    <textarea name="search" rows="5" placeholder="Scan or paste asset tags, BIOS serials, or unit serials — one per line"><%= filters.search %></textarea>
                    <small class="field-hint">
                      Search one unit or several units at a time. Asset tags work with or without the <%= result.assetTagPrefix || 'BWT' %> prefix. Parked units are excluded from the Active view; authorized users can use the Show Parked Units toggle above to review them.
                    </small>
                  </label>

                  <div class="tech-filter-grid <%= isRegularTechBrowserUser ? 'tech-filter-grid--regular-tech' : 'tech-filter-grid--tech-lead-plus' %>" aria-label="Unit filters">
                    <label class="form-field">
                      <span>Assignable Lot</span>
                      <select name="lotId" data-tech-filter-auto-submit>
                        <option value="">All visible lots</option>
                        <% result.lots.forEach((lot) => { %>
                          <option value="<%= lot.lot_id %>" <%= String(filters.lotId) === String(lot.lot_id) ? 'selected' : '' %>><%= lot.lot_name %></option>
                        <% }) %>
                      </select>
                      <small class="field-hint tech-filter-field-hint">Closed lots remain available for review but cannot receive new or moved units. Lots with child lots are containers and are not assignable.</small>
                    </label>

                    <label class="form-field">
                      <span>Category</span>
                      <select name="categoryId" data-tech-filter-auto-submit>
                        <option value="">All categories</option>
                        <% unitCategoryOptions.forEach((category) => { %>
                          <option value="<%= category.id %>" <%= String(filters.categoryId) === String(category.id) ? 'selected' : '' %>><%= category.label %></option>
                        <% }) %>
                      </select>
                    </label>

                    <label class="form-field">
                      <span>Grade</span>
                      <select name="gradeFilter" data-tech-filter-auto-submit>
                        <option value="">All grades</option>
                        <option value="current" <%= filters.gradeFilter === 'current' ? 'selected' : '' %>>Has current grade</option>
                        <option value="needs" <%= filters.gradeFilter === 'needs' ? 'selected' : '' %>>Needs grade</option>
                        <% overallGradeOptions.forEach((grade) => { %>
                          <option value="grade:<%= grade.id %>" <%= filters.gradeFilter === `grade:${grade.id}` ? 'selected' : '' %>>Grade <%= grade.label %></option>
                        <% }) %>
                      </select>
                    </label>

                    <% if (!isRegularTechBrowserUser) { %>
                      <label class="form-field">
                        <span>Tech User</span>
                        <select name="techUserId" data-tech-filter-auto-submit>
                          <option value="">All Tech Users</option>
                          <% techUserOptions.forEach((techUser) => { %>
                            <option value="<%= techUser.id %>" <%= String(filters.techUserId) === String(techUser.id) ? 'selected' : '' %>><%= techUser.label %> (<%= formatNumber(techUser.count) %>)</option>
                          <% }) %>
                        </select>
                      </label>
                    <% } %>

                    <fieldset class="form-field tech-created-date-range" aria-describedby="tech-created-date-range-hint">
                      <legend>Created Date Range</legend>
                      <div class="tech-created-date-range-inputs">
                        <div class="tech-created-date-picker" data-tech-created-date-picker>
                          <input type="hidden" name="createdStartDate" value="<%= filters.createdStartDate || '' %>" data-tech-created-date-picker-input />
                          <button class="tech-created-date-picker-trigger" type="button" data-tech-created-date-picker-trigger aria-haspopup="dialog" aria-expanded="false" aria-controls="tech-created-start-date-calendar">
                            <span data-tech-created-date-picker-label><%= formatTechUnitsPickerDate(filters.createdStartDate) %></span>
                            <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M4 6.25 8 10l4-3.75" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7"/></svg>
                          </button>
                          <span class="tech-created-date-picker-label">From</span>
                          <div id="tech-created-start-date-calendar" class="tech-created-date-calendar" data-tech-created-date-picker-popover role="dialog" aria-label="Choose From date" hidden>
                            <div class="tech-created-date-calendar-heading">
                              <button type="button" class="tech-created-date-calendar-nav" data-tech-created-date-picker-previous aria-label="Previous month">‹</button>
                              <strong data-tech-created-date-picker-month-label></strong>
                              <button type="button" class="tech-created-date-calendar-nav" data-tech-created-date-picker-next aria-label="Next month">›</button>
                            </div>
                            <div class="tech-created-date-calendar-weekdays" aria-hidden="true"><span>Sun</span><span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span></div>
                            <div class="tech-created-date-calendar-days" data-tech-created-date-picker-grid role="grid" aria-label="Calendar days"></div>
                            <div class="tech-created-date-calendar-footer"><button type="button" class="button-link" data-tech-created-date-picker-today>Today</button><button type="button" class="button-link" data-tech-created-date-picker-clear>Clear</button></div>
                          </div>
                        </div>

                        <div class="tech-created-date-picker" data-tech-created-date-picker>
                          <input type="hidden" name="createdEndDate" value="<%= filters.createdEndDate || '' %>" data-tech-created-date-picker-input />
                          <button class="tech-created-date-picker-trigger" type="button" data-tech-created-date-picker-trigger aria-haspopup="dialog" aria-expanded="false" aria-controls="tech-created-end-date-calendar">
                            <span data-tech-created-date-picker-label><%= formatTechUnitsPickerDate(filters.createdEndDate) %></span>
                            <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M4 6.25 8 10l4-3.75" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7"/></svg>
                          </button>
                          <span class="tech-created-date-picker-label">Through</span>
                          <div id="tech-created-end-date-calendar" class="tech-created-date-calendar" data-tech-created-date-picker-popover role="dialog" aria-label="Choose Through date" hidden>
                            <div class="tech-created-date-calendar-heading">
                              <button type="button" class="tech-created-date-calendar-nav" data-tech-created-date-picker-previous aria-label="Previous month">‹</button>
                              <strong data-tech-created-date-picker-month-label></strong>
                              <button type="button" class="tech-created-date-calendar-nav" data-tech-created-date-picker-next aria-label="Next month">›</button>
                            </div>
                            <div class="tech-created-date-calendar-weekdays" aria-hidden="true"><span>Sun</span><span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span></div>
                            <div class="tech-created-date-calendar-days" data-tech-created-date-picker-grid role="grid" aria-label="Calendar days"></div>
                            <div class="tech-created-date-calendar-footer"><button type="button" class="button-link" data-tech-created-date-picker-today>Today</button><button type="button" class="button-link" data-tech-created-date-picker-clear>Clear</button></div>
                          </div>
                        </div>
                      </div>
                      <small id="tech-created-date-range-hint" class="field-hint tech-filter-field-hint">Set both dates as needed, then choose Apply Filters.</small>
                    </fieldset>
                  </div>
                </div>

                <% if (isLast24HourDrilldown) { %>
                  <input type="hidden" name="createdWindow" value="24h" />
                  <div class="message success tech-filter-drilldown-note">
                    <p>This Unit Browser view is filtered to records created in the last 24 hours.</p>
                  </div>
                <% } %>

                <p class="tech-filter-stage-a-guidance">
                  Selections apply immediately. Choose Apply Filters for Search Units and Created Date Range.
                </p>

                <div class="tech-filter-actions">
                  <button class="primary-button" type="submit">Apply Filters</button>
                  <a class="secondary-button" href="/tech/units">Clear</a>
                </div>
              </form>

              <div class="tech-table-shell" id="tech-units-list" hx-get="<%= tableUrl %>" hx-trigger="load, unit-saved from:body, unit-work-completed from:body, unit-permanently-deleted from:body, unit-parked from:body, unit-returned-active from:body" hx-swap="innerHTML">
                <div class="tech-loading-card">
                  Loading units...
                </div>
              </div>
            <% } %>
          </section>

        </main>

        <div id="modal-root"></div>
      </div>
    </div>
  </body>
</html>