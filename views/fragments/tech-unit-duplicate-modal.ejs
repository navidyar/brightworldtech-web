<%
  const safeMatches = Array.isArray(duplicateMatches) ? duplicateMatches : [];
  const safeErrors = Array.isArray(errorMessages) ? errorMessages : [];

  const hiddenFields = [
    'assetTag',
    'unitSerialNumber',
    'biosSerialNumber',
    'lotId',
    'unitCategoryConfigValueId',
    'currentUnitStatusConfigValueId',
    'manufacturerId',
    'unitModelId',
    'processorModelId',
    'processorSpeedGhz',
    'ramGb',
    'ramTypeConfigValueId',
    'storageGb',
    'storageTypeConfigValueId',
    'operatingSystemConfigValueId',
    'productionWeightOverride',
    'productionWeightNotes',
    'overallGradeConfigValueId',
    'overallGradeNotes',
    'biosVersion',
    'osBuild',
    'absoluteStatusConfigValueId',
    'physicalCameraStatusConfigValueId',
    'touchscreenStatusConfigValueId',
    'keyboardLanguageConfigValueId',
    'completeDiagnosticsStatusConfigValueId',
    'virusCheckStatusConfigValueId',
    'driverCheckStatusConfigValueId',
    'skinnedStatusConfigValueId',
    'generalCommentTypeConfigValueId',
    'generalCommentText',
    'hardwareNotes',
    'cosmeticNotes'
  ];

  function getFormValue(fieldName) {
    return formData && formData[fieldName] !== undefined && formData[fieldName] !== null
      ? String(formData[fieldName])
      : '';
  }

  function getFormRows(fieldName) {
    return formData && Array.isArray(formData[fieldName]) ? formData[fieldName] : [];
  }

  function getRowValue(row, fieldName) {
    return row && row[fieldName] !== undefined && row[fieldName] !== null ? String(row[fieldName]) : '';
  }

  const assetTagPrefix = formOptions && formOptions.assetTagPrefix
    ? String(formOptions.assetTagPrefix).trim().toUpperCase()
    : 'BWT';

  function displayAssetTag(value) {
    const rawValue = String(value || '').trim();

    if (!rawValue) {
      return '';
    }

    const compactPrefix = assetTagPrefix.replace(/[\s-]+/g, '').toUpperCase();
    const compactValue = rawValue.replace(/[\s-]+/g, '').toUpperCase();

    if (compactValue.startsWith(compactPrefix)) {
      const suffix = compactValue.slice(compactPrefix.length);
      return suffix ? `${assetTagPrefix}${suffix}` : rawValue;
    }

    if (/^\d+$/.test(compactValue)) {
      return `${assetTagPrefix}${compactValue}`;
    }

    return rawValue;
  }

  function getMatchIdentifierValue(match) {
    if (!match) {
      return '—';
    }

    const rawValue = match.identifierValue || match.normalizedValue || '';

    if (match.identifierTypeCode === 'asset_tag') {
      return displayAssetTag(rawValue) || '—';
    }

    return rawValue || '—';
  }

  function getMatchUnitLabel(match) {
    if (!match) {
      return 'Unknown Unit';
    }

    return displayAssetTag(match.assetTag || match.assetNumber) || 'Existing unit without asset tag';
  }

  function getMatchLotLabel(match) {
    if (!match) {
      return 'Unknown lot';
    }

    if (match.lotName) {
      return match.lotName;
    }

    if (match.lotId) {
      return 'Lot name not available';
    }

    return 'No lot recorded';
  }
%>

<div class="modal-backdrop" data-modal-backdrop>
  <section class="modal-panel tech-unit-modal" role="dialog" aria-modal="true" aria-labelledby="tech-duplicate-modal-title">
    <header class="modal-header">
      <div>
        <p class="eyebrow">Duplicate Check</p>
        <h2 id="tech-duplicate-modal-title">Possible Existing Unit Found</h2>
      </div>

      <button type="button" class="modal-close-button" data-modal-close aria-label="Close modal">×</button>
    </header>

    <div class="modal-body">
      <% if (safeErrors.length > 0) { %>
        <div class="message error">
          <% safeErrors.forEach((errorMessage) => { %>
            <p><%= errorMessage %></p>
          <% }) %>
        </div>
      <% } %>

      <div class="message error">
        <p>
          This unit may already exist. Review the match below before creating another unit record.
        </p>
        <p>
          Close this window and use the early serial-match panel in Create Unit to select an eligible existing unit for assumption. Same-lot and closed-lot candidates remain controlled through the override workflow.
        </p>
      </div>

      <% if (safeMatches.length === 0) { %>
        <div class="message error">
          <p>No duplicate match details were available. Close this window and search for the unit manually.</p>
        </div>
      <% } else { %>
        <div class="workflow-list">
          <% safeMatches.forEach((match) => { %>
            <article class="workflow-item warning">
              <span></span>
              <div style="width: 100%;">
                <strong><%= getMatchUnitLabel(match) %></strong>
                <p>
                  Matched by <%= match.identifierTypeLabel || 'identifier' %>:
                  <strong><%= getMatchIdentifierValue(match) %></strong>
                </p>
                <p><%= getMatchLotLabel(match) %></p>

                <div class="tech-override-summary" style="margin-top: 12px;">
                  <dl>
                    <div>
                      <dt>Unit Serial</dt>
                      <dd><%= match.unitSerialNumber || '—' %></dd>
                    </div>

                    <div>
                      <dt>BIOS Serial</dt>
                      <dd><%= match.biosSerialNumber || '—' %></dd>
                    </div>

                    <div>
                      <dt>Model</dt>
                      <dd><%= match.modelSummary || '—' %></dd>
                    </div>

                    <div>
                      <dt>CPU</dt>
                      <dd><%= match.cpuSummary || '—' %></dd>
                    </div>
                  </dl>
                </div>
                <div class="message info" style="margin-top: 12px;">
                  <p>Creating a second unit with these matching serials remains blocked. Use the early serial-match panel to review an eligible assumption before submitting the form.</p>
                </div>
                <button type="button" class="secondary-button" data-modal-close style="margin-top: 12px;">Close</button>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </div>
  </section>
</div>
