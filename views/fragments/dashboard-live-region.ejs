<div id="dashboard-live-region">
  <% if (typeof dashboardErrorMessage === 'string' && dashboardErrorMessage) { %>
    <section class="content-card">
      <div class="message error"><p><%= dashboardErrorMessage %></p></div>
    </section>
  <% } else { %>
    <% if (dashboardKey === 'management') { %>
      <%- include('./management-dashboard-completion-foundation', { dashboardData, dashboardFilters, dashboardFilterConfig }) %>
    <% } else if (dashboardKey === 'tech') { %>
      <%- include('./tech-dashboard-productivity', { dashboardData, dashboardFilters, dashboardFilterConfig }) %>
    <% } else { %>
      <%- include('./dashboard-filters', { dashboardFilters, dashboardFilterOptions, dashboardFilterConfig }) %>
      <%- include('./dashboard-foundation', { dashboardData }) %>
    <% } %>
  <% } %>
</div>
