<%
  const safeErrors = Array.isArray(errorMessages) ? errorMessages : [];
  const safeUnit = unit || null;
%>

<div class="modal-backdrop" data-modal-backdrop>
  <section class="modal-panel tech-delete-modal" role="dialog" aria-modal="true" aria-labelledby="tech-unit-delete-modal-title">
    <header class="modal-header">
      <div>
        <p class="eyebrow">Tech Unit</p>
        <h2 id="tech-unit-delete-modal-title">Archive Unit</h2>
      </div>

      <button type="button" class="modal-close-button" data-modal-close aria-label="Close modal">×</button>
    </header>

    <div class="modal-body">
      <% if (safeErrors.length > 0) { %>
        <div class="message error">
          <% safeErrors.forEach((errorMessage) => { %>
            <p><%= errorMessage %></p>
          <% }) %>
        </div>
      <% } %>

      <% if (safeUnit && safeUnit.archiveSupported && !safeUnit.isArchived) { %>
        <div class="tech-delete-confirm-card">
          <p class="tech-delete-warning">This will archive the unit from the normal Unit Browser. The unit record, identifiers, history, and related details remain intact and can still be retrieved by searching for an identifier.</p>

          <dl class="tech-delete-summary-list">
            <div>
              <dt>Asset Tag</dt>
              <dd><%= safeUnit.assetTag || '—' %></dd>
            </div>
            <div>
              <dt>BIOS Serial</dt>
              <dd><%= safeUnit.biosSerialNumber || '—' %></dd>
            </div>
            <div>
              <dt>Unit Serial</dt>
              <dd><%= safeUnit.unitSerialNumber || '—' %></dd>
            </div>
            <div>
              <dt>Lot</dt>
              <dd><%= safeUnit.lotName || '—' %></dd>
            </div>
            <div>
              <dt>Category</dt>
              <dd><%= safeUnit.categoryLabel || '—' %></dd>
            </div>
            <div>
              <dt>Specs</dt>
              <dd><%= safeUnit.specSummary || '—' %></dd>
            </div>
          </dl>
        </div>

        <form
          class="tech-delete-confirm-actions"
          method="post"
          action="/tech/units/<%= safeUnit.unitId %>/delete"
          data-delete-confirm-form
          hx-post="/tech/units/<%= safeUnit.unitId %>/delete"
          hx-trigger="submit consume"
          hx-target="#modal-root"
          hx-swap="innerHTML"
        >
          <button type="button" class="secondary-button" data-modal-close>Cancel</button>
          <button type="submit" class="secondary-button danger-button">Archive Unit</button>
        </form>
      <% } else { %>
        <div class="tech-delete-confirm-actions">
          <button type="button" class="secondary-button" data-modal-close>Close</button>
        </div>
      <% } %>
    </div>
  </section>
</div>
