<%
  function sourceLabel(sourceCode) {
    const normalizedSource = String(sourceCode || '').trim();

    if (!normalizedSource) {
      return 'Unknown Source';
    }

    if (normalizedSource === 'scantool') {
      return 'ScanTool';
    }

    return normalizedSource
      .split('_')
      .filter(Boolean)
      .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
      .join(' ');
  }

  function formatGb(value) {
    return value ? `${formatNumber(value)}GB` : '—';
  }

  function formatMhz(value) {
    return value ? `${formatNumber(value)}MHz` : '';
  }

  function formatVram(value) {
    return value ? `${formatNumber(value)}MB VRAM` : '';
  }

  const assetTagPrefix = result && result.assetTagPrefix
    ? String(result.assetTagPrefix).trim().toUpperCase()
    : 'BWT';

  function identifierValue(identifiers, typeCode) {
    const safeIdentifiers = Array.isArray(identifiers) ? identifiers : [];
    const match = safeIdentifiers.find((identifier) => identifier.typeCode === typeCode);

    return match && match.value ? match.value : '';
  }

  function displayAssetTag(value) {
    const rawValue = String(value || '').trim();

    if (!rawValue) {
      return '';
    }

    const compactPrefix = assetTagPrefix.replace(/[\s-]+/g, '').toUpperCase();
    const compactValue = rawValue.replace(/[\s-]+/g, '').toUpperCase();

    if (compactValue.startsWith(compactPrefix)) {
      const suffix = compactValue.slice(compactPrefix.length);
      return suffix ? `${assetTagPrefix}${suffix}` : rawValue;
    }

    if (/^\d+$/.test(compactValue)) {
      return `${assetTagPrefix}${compactValue}`;
    }

    return rawValue;
  }

  const currentUserRoles = typeof currentRoles !== 'undefined' && Array.isArray(currentRoles) ? currentRoles : [];
  const canDeleteTechUnits = currentUserRoles.some((roleCode) => ['admin', 'management', 'tech_lead'].includes(roleCode));
  const canManageUnitLifecycle = currentUserRoles.some((roleCode) => ['admin', 'management', 'tech_lead'].includes(roleCode));
  const canApproveUnitOutcomes = currentUserRoles.some((roleCode) => ['admin', 'management', 'tech_lead'].includes(roleCode));
  const canCompleteTechUnits = currentUserRoles.some((roleCode) => ['admin', 'management', 'tech_lead', 'tech'].includes(roleCode));
  const canViewUnitHistory = currentUserRoles.some((roleCode) => ['admin', 'management', 'tech_lead'].includes(roleCode));
  const currentUserId = currentUser && Number.isInteger(Number(currentUser.user_id))
    ? Number(currentUser.user_id)
    : null;
  const isRegularTechUser = currentUserRoles.includes('tech')
    && !currentUserRoles.some((roleCode) => ['admin', 'management', 'tech_lead'].includes(roleCode));
  const isRegularTechOverrideRequester = isRegularTechUser;



  const appDisplayTimeZone = 'America/Chicago';

  function formatUnitCreatedDate(value) {
    if (!value) {
      return '—';
    }

    const date = new Date(value);

    if (Number.isNaN(date.getTime())) {
      return '—';
    }

    return new Intl.DateTimeFormat('en-US', {
      month: '2-digit',
      day: '2-digit',
      year: 'numeric',
      timeZone: appDisplayTimeZone
    }).format(date);
  }

  function formatUnitCreatedTime(value) {
    if (!value) {
      return '';
    }

    const date = new Date(value);

    if (Number.isNaN(date.getTime())) {
      return '';
    }

    return new Intl.DateTimeFormat('en-US', {
      hour: '2-digit',
      minute: '2-digit',
      hour12: true,
      timeZone: appDisplayTimeZone
    }).format(date);
  }

  function displayIdentifierValue(identifier) {
    const safeIdentifier = identifier || {};
    const rawValue = safeIdentifier.value || safeIdentifier.normalizedValue || '';

    if (safeIdentifier.typeCode === 'asset_tag') {
      return displayAssetTag(rawValue) || '—';
    }

    return rawValue || '—';
  }
%>

<strong id="tech-units-loaded-count" hx-swap-oob="true"><%= result && result.units ? formatNumber(result.units.length) : '—' %></strong>

<div class="table-card tech-table-card">
  <table class="tech-units-table">
    <thead>
      <tr>
        <th>Unit<%= isRegularTechUser ? '' : ' / Weight' %></th>
        <th>Date</th>
        <th>Work / Assignment</th>
        <th>Identifiers</th>
        <th>Grade / Pass-Fail</th>
        <th>Unit Actions</th>
      </tr>
    </thead>

    <tbody>
      <% if (result.units.length === 0) { %>
        <tr>
          <td colspan="6">No units match the current filters.</td>
        </tr>
      <% } %>

      <% result.units.forEach((unit) => { %>
        <%
          const expanded = unit.expandedDetails || {};
          const identifiers = Array.isArray(expanded.identifiers) ? expanded.identifiers : [];
          const specifications = expanded.specifications || null;
          const currentGrade = expanded.currentGrade || null;
          const currentOutcome = expanded.currentOutcome || null;
          const memoryModules = Array.isArray(expanded.memoryModules) ? expanded.memoryModules : [];
          const storageDevices = Array.isArray(expanded.storageDevices) ? expanded.storageDevices : [];
          const cellularModules = Array.isArray(expanded.cellularModules) ? expanded.cellularModules : [];
          const graphicsAdapters = Array.isArray(expanded.graphicsAdapters) ? expanded.graphicsAdapters : [];
          const cosmeticIssues = Array.isArray(expanded.cosmeticIssues) ? expanded.cosmeticIssues : [];
          const hardwareIssues = Array.isArray(expanded.hardwareIssues) ? expanded.hardwareIssues : [];
          const comments = Array.isArray(expanded.comments) ? expanded.comments : [];
          const assetTagValue = displayAssetTag(unit.assetTag || identifierValue(identifiers, 'asset_tag')) || '—';
          const biosSerialValue = identifierValue(identifiers, 'bios_serial_number') || '—';
          const unitSerialValue = identifierValue(identifiers, 'unit_serial_number') || '—';
          const currentGradeLabel = currentGrade && currentGrade.gradeLabel ? currentGrade.gradeLabel : '—';
          const currentOutcomeLabel = currentOutcome && currentOutcome.outcomeLabel ? currentOutcome.outcomeLabel : '';
          const currentOutcomeClass = currentOutcome && currentOutcome.outcomeCode === 'pass' ? 'pass' : (currentOutcome && currentOutcome.outcomeCode === 'fail' ? 'fail' : '');
          const assignedTechName = unit.assignedToName || 'Unassigned';
          const isReadOnlySearchResult = Boolean(unit.isReadOnlyForCurrentUser);
          const isAssignedToCurrentUser = Boolean(currentUserId && Number(unit.assignedToUserId) === currentUserId);
          const canRequestUnitOverride = isRegularTechOverrideRequester && Boolean(currentUserId) && !isAssignedToCurrentUser;
          const unitCreatedDate = formatUnitCreatedDate(unit.createdAt);
          const unitCreatedTime = formatUnitCreatedTime(unit.createdAt);
        %>

        <tr class="tech-summary-row" data-unit-summary-row data-target="tech-unit-detail-<%= unit.unitId %>">
          <td>
            <button
              type="button"
              class="tech-unit-toggle tech-unit-summary-toggle"
              data-unit-detail-toggle
              data-target="tech-unit-detail-<%= unit.unitId %>"
              aria-expanded="false"
              aria-controls="tech-unit-detail-<%= unit.unitId %>"
            >
              <span class="tech-unit-toggle-icon" aria-hidden="true">▸</span>
              <span class="tech-unit-summary-spec">
                <strong><%= unit.specSummary %></strong>
                <small>
                  <span>Lot: <%= unit.lotName || '—' %></span>
                  <% if (unit.isLotClosed) { %>
                    <span aria-hidden="true">·</span>
                    <span>Closed lot</span>
                  <% } %>
                  <span aria-hidden="true">·</span>
                  <span>Category: <%= unit.categoryLabel || '—' %></span>
                  <% if (unit.isParked) { %>
                    <span aria-hidden="true">·</span>
                    <span>Parked</span>
                  <% } %>
                </small>
                <% if (!isRegularTechUser) { %>
                  <span class="tech-unit-summary-weight-strip">
                    <span class="tech-unit-summary-weight-value">Current lot weight <strong><%= unit.formattedCurrentLotWeight || '—' %></strong></span>
                  </span>
                <% } %>
              </span>
            </button>
          </td>

          <td>
            <span class="tech-unit-summary-created">
              <span><%= unitCreatedDate %></span>
              <% if (unitCreatedTime) { %>
                <small><%= unitCreatedTime %></small>
              <% } %>
            </span>
          </td>

          <td>
            <span class="tech-unit-summary-work-stack">
              <small class="tech-outcome-status">Assigned To</small>
              <span class="tech-unit-summary-tech-user"><%= assignedTechName %></span>
            </span>
          </td>

          <td>
            <div class="tech-unit-summary-identifiers" aria-label="Unit identifiers">
              <span class="tech-unit-summary-id-item">
                <span class="tech-unit-summary-id-label">Asset</span>
                <span class="tech-unit-summary-id-value"><%= assetTagValue %></span>
              </span>
              <span class="tech-unit-summary-id-item">
                <span class="tech-unit-summary-id-label">BIOS</span>
                <span class="tech-unit-summary-id-value"><%= biosSerialValue %></span>
              </span>
              <span class="tech-unit-summary-id-item">
                <span class="tech-unit-summary-id-label">Unit</span>
                <span class="tech-unit-summary-id-value"><%= unitSerialValue %></span>
              </span>
            </div>
          </td>

          <td>
            <div class="tech-unit-summary-grade-stack">
              <div class="tech-unit-summary-grade-row">
                <span class="tech-unit-summary-grade"><%= currentGradeLabel %></span>
                <% if (currentOutcomeLabel) { %>
                  <span class="tech-outcome-pill tech-outcome-pill--<%= currentOutcomeClass %>"><%= currentOutcomeLabel %></span>
                <% } %>
              </div>

              <% if (currentOutcomeLabel) { %>
                <% if (currentOutcome.isPendingApproval) { %>
                  <small class="tech-outcome-status">Approval Requested</small>
                <% } else if (currentOutcome.isApproved && currentOutcome.approvedByName) { %>
                  <small class="tech-outcome-status">Approved by <%= currentOutcome.approvedByName %></small>
                <% } else if (currentOutcome.approvalStatusCode === 'denied' && currentOutcome.approvedByName) { %>
                  <small class="tech-outcome-status">Review declined by <%= currentOutcome.approvedByName %></small>
                <% } %>
              <% } else { %>
                <small class="tech-outcome-status">No Pass/Fail</small>
              <% } %>
            </div>
          </td>

          <td>
            <% if (unit.unitId) { %>
              <div class="tech-summary-actions">
                <% if (canCompleteTechUnits && !unit.isParked && !isReadOnlySearchResult) { %>
                  <a
                    class="secondary-button"
                    href="/tech/units/<%= unit.unitId %>/complete-work/modal"
                    data-tech-modal-trigger
                    data-no-row-toggle
                  >
                    Work Complete
                  </a>
                <% } %>
                <% if (!unit.isParked && !isReadOnlySearchResult) { %>
                  <a class="secondary-button" href="/tech/units/<%= unit.unitId %>/edit" hx-get="/tech/units/<%= unit.unitId %>/edit/modal" hx-target="#modal-root" hx-swap="innerHTML" data-no-row-toggle>
                    Edit
                  </a>
                <% } %>
                <% if (unit.isParked) { %>
                  <span class="tech-chip">Parked</span>
                  <% if (canManageUnitLifecycle) { %>
                    <a
                      class="secondary-button"
                      href="/tech/units/<%= unit.unitId %>/return-to-active/modal"
                      data-tech-modal-trigger
                      data-no-row-toggle
                    >
                      Return to Active
                    </a>
                  <% } %>
                <% } else if (canManageUnitLifecycle) { %>
                  <a
                    class="secondary-button tech-delete-action-button"
                    href="/tech/units/<%= unit.unitId %>/park/modal"
                    data-tech-modal-trigger
                    data-no-row-toggle
                  >
                    Park Unit
                  </a>
                <% } %>
              </div>
            <% } else { %>
              —
            <% } %>
          </td>
        </tr>

        <tr class="tech-detail-row" id="tech-unit-detail-<%= unit.unitId %>" hidden>
          <td colspan="6">
            <div class="tech-detail-offset">
              <div class="tech-detail-panel" data-unit-detail-panel>
                <div class="tech-detail-header">
                  <div class="tech-detail-title">
                    <strong>Unit Details</strong>
                    <span>Identity, grade/pass-fail, hardware, workflow, modules, issues, and comments.</span>
                  </div>

                  <div class="tech-detail-actions">
                    <div class="tech-detail-status">
                      <span class="tech-chip"><%= unit.categoryLabel %></span>
                      <% if (currentGrade) { %>
                        <span class="tech-chip">Grade <%= currentGrade.gradeLabel %></span>
                      <% } %>
                      <% if (currentOutcomeLabel) { %>
                        <span class="tech-chip"><%= currentOutcomeLabel %></span>
                      <% } %>
                      <% if (unit.isParked) { %>
                        <span class="tech-chip">Parked</span>
                      <% } %>
                      <% if (isReadOnlySearchResult) { %>
                        <span class="tech-chip">Read-only search result</span>
                      <% } %>
                    </div>

                    <% if (unit.unitId) { %>
                      <% if (canRequestUnitOverride && !unit.isParked) { %>
                        <a
                          class="secondary-button"
                          href="/tech/units/<%= unit.unitId %>/override/modal"
                          data-tech-modal-trigger
                          data-no-row-toggle
                        >
                          Request Override
                        </a>
                      <% } %>

                      <% if (isRegularTechUser) { %>
                        <button
                          type="button"
                          class="secondary-button tech-personal-credit-action-button"
                          data-unit-panel-button
                          data-panel="my-weight"
                          data-no-row-toggle
                          hx-get="/tech/units/<%= unit.unitId %>/my-weight-earned"
                          hx-target="#tech-unit-my-weight-content-<%= unit.unitId %>"
                          hx-swap="innerHTML"
                        >
                          My Weight Earned
                        </button>
                      <% } %>

                      <% if (canViewUnitHistory) { %>
                        <button
                          type="button"
                          class="secondary-button tech-history-action-button"
                          data-unit-panel-button
                          data-panel="history"
                          data-no-row-toggle
                          hx-get="/tech/units/<%= unit.unitId %>/history"
                          hx-target="#tech-unit-history-content-<%= unit.unitId %>"
                          hx-swap="innerHTML"
                        >
                          History
                        </button>
                      <% } %>
                      <% if (canDeleteTechUnits) { %>
                        <a
                          class="secondary-button danger-button tech-permanent-delete-action-button"
                          href="/tech/units/<%= unit.unitId %>/permanent-delete/modal"
                          data-tech-modal-trigger
                          data-no-row-toggle
                        >
                          Delete Unit Permanently
                        </a>
                      <% } %>
                    <% } %>
                  </div>
                </div>

                <div class="tech-unit-panel-stack">
                  <div id="tech-unit-current-panel-<%= unit.unitId %>" class="tech-unit-panel-view" data-unit-panel-content="details">

                <% if (expanded.schemaReady === false) { %>
                  <div class="message error">
                    <p>Expanded Step 3a tables were not detected. Run the Step 3a database migration before using expanded unit details.</p>
                  </div>
                <% } else if (!expanded.hasAnyExpandedData) { %>
                  <div class="message success">
                    <p>Expanded unit tables are ready. No detailed memory, storage, cellular, GPU, issue, grade, or comment records have been added for this unit yet.</p>
                  </div>
                <% } %>

                <div class="tech-detail-layout tech-detail-layout--identity-grade">
                  <section class="tech-detail-section tech-detail-section--identity tech-detail-section--identity-identifiers">
                    <h3>Identity</h3>

                    <p class="tech-detail-subheading">Identity</p>
                    <dl class="tech-detail-list">
                      <div>
                        <dt>Lot</dt>
                        <dd>
                          <%= unit.lotName || '—' %>
                          <% if (unit.isLotClosed) { %>
                            <span class="tech-chip">Closed</span>
                          <% } %>
                        </dd>
                      </div>

                      <div>
                        <dt>Assigned Tech</dt>
                        <dd><%= unit.assignedToName || 'Unassigned' %></dd>
                      </div>

                      <div>
                        <dt>Category</dt>
                        <dd><%= unit.categoryLabel || '—' %></dd>
                      </div>

                      <div>
                        <dt>Current Lot Weight</dt>
                        <dd>
                          <div class="tech-production-weight-detail">
                            <div class="tech-production-weight-detail-main">
                              <strong><%= unit.formattedCurrentLotWeight || '—' %></strong>
                            </div>
                          </div>
                        </dd>
                      </div>
                    </dl>

                    <p class="tech-detail-subheading">Identifiers</p>
                    <% if (identifiers.length > 0) { %>
                      <dl class="tech-detail-list tech-detail-list--identifiers">
                        <% identifiers.forEach((identifier) => { %>
                          <div>
                            <dt><%= identifier.typeLabel %></dt>
                            <dd>
                              <%= displayIdentifierValue(identifier) %>
                              <% if (identifier.isPrimary) { %>
                                <span class="tech-chip">Primary</span>
                              <% } %>
                            </dd>
                          </div>
                        <% }) %>
                      </dl>
                    <% } else { %>
                      <p class="field-hint">No serial or BIOS identifier rows have been recorded yet.</p>
                    <% } %>
                  </section>

                  <section class="tech-detail-section tech-detail-section--grade">
                    <h3>Cosmetic Grade & Unit Outcome</h3>

                    <dl class="tech-detail-list">
                      <div>
                        <dt>Cosmetic Grade</dt>
                        <dd><%= currentGrade ? currentGrade.gradeLabel : '—' %></dd>
                      </div>

                      <div>
                        <dt>Unit Outcome</dt>
                        <dd>
                          <% if (currentOutcomeLabel) { %>
                            <span class="tech-outcome-pill tech-outcome-pill--<%= currentOutcomeClass %>"><%= currentOutcomeLabel %></span>
                          <% } else { %>
                            —
                          <% } %>
                        </dd>
                      </div>

                      <div>
                        <dt>Outcome Approval</dt>
                        <dd>
                          <% if (currentOutcome && currentOutcome.isApproved && currentOutcome.approvedByName) { %>
                            Approved by <%= currentOutcome.approvedByName %>
                          <% } else if (currentOutcome && currentOutcome.isPendingApproval) { %>
                            Approval Requested
                          <% } else { %>
                            —
                          <% } %>
                        </dd>
                      </div>

                      <% if (currentOutcome && currentOutcome.approvalRequestNotes) { %>
                        <div>
                          <dt>Approval Request Notes</dt>
                          <dd><%= currentOutcome.approvalRequestNotes %></dd>
                        </div>
                      <% } %>

                      <% if (currentOutcome && currentOutcome.isPendingApproval && canApproveUnitOutcomes) { %>
                        <div>
                          <dt>Review</dt>
                          <dd><a href="/management/overrides?status=pending">Review in Overrides</a></dd>
                        </div>
                      <% } %>

                      <div>
                        <dt>Grade Source</dt>
                        <dd><%= currentGrade ? sourceLabel(currentGrade.sourceCode) : '—' %></dd>
                      </div>

                      <div>
                        <dt>Grade Assessed</dt>
                        <dd><%= currentGrade && currentGrade.assessedAt ? formatDateTime(currentGrade.assessedAt) : '—' %></dd>
                      </div>

                      <% if (currentGrade && currentGrade.notes) { %>
                        <div>
                          <dt>Cosmetic Grade Notes</dt>
                          <dd><%= currentGrade.notes %></dd>
                        </div>
                      <% } %>
                    </dl>
                  </section>
                </div>

                <div class="tech-detail-layout">
                  <section class="tech-detail-section tech-detail-section--hardware">
                    <h3>Hardware</h3>

                    <dl class="tech-detail-list">
                      <div>
                        <dt>Manufacturer</dt>
                        <dd><%= unit.manufacturerLabel || '—' %></dd>
                      </div>

                      <div>
                        <dt>Model</dt>
                        <dd><%= unit.modelLabel || '—' %></dd>
                      </div>

                      <div>
                        <dt>Processor</dt>
                        <dd><%= unit.processorLabel || '—' %></dd>
                      </div>

                      <div>
                        <dt>Processor Speed</dt>
                        <dd><%= unit.processorSpeedGhz ? `${unit.processorSpeedGhz}GHz` : '—' %></dd>
                      </div>
                    </dl>
                  </section>

                  <section class="tech-detail-section tech-detail-section--checks">
                    <h3>System Checks</h3>

                    <dl class="tech-detail-list">
                      <div>
                        <dt>Operating System</dt>
                        <dd><%= unit.operatingSystemLabel || '—' %></dd>
                      </div>

                      <div>
                        <dt>BIOS Version</dt>
                        <dd><%= specifications && specifications.biosVersion ? specifications.biosVersion : '—' %></dd>
                      </div>

                      <div>
                        <dt>OS Build</dt>
                        <dd><%= specifications && specifications.osBuild ? specifications.osBuild : '—' %></dd>
                      </div>

                      <div>
                        <dt>Absolute Status</dt>
                        <dd><%= specifications ? specifications.absoluteStatusLabel : '—' %></dd>
                      </div>

                      <div>
                        <dt>Camera</dt>
                        <dd><%= specifications ? specifications.physicalCameraStatusLabel : '—' %></dd>
                      </div>

                      <div>
                        <dt>Touchscreen</dt>
                        <dd><%= specifications ? specifications.touchscreenStatusLabel : '—' %></dd>
                      </div>

                      <div>
                        <dt>Keyboard</dt>
                        <dd><%= specifications ? specifications.keyboardLanguageLabel : '—' %></dd>
                      </div>

                      <div>
                        <dt>Diagnostics</dt>
                        <dd><%= specifications ? specifications.completeDiagnosticsStatusLabel : '—' %></dd>
                      </div>

                      <div>
                        <dt>Virus Check</dt>
                        <dd><%= specifications ? specifications.virusCheckStatusLabel : '—' %></dd>
                      </div>

                      <div>
                        <dt>Driver Check</dt>
                        <dd><%= specifications ? specifications.driverCheckStatusLabel : '—' %></dd>
                      </div>

                      <div>
                        <dt>Skinned</dt>
                        <dd><%= specifications ? specifications.skinnedStatusLabel : '—' %></dd>
                      </div>
                    </dl>
                  </section>

                  <section class="tech-detail-section tech-detail-section--workflow">
                    <h3>Workflow</h3>

                    <dl class="tech-detail-list">
                      <div>
                        <dt>Created</dt>
                        <dd><%= unit.createdAt ? formatDateTime(unit.createdAt) : '—' %></dd>
                      </div>

                      <div>
                        <dt>Updated</dt>
                        <dd><%= unit.updatedAt ? formatDateTime(unit.updatedAt) : '—' %></dd>
                      </div>

                      <div>
                        <dt>Completed</dt>
                        <dd><%= unit.completedAt ? formatDateTime(unit.completedAt) : '—' %></dd>
                      </div>

                      <% if (unit.isParked) { %>
                        <div>
                          <dt>Parked</dt>
                          <dd><%= unit.parkedAt ? formatDateTime(unit.parkedAt) : 'Yes' %></dd>
                        </div>
                      <% } %>
                    </dl>
                  </section>
                </div>

                <div class="tech-module-pair-layout">
                  <section class="tech-notes-section tech-notes-section--memory">
                  <div class="tech-section-title-row">
                    <h3>Current Memory Modules</h3>
                  </div>

                  <% if (memoryModules.length > 0) { %>
                    <p class="field-hint">Current Memory Total: <strong><%= formatGb(expanded.memoryTotalGb) %></strong></p>

                    <div class="tech-detail-layout tech-current-module-layout">
                      <% memoryModules.forEach((memoryModule) => { %>
                          <section class="tech-detail-section tech-detail-section--memory-module">
                          <dl class="tech-detail-list">
                            <div>
                              <dt>Slot</dt>
                              <dd><%= memoryModule.slotLabel %></dd>
                            </div>
                            <div>
                              <dt>Size / Type</dt>
                              <dd><%= formatGb(memoryModule.sizeGb) %> <%= memoryModule.ramTypeLabel || '' %></dd>
                            </div>
                            <div>
                              <dt>Install Type</dt>
                              <dd><%= memoryModule.memoryInstallTypeLabel || 'Removable Module' %></dd>
                            </div>
                            <div>
                              <dt>Source</dt>
                              <dd><%= sourceLabel(memoryModule.sourceCode) %></dd>
                            </div>
                          </dl>
                        </section>
                      <% }) %>
                    </div>
                  <% } else { %>
                    <p class="field-hint">No detailed memory module rows yet. Legacy memory display: <%= unit.ramGb ? `${unit.ramGb}GB ${unit.ramTypeLabel !== '—' ? unit.ramTypeLabel : ''}` : '—' %></p>
                  <% } %>
                  </section>

                  <section class="tech-notes-section tech-notes-section--storage">
                  <h3>Current Storage Devices</h3>

                  <% if (storageDevices.length > 0) { %>
                    <p class="field-hint">Current Storage Total: <strong><%= formatGb(expanded.storageTotalGb) %></strong></p>

                    <div class="tech-detail-layout tech-current-module-layout">
                      <% storageDevices.forEach((storageDevice) => { %>
                          <section class="tech-detail-section tech-detail-section--storage-device">
                          <dl class="tech-detail-list">
                            <div>
                              <dt>Slot</dt>
                              <dd><%= storageDevice.slotLabel %></dd>
                            </div>
                            <div>
                              <dt>Size / Type</dt>
                              <dd><%= formatGb(storageDevice.sizeGb) %> <%= storageDevice.storageTypeLabel || '' %></dd>
                            </div>
                            <div>
                              <dt>Wipe Status</dt>
                              <dd><%= storageDevice.wipeStatusLabel || '—' %></dd>
                            </div>
                            <div>
                              <dt>Source</dt>
                              <dd><%= sourceLabel(storageDevice.sourceCode) %></dd>
                            </div>
                          </dl>
                        </section>
                      <% }) %>
                    </div>
                  <% } else { %>
                    <p class="field-hint">No detailed storage device rows yet. Legacy storage display: <%= unit.storageGb ? `${unit.storageGb}GB ${unit.storageTypeLabel !== '—' ? unit.storageTypeLabel : ''}` : '—' %></p>
                  <% } %>
                  </section>

                </div>

                <section class="tech-notes-section tech-notes-section--cellular">
                  <h3>Cellular / WWAN</h3>
                  <p class="field-hint">Deep cellular module and band details should be populated by ScanTool. Manual unit forms should not edit ScanTool-only band details.</p>

                  <% if (cellularModules.length > 0) { %>
                    <div class="tech-detail-layout">
                      <% cellularModules.forEach((cellularModule) => { %>
                        <section class="tech-detail-section tech-detail-section--cellular-module">
                          <dl class="tech-detail-list">
                            <div>
                              <dt>Status</dt>
                              <dd><%= cellularModule.wwanStatusLabel %></dd>
                            </div>
                            <div>
                              <dt>Module</dt>
                              <dd><%= [cellularModule.moduleManufacturer, cellularModule.moduleModel].filter(Boolean).join(' ') || '—' %></dd>
                            </div>
                            <div>
                              <dt>IMEI</dt>
                              <dd><%= cellularModule.imei || '—' %></dd>
                            </div>
                            <div>
                              <dt>Networks</dt>
                              <dd><%= cellularModule.supportedNetworksText || '—' %></dd>
                            </div>
                            <div>
                              <dt>Bands</dt>
                              <dd><%= cellularModule.bandSummary || '—' %></dd>
                            </div>
                            <div>
                              <dt>Carriers</dt>
                              <dd><%= cellularModule.supportedCarriersText || '—' %></dd>
                            </div>
                            <div>
                              <dt>Source</dt>
                              <dd><%= sourceLabel(cellularModule.sourceCode) %></dd>
                            </div>
                          </dl>
                        </section>
                      <% }) %>
                    </div>
                  <% } else { %>
                    <p class="field-hint">No current cellular / WWAN module details recorded yet.</p>
                  <% } %>
                </section>

                <section class="tech-notes-section tech-notes-section--graphics">
                  <h3>Graphics</h3>

                  <% if (graphicsAdapters.length > 0) { %>
                    <div class="tech-detail-layout tech-current-module-layout">
                      <% graphicsAdapters.forEach((graphicsAdapter) => { %>
                        <section class="tech-detail-section tech-detail-section--graphics-adapter">
                          <dl class="tech-detail-list">
                            <div>
                              <dt>Type</dt>
                              <dd><%= graphicsAdapter.gpuTypeLabel %></dd>
                            </div>
                            <div>
                              <dt>Model</dt>
                              <dd><%= graphicsAdapter.gpuModel || '—' %></dd>
                            </div>
                            <div>
                              <dt>VRAM</dt>
                              <dd><%= formatVram(graphicsAdapter.vramMb) || '—' %></dd>
                            </div>
                            <div>
                              <dt>Source</dt>
                              <dd><%= sourceLabel(graphicsAdapter.sourceCode) %></dd>
                            </div>
                          </dl>
                        </section>
                      <% }) %>
                    </div>
                  <% } else { %>
                    <p class="field-hint">No graphics adapter rows recorded yet.</p>
                  <% } %>
                </section>

                <% if (cosmeticIssues.length > 0 || hardwareIssues.length > 0) { %>
                  <section class="tech-notes-section tech-notes-section--issues">
                    <h3>Issue Details</h3>

                    <div class="tech-notes-grid">
                      <div class="tech-note-block">
                        <strong>Cosmetic Issues</strong>

                        <% if (cosmeticIssues.length > 0) { %>
                          <% cosmeticIssues.forEach((issue) => { %>
                            <p>
                              <strong><%= issue.issueLabel %></strong>
                              <% if (issue.severityLabel) { %> · <%= issue.severityLabel %><% } %>
                              <% if (issue.locationLabel) { %> · <%= issue.locationLabel %><% } %>
                              <% if (issue.issueRemark) { %><br /><%= issue.issueRemark %><% } %>
                            </p>
                          <% }) %>
                        <% } else { %>
                          <p>No cosmetic issues recorded.</p>
                        <% } %>
                      </div>

                      <div class="tech-note-block">
                        <strong>Hardware Issues</strong>

                        <% if (hardwareIssues.length > 0) { %>
                          <% hardwareIssues.forEach((issue) => { %>
                            <p>
                              <strong><%= issue.issueLabel %></strong>
                              <% if (issue.locationLabel) { %> · <%= issue.locationLabel %><% } %>
                              <% if (issue.issueRemark) { %><br /><%= issue.issueRemark %><% } %>
                            </p>
                          <% }) %>
                        <% } else { %>
                          <p>No hardware issues recorded.</p>
                        <% } %>
                      </div>
                    </div>
                  </section>
                <% } %>



                <% if (comments.length > 0) { %>
                  <section class="tech-notes-section tech-notes-section--comments">
                    <h3>Comment History</h3>

                    <div class="tech-comment-history-list">
                      <% comments.forEach((comment) => { %>
                        <article class="tech-comment-history-row">
                          <div class="tech-comment-history-meta">
                            <span class="tech-comment-type-label"><%= comment.noteTypeLabel || 'General' %></span>
                            <span><%= comment.createdByName || sourceLabel(comment.sourceCode) %></span>
                            <span><%= comment.createdAt ? formatDateTime(comment.createdAt) : 'No date recorded' %></span>
                          </div>
                          <p class="tech-comment-history-text"><%= comment.commentText %></p>
                        </article>
                      <% }) %>
                    </div>
                  </section>
                <% } %>
                  </div>

                  <% if (isRegularTechUser) { %>
                    <div id="tech-unit-my-weight-panel-<%= unit.unitId %>" class="tech-unit-panel-view" data-unit-panel-content="my-weight" hidden>
                      <div id="tech-unit-my-weight-content-<%= unit.unitId %>" class="tech-history-panel-placeholder">
                        <p>Select My Weight Earned to load your recorded work credit.</p>
                      </div>
                    </div>
                  <% } %>

                  <% if (canViewUnitHistory) { %>
                    <div id="tech-unit-history-panel-<%= unit.unitId %>" class="tech-unit-panel-view" data-unit-panel-content="history" hidden>
                      <div id="tech-unit-history-content-<%= unit.unitId %>" class="tech-history-panel-placeholder">
                        <p>Select History to load this unit's audit history from the server.</p>
                      </div>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<% if (result.units.length >= result.unitLimit) { %>
  <div class="message error">
    <p>
      This view is limited to <%= formatNumber(result.unitLimit) %> units for safety.
      We can add pagination later.
    </p>
  </div>
<% } %>
