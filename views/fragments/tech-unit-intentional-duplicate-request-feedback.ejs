<%
  const safeErrors = Array.isArray(errorMessages) ? errorMessages : [];
%>

<div class="message error tech-intentional-duplicate-request-feedback" data-intentional-duplicate-request-feedback role="alert">
  <% safeErrors.forEach((errorMessage) => { %>
    <p><%= errorMessage %></p>
  <% }) %>
</div>
