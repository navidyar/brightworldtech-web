<%
  const safeProfile = profile || null;
  const safeErrorMessage = String(errorMessage || '').trim();
%>

<% if (safeProfile) { %>
  <div
    hidden
    data-unit-form-profile
    data-lot-id="<%= safeProfile.lotId %>"
    data-lot-name="<%= safeProfile.lotName %>"
    data-total-field-count="<%= safeProfile.summary.totalFields %>"
    data-visible-field-count="<%= safeProfile.summary.visibleFields %>"
    data-required-field-count="<%= safeProfile.summary.requiredFields %>"
    data-hidden-field-count="<%= safeProfile.summary.hiddenFields %>"
  >
    <% safeProfile.fields.forEach((field) => { %>
      <span
        data-unit-form-profile-field
        data-field-key="<%= field.key %>"
        data-field-label="<%= field.label %>"
        data-visible="<%= field.visible ? '1' : '0' %>"
        data-required="<%= field.required ? '1' : '0' %>"
        data-required-suppressed-by-hidden="<%= field.requiredSuppressedByHidden ? '1' : '0' %>"
      ></span>
    <% }) %>
  </div>
<% } else { %>
  <div
    hidden
    data-unit-form-profile-error
    data-error-message="<%= safeErrorMessage || 'The selected Lot form settings could not be loaded.' %>"
  ></div>
<% } %>
