          <label class="form-field"><span>Size GB</span><input type="number" name="storageDevices[__INDEX__][sizeGb]" min="1" step="1" placeholder="Example: 256" data-storage-size-input data-module-field /></label>
          <label class="form-field"><span>Storage Type</span><select name="storageDevices[__INDEX__][storageTypeConfigValueId]" data-module-field><option value="">Select storage type</option><% formOptions.storageTypes.forEach((storageType) => { %><option value="<%= storageType.id %>"><%= storageType.label %></option><% }) %></select></label>
          <label class="form-field"><span>Wipe Status</span><select name="storageDevices[__INDEX__][wipeStatusConfigValueId]" data-module-field><option value="">Select wipe status</option><% (formOptions.storageWipeStatuses || []).forEach((wipeStatus) => { %><option value="<%= wipeStatus.id %>"><%= wipeStatus.label %></option><% }) %></select></label>
          <input type="hidden" name="storageDevices[__INDEX__][manufacturerName]" />
          <input type="hidden" name="storageDevices[__INDEX__][modelNumber]" />
          <input type="hidden" name="storageDevices[__INDEX__][serialNumber]" />
          <input type="hidden" name="storageDevices[__INDEX__][firmwareVersion]" />
          <label class="form-field"><span>Change Notes</span><input type="text" name="storageDevices[__INDEX__][changeNotes]" maxlength="500" placeholder="Installed, replaced, upgraded, downgraded, wiped, etc." data-module-field /></label>
        </div>
      </div>
    </article>
  </template>

  <div class="form-actions">
    <button class="primary-button" type="submit">
      <%= isEditMode ? 'Update Unit' : 'Create Unit' %>
    </button>

    <% if (isModal) { %>
      <button type="button" class="secondary-button" data-modal-close>Cancel</button>
    <% } else { %>
      <a class="secondary-button" href="/tech/units">Cancel</a>
    <% } %>
  </div>
</form>
