<%
  const isEditMode = mode === 'edit';
  const htmxAttrs = isModal ? `hx-post="${formAction}" hx-target="#modal-root" hx-swap="innerHTML"` : '';
  const memoryInstallTypes = Array.isArray(formOptions.memoryInstallTypes) && formOptions.memoryInstallTypes.length > 0
    ? formOptions.memoryInstallTypes
    : [
        { code: 'removable_module', label: 'Removable Module' },
        { code: 'integrated_soldered', label: 'Integrated / Soldered' },
        { code: 'unknown', label: 'Unknown' }
      ];
  const memoryRows = Array.isArray(formData.memoryModules) && formData.memoryModules.length > 0
    ? formData.memoryModules
    : [{ slotLabel: 'Slot 1', sizeGb: '', ramTypeConfigValueId: '', memoryInstallTypeCode: 'removable_module', speedMhz: '', manufacturerName: '', partNumber: '', serialNumber: '', changeNotes: '' }];
  const storageRows = Array.isArray(formData.storageDevices) && formData.storageDevices.length > 0
    ? formData.storageDevices
    : [{ slotLabel: 'Drive 1', sizeGb: '', storageTypeConfigValueId: '', manufacturerName: '', modelNumber: '', serialNumber: '', firmwareVersion: '', wipeStatusConfigValueId: '', changeNotes: '' }];
  const cosmeticIssueTypes = Array.isArray(formOptions.cosmeticIssueTypes) ? formOptions.cosmeticIssueTypes : [];
  const hardwareIssueTypes = Array.isArray(formOptions.hardwareIssueTypes) ? formOptions.hardwareIssueTypes : [];
  const issueLocations = Array.isArray(formOptions.issueLocations) ? formOptions.issueLocations : [];
  const issueSeverities = Array.isArray(formOptions.issueSeverities) ? formOptions.issueSeverities : [];
  const commentTypes = Array.isArray(formOptions.commentTypes) ? formOptions.commentTypes : [];
  const cosmeticIssueRows = Array.isArray(formData.cosmeticIssues) && formData.cosmeticIssues.length > 0
    ? formData.cosmeticIssues
    : [{ issueTypeConfigValueId: '', severityConfigValueId: '', locationConfigValueId: '', issueRemark: '' }];
  const hardwareIssueRows = Array.isArray(formData.hardwareIssues) && formData.hardwareIssues.length > 0
    ? formData.hardwareIssues
    : [{ issueTypeConfigValueId: '', customIssueLabel: '', locationConfigValueId: '', issueRemark: '' }];
  const generalCommentType = commentTypes.find((commentType) => {
    const normalizedCode = String(commentType.code || commentType.value || commentType.label || '').trim().toLowerCase();

    return normalizedCode === 'general';
  }) || null;
  const generalCommentTypeConfigValueId = generalCommentType
    ? generalCommentType.id
    : (formOptions.defaultCommentTypeConfigValueId || '');
  const overallGradeOptions = Array.isArray(formOptions.overallGradeOptions) ? formOptions.overallGradeOptions : [];
  const absoluteStatusOptions = Array.isArray(formOptions.absoluteStatusOptions) ? formOptions.absoluteStatusOptions : [];
  const physicalCameraStatusOptions = Array.isArray(formOptions.physicalCameraStatusOptions) ? formOptions.physicalCameraStatusOptions : [];
  const touchscreenStatusOptions = Array.isArray(formOptions.touchscreenStatusOptions) ? formOptions.touchscreenStatusOptions : [];
  const keyboardLanguageOptions = Array.isArray(formOptions.keyboardLanguageOptions) ? formOptions.keyboardLanguageOptions : [];
  const diagnosticsStatusOptions = Array.isArray(formOptions.diagnosticsStatusOptions) ? formOptions.diagnosticsStatusOptions : [];
  const virusCheckStatusOptions = Array.isArray(formOptions.virusCheckStatusOptions) ? formOptions.virusCheckStatusOptions : [];
  const driverCheckStatusOptions = Array.isArray(formOptions.driverCheckStatusOptions) ? formOptions.driverCheckStatusOptions : [];
  const skinnedStatusOptions = Array.isArray(formOptions.skinnedStatusOptions) ? formOptions.skinnedStatusOptions : [];
  const outcomeOptions = Array.isArray(formOptions.outcomeOptions) && formOptions.outcomeOptions.length > 0
    ? formOptions.outcomeOptions
    : [
        { code: 'pass', label: 'Pass' },
        { code: 'fail', label: 'Fail' }
      ];
  const selectedOutcomeCode = String(formData.outcomeCode || '').trim().toLowerCase();
  const outcomeApprovalRequested = Boolean(formData.outcomeApprovalRequested);
  const productionWeightCapabilities = formOptions.productionWeightCapabilities || {};
  const productionWeightDetails = formData.productionWeightDetails || {
    formattedEffectiveWeight: '—',
    sourceLabel: 'Calculated after save',
    sourceCode: 'not_configured',
    notes: '',
    hasOverride: false
  };
  const canOverrideProductionWeight = Boolean(formOptions.canOverrideProductionWeight && productionWeightCapabilities.hasProductionWeightOverride);
  const productionWeightHasUnitOverride = productionWeightDetails.sourceCode === 'unit_override' || Boolean(productionWeightDetails.hasOverride);
  const initialDuplicateMatches = typeof duplicateMatches !== 'undefined' && Array.isArray(duplicateMatches) ? duplicateMatches : [];
  const duplicateCheckWasForced = typeof duplicateCheckPerformed !== 'undefined' && Boolean(duplicateCheckPerformed);
  const canRequestCatalogException = !isEditMode && Boolean(formOptions.canRequestCatalogException);


  function selected(currentValue, optionValue) {
    return String(currentValue || '') === String(optionValue || '') ? 'selected' : '';
  }

  function selectedInstallType(currentValue, optionCode) {
    const safeCurrentValue = currentValue || 'removable_module';

    return String(safeCurrentValue) === String(optionCode || '') ? 'selected' : '';
  }

  function displayAssetTag(value) {
    const assetTagPrefix = formOptions && formOptions.assetTagPrefix
      ? String(formOptions.assetTagPrefix).trim().toUpperCase()
      : 'BWT';
    const rawValue = String(value || '').trim();

    if (!rawValue) {
      return '';
    }

    const compactPrefix = assetTagPrefix.replace(/[\s-]+/g, '').toUpperCase();
    const compactValue = rawValue.replace(/[\s-]+/g, '').toUpperCase();

    if (compactValue.startsWith(compactPrefix)) {
      const suffix = compactValue.slice(compactPrefix.length);
      return suffix ? `${assetTagPrefix}${suffix}` : rawValue;
    }

    if (/^\d+$/.test(compactValue)) {
      return `${assetTagPrefix}${compactValue}`;
    }

    return rawValue;
  }


  function memoryTotalGb() {
    return memoryRows.reduce((sum, row) => {
      const value = Number(row.sizeGb || 0);

      return Number.isFinite(value) && value > 0 ? sum + value : sum;
    }, 0);
  }

  function storageTotalGb() {
    return storageRows.reduce((sum, row) => {
      const value = Number(row.sizeGb || 0);

      return Number.isFinite(value) && value > 0 ? sum + value : sum;
    }, 0);
  }
%>

<% if (!formOptions.supported) { %>
  <div class="message error">
    <p><%= formOptions.message %></p>
  </div>
<% } %>

<% if (errorMessages.length > 0) { %>
  <div class="message error">
    <% errorMessages.forEach((errorMessage) => { %>
      <p><%= errorMessage %></p>
    <% }) %>
  </div>
<% } %>

<form class="app-form tech-unit-form" method="post" action="<%= formAction %>" data-tech-unit-form <%- htmxAttrs %>>
  <input type="hidden" name="ramGb" value="<%= memoryTotalGb() || formData.ramGb || '' %>" data-memory-total-input />
  <input type="hidden" name="storageGb" value="<%= storageTotalGb() || formData.storageGb || '' %>" data-storage-total-input />
  <input type="hidden" name="currentUnitStatusConfigValueId" value="<%= formData.currentUnitStatusConfigValueId || formOptions.defaultUnitStatusId || '' %>" />
  <% if (!isEditMode) { %>
    <input type="hidden" name="duplicateAssumptionNonce" value="<%= formData.duplicateAssumptionNonce || '' %>" data-duplicate-assumption-nonce />
  <% } %>

  <div class="form-section">
    <div class="form-section-header">
      <div>
        <p class="eyebrow">Assignment</p>
        <h3>Lot Assignment</h3>
      </div>
      <p>
        Select the open child or standalone lot the Tech is working on before entering serials. Closed and parent/container lots cannot receive units.
        The selected lot also controls whether a confirmed existing unit can be assumed during duplicate matching.
      </p>
    </div>

    <div class="form-grid tech-lot-assignment-grid">
      <%
        const selectedAssignableLot = formOptions.lots.find((lot) => String(lot.lot_id) === String(formData.lotId || ''));
        const selectedAssignableLotLabel = selectedAssignableLot
          ? (selectedAssignableLot.isCurrentLotClosed
            ? `${selectedAssignableLot.lot_name} (Closed — current lot)`
            : selectedAssignableLot.lot_name)
          : '';
        const selectedAssignableLotAllowsAssumption = Boolean(
          selectedAssignableLot
          && Number(selectedAssignableLot.allow_duplicate_unit_assumption || 0) === 1
        );
      %>
      <label class="form-field tech-assignable-lot-field">
        <span>Assignable Lot</span>
        <div class="tech-assignable-lot-combobox" data-assignable-lot-combobox>
          <input
            type="search"
            class="tech-assignable-lot-combobox-input"
            data-assignable-lot-combobox-input
            value="<%= selectedAssignableLotLabel %>"
            autocomplete="off"
            placeholder="Search or select an assignable lot"
            aria-label="Assignable Lot"
            aria-autocomplete="list"
            aria-expanded="false"
            aria-required="true"
          />
          <select name="lotId" data-lot-select data-assignable-lot-catalog hidden aria-hidden="true" tabindex="-1">
            <option value="">Select assignable lot</option>
            <% formOptions.lots.forEach((lot) => { %>
              <%
                const lotProductionWeightNumber = Number(lot.resolved_default_production_weight);
                const lotProductionWeightValue = Number.isFinite(lotProductionWeightNumber) ? lotProductionWeightNumber.toFixed(2) : '';
                const lotOptionLabel = lot.isCurrentLotClosed
                  ? `${lot.lot_name} (Closed — current lot)`
                  : lot.lot_name;
              %>
              <option
                value="<%= lot.lot_id %>"
                data-production-weight="<%= lotProductionWeightValue %>"
                data-allow-duplicate-unit-assumption="<%= Number(lot.allow_duplicate_unit_assumption || 0) === 1 ? '1' : '0' %>"
                <%= selected(formData.lotId, lot.lot_id) %>
              >
                <%= lotOptionLabel %>
              </option>
            <% }) %>
          </select>
          <div class="tech-assignable-lot-options" data-assignable-lot-options role="listbox" hidden></div>
        </div>
        <small class="field-hint" data-assignable-lot-hint>
          Search by lot name, then choose a listed assignable lot. Closed lots and parent/container lots cannot receive units.
          <% if (formOptions.currentLotIsClosed) { %>
            This unit remains in its current closed lot unless you select an open destination lot.
          <% } %>
        </small>
      </label>

      <% if (!isEditMode) { %>
        <p
          class="tech-lot-assumption-status"
          data-assignable-lot-assumption-status
          data-status="<%= selectedAssignableLotAllowsAssumption ? 'enabled' : 'disabled' %>"
          <%= selectedAssignableLot ? '' : 'hidden' %>
          aria-live="polite"
        >
          Existing-unit assumption is
          <span data-assignable-lot-assumption-status-state><%= selectedAssignableLotAllowsAssumption ? 'enabled' : 'not enabled' %></span>
          for this lot.
        </p>
      <% } %>
    </div>
  </div>

  <div class="form-section">
    <div class="form-section-header">
      <div>
        <p class="eyebrow">Identity</p>
        <h3>Unit Identity</h3>
      </div>
      <p>
        Asset tags are generated only after a new unit is created. Unit serial and BIOS serial are checked early for possible existing units,
        using case-insensitive matching across both serial fields.
      </p>
    </div>

    <div class="form-grid">
      <% if (isEditMode) { %>
        <div class="form-field tech-unit-asset-tag-readonly">
          <span>Asset Tag</span>
          <output><%= displayAssetTag(formData.assetTag) || '—' %></output>
          <small class="field-hint">Asset tags are permanent and cannot be changed.</small>
        </div>
      <% } %>

      <label class="form-field">
        <span>Unit Serial Number</span>
        <input
          type="text"
          name="unitSerialNumber"
          value="<%= formData.unitSerialNumber %>"
          placeholder="Physical serial from the unit"
          autocomplete="off"
          spellcheck="false"
          maxlength="150"
          data-duplicate-check-serial
        />
        <small class="field-hint">
          Usually copied from the device label or chassis. The system checks both serial types after you leave this field.
        </small>
      </label>

      <label class="form-field">
        <span>BIOS Serial Number</span>
        <input
          type="text"
          name="biosSerialNumber"
          value="<%= formData.biosSerialNumber %>"
          placeholder="Serial reported by BIOS or ScanTool"
          autocomplete="off"
          spellcheck="false"
          maxlength="150"
          data-duplicate-check-serial
        />
        <small class="field-hint">
          BIOS serial is checked against both stored serial types after you leave this field.
        </small>
      </label>
    </div>

    <% if (!isEditMode) { %>
      <div class="tech-unit-duplicate-check-region" data-duplicate-check-region aria-live="polite">
        <% if (duplicateCheckWasForced) { %>
          <%- include('./tech-unit-duplicate-check', {
            duplicateMatches: initialDuplicateMatches,
            hasSerialSearch: true,
            destinationLotId: formData.lotId || '',
            canRequestIntentionalDuplicate: typeof canRequestIntentionalDuplicate !== 'undefined' ? canRequestIntentionalDuplicate : false
          }) %>
        <% } %>
      </div>
    <% } %>
  </div>

  <div class="form-section">
    <div class="form-section-header">
      <div>
        <p class="eyebrow">Model</p>
        <h3>Manufacturer and Model</h3>
      </div>
      <p>
        Select the manufacturer first, then search its managed model catalog. Choosing a model automatically applies its matching Unit Category.
      </p>
    </div>

    <div class="form-grid">
      <label class="form-field">
        <span>Manufacturer</span>
        <select name="manufacturerId" data-manufacturer-select>
          <option value="">Select manufacturer</option>
          <% formOptions.manufacturers.forEach((manufacturer) => { %>
            <option value="<%= manufacturer.id %>" <%= selected(formData.manufacturerId, manufacturer.id) %>>
              <%= manufacturer.label %>
            </option>
          <% }) %>
        </select>
        <small class="field-hint">
          Selecting a manufacturer loads only that manufacturer's model catalog.
        </small>
      </label>

      <label class="form-field tech-unit-model-field">
        <span>Unit Model</span>
        <div class="tech-unit-model-combobox" data-unit-model-combobox>
          <input
            type="search"
            class="tech-unit-model-combobox-input"
            data-unit-model-combobox-input
            autocomplete="off"
            placeholder="Select manufacturer first"
            aria-label="Unit Model"
            aria-autocomplete="list"
            aria-expanded="false"
            disabled
          />
          <input type="hidden" name="unitModelId" value="<%= formData.unitModelId || '' %>" data-unit-model-select />
          <div class="tech-unit-model-options" data-unit-model-options role="listbox" hidden></div>
          <select data-unit-model-catalog hidden aria-hidden="true" tabindex="-1">
            <% formOptions.unitModels.forEach((unitModel) => { %>
              <option
                value="<%= unitModel.id %>"
                data-manufacturer-id="<%= unitModel.manufacturerId || '' %>"
                data-category-id="<%= unitModel.unitCategoryConfigValueId || '' %>"
                data-model-active="<%= unitModel.isActive ? '1' : '0' %>"
                <%= selected(formData.unitModelId, unitModel.id) %>
              >
                <%= unitModel.label %><%= unitModel.isActive ? '' : ' (Inactive)' %>
              </option>
            <% }) %>
          </select>
        </div>
        <small class="field-hint" data-unit-model-hint>
          Select a manufacturer to load its model catalog. Choosing a model sets the matching Unit Category.
        </small>
      </label>

      <label class="form-field">
        <span>Unit Category</span>
        <select name="unitCategoryConfigValueId" required data-unit-category-select>
          <option value="">Select category</option>
          <% formOptions.unitCategories.forEach((category) => { %>
            <option value="<%= category.id %>" data-production-weight="<%= category.defaultProductionWeightValue || '' %>" <%= selected(formData.unitCategoryConfigValueId, category.id) %>>
              <%= category.label %>
            </option>
          <% }) %>
        </select>
        <small class="field-hint">
          Selecting a managed model applies its matching category. Choose a category manually only when no catalog model is selected.
        </small>
      </label>
    </div>

    <% if (canRequestCatalogException) { %>
      <div class="tech-catalog-request-action">
        <button type="button" class="secondary-button" data-catalog-request-button="model" disabled aria-disabled="true">Request Missing Model</button>
        <small class="field-hint" data-catalog-request-model-hint>Select Manufacturer and Unit Category, then type the exact model name that is missing from the managed catalog.</small>
      </div>
    <% } %>
  </div>

<% if (isEditMode) { %>
  <div class="form-section form-section--production-weight">
    <div class="form-section-header">
      <div>
        <p class="eyebrow">Production Weight</p>
        <h3>Production Weight</h3>
      </div>
      <p>
        Review the effective weight before saving.
      </p>
    </div>

    <div class="production-weight-preview-grid production-weight-preview-grid--simple">
      <div class="production-weight-preview-card">
        <span>Effective Weight</span>
        <strong data-production-weight-preview-value><%= productionWeightDetails.formattedEffectiveWeight || '—' %></strong>
        <small class="production-weight-unit-override-label" data-production-weight-unit-override-label data-initial-unit-override="<%= productionWeightHasUnitOverride ? 'true' : 'false' %>" <%= productionWeightHasUnitOverride ? '' : 'hidden' %>>Unit override</small>
      </div>
    </div>

    <% if (productionWeightDetails.notes) { %>
      <p class="field-hint production-weight-existing-note">
        Current override note: <%= productionWeightDetails.notes %>
      </p>
    <% } %>

    <% if (canOverrideProductionWeight) { %>
      <div class="form-grid">
        <label class="form-field">
          <span>Unit Override Weight</span>
          <input
            type="number"
            name="productionWeightOverride"
            value="<%= formData.productionWeightOverride || '' %>"
            step="0.01"
            min="0"
            placeholder="Optional custom weight"
            autocomplete="off"
            data-production-weight-override-input
          />
          <small class="field-hint">
            Leave blank to use the selected lot/category weight.
          </small>
        </label>

        <label class="form-field">
          <span>Unit Override Notes</span>
          <textarea name="productionWeightNotes" rows="3" maxlength="500" placeholder="Optional unit override note"><%= formData.productionWeightNotes || '' %></textarea>
          <small class="field-hint">
            Optional note for the unit override.
          </small>
        </label>
      </div>
    <% } %>
  </div>
<% } %>

  <div class="form-section">
    <div class="form-section-header">
      <div>
        <p class="eyebrow">CPU</p>
        <h3>Processor Information</h3>
      </div>
      <p>
        CPU details are used as a secondary confidence check when matching a unit by serial number.
        The expected display format is CPU manufacturer, CPU model, and speed.
      </p>
    </div>

    <div class="form-grid">
      <label class="form-field">
        <span>Processor Type</span>
        <select data-processor-brand-select disabled>
          <option value="">Select Unit Model first</option>
          <% (formOptions.processorBrands || []).forEach((processorBrand) => { %>
            <option value="<%= processorBrand.id %>"><%= processorBrand.label %></option>
          <% }) %>
        </select>
        <small class="field-hint" data-processor-brand-hint>
          Processor types are limited to the selected Unit Model.
        </small>
      </label>

      <label class="form-field tech-unit-processor-field">
        <span>Processor</span>
        <div class="tech-unit-processor-combobox" data-processor-combobox>
          <input
            type="search"
            class="tech-unit-processor-combobox-input"
            data-processor-combobox-input
            autocomplete="off"
            placeholder="Select Unit Model first"
            aria-label="Processor"
            aria-autocomplete="list"
            aria-expanded="false"
            disabled
          />
          <input type="hidden" name="processorModelId" value="<%= formData.processorModelId || '' %>" data-processor-model-select />
          <div class="tech-unit-processor-options" data-processor-options role="listbox" hidden></div>
          <select data-processor-catalog hidden aria-hidden="true" tabindex="-1">
            <% formOptions.processorModels.forEach((processorModel) => { %>
              <option
                value="<%= processorModel.id %>"
                data-processor-brand-id="<%= processorModel.processorBrandId || '' %>"
                data-compatible-unit-model-ids="<%= (processorModel.compatibleUnitModelIds || []).join(',') %>"
                data-base-speed-ghz="<%= processorModel.baseSpeedGhz || '' %>"
                <%= selected(formData.processorModelId, processorModel.id) %>
              >
                <%= processorModel.label %>
              </option>
            <% }) %>
          </select>
        </div>
        <small class="field-hint" data-processor-model-hint>
          Select a compatible Processor Type, then search its allowed processor values.
        </small>
      </label>

      <label class="form-field">
        <span>Processor Speed GHz</span>
        <input
          type="number"
          name="processorSpeedGhz"
          value="<%= formData.processorSpeedGhz %>"
          min="0"
          step="0.01"
          placeholder="Example: 2.40"
          data-processor-speed-input
        />
        <small class="field-hint">
          Store the numeric speed only. The frontend displays it with GHz.
        </small>
      </label>
    </div>

    <% if (canRequestCatalogException) { %>
      <div class="tech-catalog-request-action">
        <button type="button" class="secondary-button" data-catalog-request-button="processor" disabled aria-disabled="true">Request Processor Addition</button>
        <small class="field-hint" data-catalog-request-processor-hint>Select a Unit Model first. Use this only when the observed Processor Type or Processor is unavailable for that model.</small>
      </div>
    <% } %>
  </div>

  <div class="form-section">
    <div class="form-section-header">
      <div>
        <p class="eyebrow">Memory</p>
        <h3>Memory Modules</h3>
      </div>
      <p>
        Record each installed memory module separately. The total memory value is calculated from the module rows and saved back to the unit summary.
      </p>
    </div>

    <div class="workflow-list" data-module-list="memory">
      <% memoryRows.forEach((moduleRow, index) => { %>
        <article class="workflow-item slate" data-module-row="memory">
          <span></span>
          <div style="width: 100%;">
            <div class="content-header" style="align-items: center; margin-bottom: 12px;">
              <div>
                <strong>Memory Module <span data-module-display-number><%= index + 1 %></span></strong>
                <p>Slot, size, type, and install type.</p>
              </div>
              <button type="button" class="secondary-button" data-remove-module-row>Remove</button>
            </div>

            <div class="form-grid">
              <label class="form-field">
                <span>Slot Label</span>
                <input type="text" name="memoryModules[<%= index %>][slotLabel]" value="<%= moduleRow.slotLabel || '' %>" placeholder="Slot 1" maxlength="80" data-module-field />
              </label>

              <label class="form-field">
                <span>Size GB</span>
                <input type="number" name="memoryModules[<%= index %>][sizeGb]" value="<%= moduleRow.sizeGb || '' %>" min="1" step="1" placeholder="Example: 8" data-memory-size-input data-module-field />
              </label>

              <label class="form-field">
                <span>Memory Type</span>
                <select name="memoryModules[<%= index %>][ramTypeConfigValueId]" data-module-field>
                  <option value="">Select memory type</option>
                  <% formOptions.ramTypes.forEach((ramType) => { %>
                    <option value="<%= ramType.id %>" <%= selected(moduleRow.ramTypeConfigValueId, ramType.id) %>><%= ramType.label %></option>
                  <% }) %>
                </select>
      </label>

              <label class="form-field">
                <span>Install Type</span>
                <select name="memoryModules[<%= index %>][memoryInstallTypeCode]" data-module-field>
                  <% memoryInstallTypes.forEach((installType) => { %>
                    <option value="<%= installType.code %>" <%= selectedInstallType(moduleRow.memoryInstallTypeCode, installType.code) %>><%= installType.label %></option>
                  <% }) %>
                </select>
                <small class="field-hint">Defaults to removable. Use integrated/soldered when memory cannot be removed.</small>
              </label>

              <input type="hidden" name="memoryModules[<%= index %>][speedMhz]" value="<%= moduleRow.speedMhz || '' %>" />
              <input type="hidden" name="memoryModules[<%= index %>][manufacturerName]" value="<%= moduleRow.manufacturerName || '' %>" />
              <input type="hidden" name="memoryModules[<%= index %>][partNumber]" value="<%= moduleRow.partNumber || '' %>" />
              <input type="hidden" name="memoryModules[<%= index %>][serialNumber]" value="<%= moduleRow.serialNumber || '' %>" />

              <label class="form-field">
                <span>Change Notes</span>
                <input type="text" name="memoryModules[<%= index %>][changeNotes]" value="<%= moduleRow.changeNotes || '' %>" maxlength="500" placeholder="Installed, replaced, upgraded, downgraded, etc." data-module-field />
              </label>
            </div>
          </div>
        </article>
      <% }) %>
    </div>

    <div class="form-actions" style="margin-top: 12px;">
      <button type="button" class="secondary-button" data-add-module-row="memory">+ Add Memory Module</button>
      <span class="field-hint">Total Memory: <strong data-memory-total-display><%= memoryTotalGb() || formData.ramGb || 0 %></strong>GB</span>
    </div>
  </div>

  <div class="form-section">
    <div class="form-section-header">
      <div>
        <p class="eyebrow">Storage</p>
        <h3>Storage Devices</h3>
      </div>
      <p>
        Record each installed storage device separately. Previous current devices are preserved as history when the saved current set changes.
      </p>
    </div>

    <div class="workflow-list" data-module-list="storage">
