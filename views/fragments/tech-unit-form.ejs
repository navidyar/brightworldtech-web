<%
  const isEditMode = mode === 'edit';
  const htmxAttrs = isModal ? `hx-post="${formAction}" hx-target="#modal-root" hx-swap="innerHTML"` : '';
  const memoryInstallTypes = Array.isArray(formOptions.memoryInstallTypes) && formOptions.memoryInstallTypes.length > 0
    ? formOptions.memoryInstallTypes
    : [
        { code: 'removable_module', label: 'Removable Module' },
        { code: 'integrated_soldered', label: 'Integrated / Soldered' },
        { code: 'unknown', label: 'Unknown' }
      ];
  const memoryRows = Array.isArray(formData.memoryModules) && formData.memoryModules.length > 0
    ? formData.memoryModules
    : [{ slotLabel: 'Slot 1', sizeGb: '', ramTypeConfigValueId: '', memoryInstallTypeCode: 'removable_module', speedMhz: '', manufacturerName: '', partNumber: '', serialNumber: '', changeNotes: '' }];
  const storageRows = Array.isArray(formData.storageDevices) && formData.storageDevices.length > 0
    ? formData.storageDevices
    : [{ slotLabel: 'Drive 1', sizeGb: '', storageTypeConfigValueId: '', manufacturerName: '', modelNumber: '', serialNumber: '', firmwareVersion: '', wipeStatusConfigValueId: '', changeNotes: '' }];
  const cosmeticIssueTypes = Array.isArray(formOptions.cosmeticIssueTypes) ? formOptions.cosmeticIssueTypes : [];
  const hardwareIssueTypes = Array.isArray(formOptions.hardwareIssueTypes) ? formOptions.hardwareIssueTypes : [];
  const issueLocations = Array.isArray(formOptions.issueLocations) ? formOptions.issueLocations : [];
  const issueSeverities = Array.isArray(formOptions.issueSeverities) ? formOptions.issueSeverities : [];
  const commentTypes = Array.isArray(formOptions.commentTypes) ? formOptions.commentTypes : [];
  const cosmeticIssueRows = Array.isArray(formData.cosmeticIssues) && formData.cosmeticIssues.length > 0
    ? formData.cosmeticIssues
    : [{ issueTypeConfigValueId: '', severityConfigValueId: '', locationConfigValueId: '', issueRemark: '' }];
  const hardwareIssueRows = Array.isArray(formData.hardwareIssues) && formData.hardwareIssues.length > 0
    ? formData.hardwareIssues
    : [{ issueTypeConfigValueId: '', customIssueLabel: '', locationConfigValueId: '', issueRemark: '' }];
  const selectedCommentTypeConfigValueId = formData.generalCommentTypeConfigValueId || formOptions.defaultCommentTypeConfigValueId || '';

  function selected(currentValue, optionValue) {
    return String(currentValue || '') === String(optionValue || '') ? 'selected' : '';
  }

  function selectedInstallType(currentValue, optionCode) {
    const safeCurrentValue = currentValue || 'removable_module';

    return String(safeCurrentValue) === String(optionCode || '') ? 'selected' : '';
  }

  function memoryTotalGb() {
    return memoryRows.reduce((sum, row) => {
      const value = Number(row.sizeGb || 0);

      return Number.isFinite(value) && value > 0 ? sum + value : sum;
    }, 0);
  }

  function storageTotalGb() {
    return storageRows.reduce((sum, row) => {
      const value = Number(row.sizeGb || 0);

      return Number.isFinite(value) && value > 0 ? sum + value : sum;
    }, 0);
  }
%>

<% if (!formOptions.supported) { %>
  <div class="message error">
    <p><%= formOptions.message %></p>
  </div>
<% } %>

<% if (errorMessages.length > 0) { %>
  <div class="message error">
    <% errorMessages.forEach((errorMessage) => { %>
      <p><%= errorMessage %></p>
    <% }) %>
  </div>
<% } %>

<form class="app-form tech-unit-form" method="post" action="<%= formAction %>" data-tech-unit-form <%- htmxAttrs %>>
  <input type="hidden" name="ramGb" value="<%= memoryTotalGb() || formData.ramGb || '' %>" data-memory-total-input />
  <input type="hidden" name="storageGb" value="<%= storageTotalGb() || formData.storageGb || '' %>" data-storage-total-input />

  <div class="form-section">
    <div class="form-section-header">
      <div>
        <p class="eyebrow">Identity</p>
        <h3>Unit Identity</h3>
      </div>
      <p>
        These fields help identify the physical unit and prevent duplicate records. Asset tags are the strongest match;
        unit serial and BIOS serial are used when an asset tag is missing, removed, or not yet attached.
      </p>
    </div>

    <div class="form-grid">
      <label class="form-field">
        <span>Asset Tag</span>
        <input
          type="text"
          name="assetTag"
          value="<%= formData.assetTag %>"
          placeholder="<%= isEditMode ? '' : `${formOptions.assetTagPrefix || 'BWT'}2300001 or blank for auto-generate` %>"
          autocomplete="off"
          spellcheck="false"
          <%= isEditMode ? 'disabled' : '' %>
        />
        <small class="field-hint">
          Enter <%= formOptions.assetTagPrefix || 'BWT' %>2300001 or 2300001. Leave blank on create to auto-generate the next asset tag.
        </small>
      </label>

      <label class="form-field">
        <span>Unit Serial Number</span>
        <input
          type="text"
          name="unitSerialNumber"
          value="<%= formData.unitSerialNumber %>"
          placeholder="Physical serial from the unit"
          autocomplete="off"
          spellcheck="false"
          maxlength="150"
        />
        <small class="field-hint">
          Usually copied from the device label or chassis. This is used for duplicate detection.
        </small>
      </label>

      <label class="form-field">
        <span>BIOS Serial Number</span>
        <input
          type="text"
          name="biosSerialNumber"
          value="<%= formData.biosSerialNumber %>"
          placeholder="Serial reported by BIOS or ScanTool"
          autocomplete="off"
          spellcheck="false"
          maxlength="150"
        />
        <small class="field-hint">
          BIOS serial is a stronger confirmation than the physical serial alone.
        </small>
      </label>
    </div>
  </div>

  <div class="form-section">
    <div class="form-section-header">
      <div>
        <p class="eyebrow">Assignment</p>
        <h3>Lot and Workflow Status</h3>
      </div>
      <p>
        Assign the unit to the child lot the tech is working on. Parent/container lots are not assignable.
        If an existing unit is confirmed during duplicate matching, changing the lot records a lot-movement history entry.
      </p>
    </div>

    <div class="form-grid">
      <label class="form-field">
        <span>Assignable Lot</span>
        <select name="lotId" required>
          <option value="">Select assignable lot</option>
          <% formOptions.lots.forEach((lot) => { %>
            <option value="<%= lot.lot_id %>" <%= selected(formData.lotId, lot.lot_id) %>>
              <%= lot.lot_name %>
              <% if (lot.lot_number) { %>
                - Lot #<%= lot.lot_number %>
              <% } %>
            </option>
          <% }) %>
        </select>
        <small class="field-hint">
          Lots with child lots are containers and cannot receive units directly.
        </small>
      </label>

      <label class="form-field">
        <span>Unit Category</span>
        <select name="unitCategoryConfigValueId" required data-unit-category-select>
          <option value="">Select category</option>
          <% formOptions.unitCategories.forEach((category) => { %>
            <option value="<%= category.id %>" <%= selected(formData.unitCategoryConfigValueId, category.id) %>>
              <%= category.label %>
            </option>
          <% }) %>
        </select>
        <small class="field-hint">
          Required. Selecting a model can auto-fill this if the model has a category.
        </small>
      </label>

      <label class="form-field">
        <span>Unit Status</span>
        <select name="currentUnitStatusConfigValueId" required>
          <option value="">Select status</option>
          <% formOptions.unitStatuses.forEach((status) => { %>
            <option value="<%= status.id %>" <%= selected(formData.currentUnitStatusConfigValueId, status.id) %>>
              <%= status.label %>
            </option>
          <% }) %>
        </select>
        <small class="field-hint">Required. New units default to Received when that status exists.</small>
      </label>
    </div>
  </div>

  <div class="form-section">
    <div class="form-section-header">
      <div>
        <p class="eyebrow">Model</p>
        <h3>Manufacturer and Model</h3>
      </div>
      <p>
        Model selection is separated from identity so techs can first confirm the physical unit, then record the make/model details.
        The model dropdown filters by selected manufacturer and unit category.
      </p>
    </div>

    <div class="form-grid">
      <label class="form-field">
        <span>Manufacturer</span>
        <select name="manufacturerId" data-manufacturer-select>
          <option value="">Select manufacturer</option>
          <% formOptions.manufacturers.forEach((manufacturer) => { %>
            <option value="<%= manufacturer.id %>" <%= selected(formData.manufacturerId, manufacturer.id) %>>
              <%= manufacturer.label %>
            </option>
          <% }) %>
        </select>
        <small class="field-hint">
          Selecting a manufacturer filters the model dropdown.
        </small>
      </label>

      <label class="form-field">
        <span>Unit Model</span>
        <select name="unitModelId" data-unit-model-select>
          <option value="">Select model</option>
          <% formOptions.unitModels.forEach((unitModel) => { %>
            <option
              value="<%= unitModel.id %>"
              data-manufacturer-id="<%= unitModel.manufacturerId || '' %>"
              data-category-id="<%= unitModel.unitCategoryConfigValueId || '' %>"
              <%= selected(formData.unitModelId, unitModel.id) %>
            >
              <%= unitModel.label %>
            </option>
          <% }) %>
        </select>
        <small class="field-hint" data-unit-model-hint>
          Models can be filtered by manufacturer and category.
        </small>
      </label>
    </div>
  </div>

  <div class="form-section">
    <div class="form-section-header">
      <div>
        <p class="eyebrow">CPU</p>
        <h3>Processor Information</h3>
      </div>
      <p>
        CPU details are used as a secondary confidence check when matching a unit by serial number.
        The expected display format is CPU manufacturer, CPU model, and speed.
      </p>
    </div>

    <div class="form-grid">
      <label class="form-field">
        <span>Processor Model</span>
        <select name="processorModelId" data-processor-model-select>
          <option value="">Select processor</option>
          <% formOptions.processorModels.forEach((processorModel) => { %>
            <option
              value="<%= processorModel.id %>"
              data-base-speed-ghz="<%= processorModel.baseSpeedGhz || '' %>"
              <%= selected(formData.processorModelId, processorModel.id) %>
            >
              <%= processorModel.label %>
            </option>
          <% }) %>
        </select>
        <small class="field-hint">
          Choosing a processor can auto-fill speed if the base speed exists in the processor list.
        </small>
      </label>

      <label class="form-field">
        <span>Processor Speed GHz</span>
        <input
          type="number"
          name="processorSpeedGhz"
          value="<%= formData.processorSpeedGhz %>"
          min="0"
          step="0.01"
          placeholder="Example: 2.40"
          data-processor-speed-input
        />
        <small class="field-hint">
          Store the numeric speed only. The frontend displays it with GHz.
        </small>
      </label>
    </div>
  </div>

  <div class="form-section">
    <div class="form-section-header">
      <div>
        <p class="eyebrow">Memory</p>
        <h3>RAM Modules</h3>
      </div>
      <p>
        Record each installed RAM module separately. The total RAM value is calculated from the module rows and saved back to the unit summary.
      </p>
    </div>

    <div class="workflow-list" data-module-list="memory">
      <% memoryRows.forEach((moduleRow, index) => { %>
        <article class="workflow-item slate" data-module-row="memory">
          <span></span>
          <div style="width: 100%;">
            <div class="content-header" style="align-items: center; margin-bottom: 12px;">
              <div>
                <strong>RAM Module <span data-module-display-number><%= index + 1 %></span></strong>
                <p>Slot, size, type, speed, and module identifiers.</p>
              </div>
              <button type="button" class="secondary-button" data-remove-module-row>Remove</button>
            </div>

            <div class="form-grid">
              <label class="form-field">
                <span>Slot Label</span>
                <input type="text" name="memoryModules[<%= index %>][slotLabel]" value="<%= moduleRow.slotLabel || '' %>" placeholder="Slot 1" maxlength="80" data-module-field />
              </label>

              <label class="form-field">
                <span>Size GB</span>
                <input type="number" name="memoryModules[<%= index %>][sizeGb]" value="<%= moduleRow.sizeGb || '' %>" min="1" step="1" placeholder="Example: 8" data-memory-size-input data-module-field />
              </label>

              <label class="form-field">
                <span>RAM Type</span>
                <select name="memoryModules[<%= index %>][ramTypeConfigValueId]" data-module-field>
                  <option value="">Select RAM type</option>
                  <% formOptions.ramTypes.forEach((ramType) => { %>
                    <option value="<%= ramType.id %>" <%= selected(moduleRow.ramTypeConfigValueId, ramType.id) %>><%= ramType.label %></option>
                  <% }) %>
                </select>
              </label>

              <label class="form-field">
                <span>Install Type</span>
                <select name="memoryModules[<%= index %>][memoryInstallTypeCode]" data-module-field>
                  <% memoryInstallTypes.forEach((installType) => { %>
                    <option value="<%= installType.code %>" <%= selectedInstallType(moduleRow.memoryInstallTypeCode, installType.code) %>><%= installType.label %></option>
                  <% }) %>
                </select>
                <small class="field-hint">Defaults to removable. Use integrated/soldered when RAM cannot be removed.</small>
              </label>

              <label class="form-field">
                <span>Speed MHz</span>
                <input type="number" name="memoryModules[<%= index %>][speedMhz]" value="<%= moduleRow.speedMhz || '' %>" min="1" step="1" placeholder="Example: 3200" data-module-field />
              </label>

              <label class="form-field">
                <span>Module Manufacturer</span>
                <input type="text" name="memoryModules[<%= index %>][manufacturerName]" value="<%= moduleRow.manufacturerName || '' %>" maxlength="120" placeholder="Example: Samsung" data-module-field />
              </label>

              <label class="form-field">
                <span>Part Number</span>
                <input type="text" name="memoryModules[<%= index %>][partNumber]" value="<%= moduleRow.partNumber || '' %>" maxlength="120" data-module-field />
              </label>

              <label class="form-field">
                <span>Serial Number</span>
                <input type="text" name="memoryModules[<%= index %>][serialNumber]" value="<%= moduleRow.serialNumber || '' %>" maxlength="120" data-module-field />
              </label>

              <label class="form-field">
                <span>Change Notes</span>
                <input type="text" name="memoryModules[<%= index %>][changeNotes]" value="<%= moduleRow.changeNotes || '' %>" maxlength="500" placeholder="Installed, replaced, upgraded, downgraded, etc." data-module-field />
              </label>
            </div>
          </div>
        </article>
      <% }) %>
    </div>

    <div class="form-actions" style="margin-top: 12px;">
      <button type="button" class="secondary-button" data-add-module-row="memory">+ Add RAM Module</button>
      <span class="field-hint">Total RAM: <strong data-memory-total-display><%= memoryTotalGb() || formData.ramGb || 0 %></strong>GB</span>
    </div>
  </div>

  <div class="form-section">
    <div class="form-section-header">
      <div>
        <p class="eyebrow">Storage</p>
        <h3>Storage Devices</h3>
      </div>
      <p>
        Record each installed storage device separately. Previous current devices are preserved as history when the saved current set changes.
      </p>
    </div>

    <div class="workflow-list" data-module-list="storage">
      <% storageRows.forEach((deviceRow, index) => { %>
        <article class="workflow-item slate" data-module-row="storage">
          <span></span>
          <div style="width: 100%;">
            <div class="content-header" style="align-items: center; margin-bottom: 12px;">
              <div>
                <strong>Storage Device <span data-module-display-number><%= index + 1 %></span></strong>
                <p>Drive slot, size, type, model, serial, firmware, and wipe status.</p>
              </div>
              <button type="button" class="secondary-button" data-remove-module-row>Remove</button>
            </div>

            <div class="form-grid">
              <label class="form-field">
                <span>Slot Label</span>
                <input type="text" name="storageDevices[<%= index %>][slotLabel]" value="<%= deviceRow.slotLabel || '' %>" placeholder="Drive 1" maxlength="80" data-module-field />
              </label>

              <label class="form-field">
                <span>Size GB</span>
                <input type="number" name="storageDevices[<%= index %>][sizeGb]" value="<%= deviceRow.sizeGb || '' %>" min="1" step="1" placeholder="Example: 256" data-storage-size-input data-module-field />
              </label>

              <label class="form-field">
                <span>Storage Type</span>
                <select name="storageDevices[<%= index %>][storageTypeConfigValueId]" data-module-field>
                  <option value="">Select storage type</option>
                  <% formOptions.storageTypes.forEach((storageType) => { %>
                    <option value="<%= storageType.id %>" <%= selected(deviceRow.storageTypeConfigValueId, storageType.id) %>><%= storageType.label %></option>
                  <% }) %>
                </select>
              </label>

              <label class="form-field">
                <span>Wipe Status</span>
                <select name="storageDevices[<%= index %>][wipeStatusConfigValueId]" data-module-field>
                  <option value="">Select wipe status</option>
                  <% (formOptions.storageWipeStatuses || []).forEach((wipeStatus) => { %>
                    <option value="<%= wipeStatus.id %>" <%= selected(deviceRow.wipeStatusConfigValueId, wipeStatus.id) %>><%= wipeStatus.label %></option>
                  <% }) %>
                </select>
              </label>

              <label class="form-field">
                <span>Drive Manufacturer</span>
                <input type="text" name="storageDevices[<%= index %>][manufacturerName]" value="<%= deviceRow.manufacturerName || '' %>" maxlength="120" placeholder="Example: Samsung" data-module-field />
              </label>

              <label class="form-field">
                <span>Model Number</span>
                <input type="text" name="storageDevices[<%= index %>][modelNumber]" value="<%= deviceRow.modelNumber || '' %>" maxlength="120" data-module-field />
              </label>

              <label class="form-field">
                <span>Serial Number</span>
                <input type="text" name="storageDevices[<%= index %>][serialNumber]" value="<%= deviceRow.serialNumber || '' %>" maxlength="120" data-module-field />
              </label>

              <label class="form-field">
                <span>Firmware Version</span>
                <input type="text" name="storageDevices[<%= index %>][firmwareVersion]" value="<%= deviceRow.firmwareVersion || '' %>" maxlength="120" data-module-field />
              </label>

              <label class="form-field">
                <span>Change Notes</span>
                <input type="text" name="storageDevices[<%= index %>][changeNotes]" value="<%= deviceRow.changeNotes || '' %>" maxlength="500" placeholder="Installed, replaced, upgraded, downgraded, wiped, etc." data-module-field />
              </label>
            </div>
          </div>
        </article>
      <% }) %>
    </div>

    <div class="form-actions" style="margin-top: 12px;">
      <button type="button" class="secondary-button" data-add-module-row="storage">+ Add Storage Device</button>
      <span class="field-hint">Total Storage: <strong data-storage-total-display><%= storageTotalGb() || formData.storageGb || 0 %></strong>GB</span>
    </div>
  </div>

  <div class="form-section">
    <div class="form-section-header">
      <div>
        <p class="eyebrow">Operating System</p>
        <h3>OS Summary</h3>
      </div>
      <p>
        Operating system is kept separate from hardware because ELS intake may stop before OS installation, while full refurb lots may require OS details later.
      </p>
    </div>

    <div class="form-grid">
      <label class="form-field">
        <span>Operating System</span>
        <select name="operatingSystemConfigValueId">
          <option value="">Select OS</option>
          <% formOptions.operatingSystems.forEach((operatingSystem) => { %>
            <option value="<%= operatingSystem.id %>" <%= selected(formData.operatingSystemConfigValueId, operatingSystem.id) %>>
              <%= operatingSystem.label %>
            </option>
          <% }) %>
        </select>
        <small class="field-hint">
          OS build and diagnostics fields will be added after the expanded form foundation is ready.
        </small>
      </label>
    </div>
  </div>

  <div class="form-section">
    <div class="form-section-header">
      <div>
        <p class="eyebrow">Cosmetic Issues</p>
        <h3>Cosmetic Issue Rows</h3>
      </div>
      <p>
        Add each cosmetic issue as its own row with an issue type, severity, location, and optional remarks. These rows are saved as the current cosmetic issue list while older rows remain in database history.
      </p>
    </div>

    <% if (cosmeticIssueTypes.length === 0 || issueSeverities.length === 0 || issueLocations.length === 0) { %>
      <div class="message error">
        <p>Cosmetic issue options are not ready yet. Run the Step 3f SQL migration to seed issue types, severities, and locations.</p>
      </div>
    <% } %>

    <div class="workflow-list" data-module-list="cosmeticIssue">
      <% cosmeticIssueRows.forEach((issueRow, index) => { %>
        <article class="workflow-item slate" data-module-row="cosmeticIssue">
          <span></span>
          <div style="width: 100%;">
            <div class="content-header" style="align-items: center; margin-bottom: 12px;">
              <div>
                <strong>Cosmetic Issue <span data-module-display-number><%= index + 1 %></span></strong>
                <p>Issue type, severity, location, and remarks.</p>
              </div>
              <button type="button" class="secondary-button" data-remove-module-row>Remove</button>
            </div>

            <div class="form-grid">
              <label class="form-field">
                <span>Issue Type</span>
                <select name="cosmeticIssues[<%= index %>][issueTypeConfigValueId]" data-module-field>
                  <option value="">Select cosmetic issue</option>
                  <% cosmeticIssueTypes.forEach((issueType) => { %>
                    <option value="<%= issueType.id %>" <%= selected(issueRow.issueTypeConfigValueId, issueType.id) %>><%= issueType.label %></option>
                  <% }) %>
                </select>
              </label>

              <label class="form-field">
                <span>Severity</span>
                <select name="cosmeticIssues[<%= index %>][severityConfigValueId]" data-module-field>
                  <option value="">Select severity</option>
                  <% issueSeverities.forEach((severity) => { %>
                    <option value="<%= severity.id %>" <%= selected(issueRow.severityConfigValueId, severity.id) %>><%= severity.label %></option>
                  <% }) %>
                </select>
              </label>

              <label class="form-field">
                <span>Location</span>
                <select name="cosmeticIssues[<%= index %>][locationConfigValueId]" data-module-field>
                  <option value="">Select location</option>
                  <% issueLocations.forEach((location) => { %>
                    <option value="<%= location.id %>" <%= selected(issueRow.locationConfigValueId, location.id) %>><%= location.label %></option>
                  <% }) %>
                </select>
              </label>

              <label class="form-field">
                <span>Remarks</span>
                <input type="text" name="cosmeticIssues[<%= index %>][issueRemark]" value="<%= issueRow.issueRemark || '' %>" maxlength="500" placeholder="Short note explaining the issue" data-module-field />
              </label>
            </div>
          </div>
        </article>
      <% }) %>
    </div>

    <div class="form-actions" style="margin-top: 12px;">
      <button type="button" class="secondary-button" data-add-module-row="cosmeticIssue">+ Add Cosmetic Issue</button>
    </div>
  </div>

  <div class="form-section">
    <div class="form-section-header">
      <div>
        <p class="eyebrow">Hardware Issues</p>
        <h3>Hardware Issue Rows</h3>
      </div>
      <p>
        Add hardware failures as structured rows. Hardware issues can use a configured issue type or a custom issue name when the exact failure is not configured yet.
      </p>
    </div>

    <% if (hardwareIssueTypes.length === 0 || issueLocations.length === 0) { %>
      <div class="message error">
        <p>Hardware issue options are not ready yet. Run the Step 3f SQL migration to seed hardware issue types and locations.</p>
      </div>
    <% } %>

    <div class="workflow-list" data-module-list="hardwareIssue">
      <% hardwareIssueRows.forEach((issueRow, index) => { %>
        <article class="workflow-item slate" data-module-row="hardwareIssue">
          <span></span>
          <div style="width: 100%;">
            <div class="content-header" style="align-items: center; margin-bottom: 12px;">
              <div>
                <strong>Hardware Issue <span data-module-display-number><%= index + 1 %></span></strong>
                <p>Configured issue or custom issue, location, and remarks.</p>
              </div>
              <button type="button" class="secondary-button" data-remove-module-row>Remove</button>
            </div>

            <div class="form-grid">
              <label class="form-field">
                <span>Configured Issue</span>
                <select name="hardwareIssues[<%= index %>][issueTypeConfigValueId]" data-module-field>
                  <option value="">Select configured issue</option>
                  <% hardwareIssueTypes.forEach((issueType) => { %>
                    <option value="<%= issueType.id %>" <%= selected(issueRow.issueTypeConfigValueId, issueType.id) %>><%= issueType.label %></option>
                  <% }) %>
                </select>
                <small class="field-hint">Use this when the issue exists in the configured list.</small>
              </label>

              <label class="form-field">
                <span>Custom Issue</span>
                <input type="text" name="hardwareIssues[<%= index %>][customIssueLabel]" value="<%= issueRow.customIssueLabel || '' %>" maxlength="120" placeholder="Example: Cannot install OS" data-module-field />
                <small class="field-hint">Use this when the issue is not configured yet.</small>
              </label>

              <label class="form-field">
                <span>Location</span>
                <select name="hardwareIssues[<%= index %>][locationConfigValueId]" data-module-field>
                  <option value="">Select location</option>
                  <% issueLocations.forEach((location) => { %>
                    <option value="<%= location.id %>" <%= selected(issueRow.locationConfigValueId, location.id) %>><%= location.label %></option>
                  <% }) %>
                </select>
              </label>

              <label class="form-field">
                <span>Remarks</span>
                <input type="text" name="hardwareIssues[<%= index %>][issueRemark]" value="<%= issueRow.issueRemark || '' %>" maxlength="500" placeholder="Short note explaining the issue" data-module-field />
              </label>
            </div>
          </div>
        </article>
      <% }) %>
    </div>

    <div class="form-actions" style="margin-top: 12px;">
      <button type="button" class="secondary-button" data-add-module-row="hardwareIssue">+ Add Hardware Issue</button>
    </div>
  </div>

  <div class="form-section">
    <div class="form-section-header">
      <div>
        <p class="eyebrow">Comments</p>
        <h3>Add General Comment</h3>
      </div>
      <p>
        General comments are appended as history. Existing comments stay visible in the expanded unit mini-menu and are not overwritten by this field.
      </p>
    </div>

    <div class="form-grid">
      <label class="form-field">
        <span>Comment Type</span>
        <select name="generalCommentTypeConfigValueId">
          <option value="">Select comment type</option>
          <% commentTypes.forEach((commentType) => { %>
            <option value="<%= commentType.id %>" <%= selected(selectedCommentTypeConfigValueId, commentType.id) %>><%= commentType.label %></option>
          <% }) %>
        </select>
      </label>

      <label class="form-field">
        <span>New Comment</span>
        <textarea name="generalCommentText" rows="4" maxlength="2000" placeholder="Add a new general comment. Leave blank if no new comment is needed."><%= formData.generalCommentText || '' %></textarea>
      </label>
    </div>
  </div>

  <div class="form-section">
    <div class="form-section-header">
      <div>
        <p class="eyebrow">Notes</p>
        <h3>Current Notes</h3>
      </div>
      <p>
        These notes remain available for the current workflow. Step 3f will add structured hardware and cosmetic issue rows with dropdowns, custom issue text, locations, severity where needed, and remarks.
      </p>
    </div>

    <div class="form-grid">
      <label class="form-field">
        <span>Hardware Notes</span>
        <textarea name="hardwareNotes" rows="4" maxlength="1000"><%= formData.hardwareNotes %></textarea>
        <small class="field-hint">
          Use this for current hardware notes until structured hardware issue rows are added.
        </small>
      </label>

      <label class="form-field">
        <span>Cosmetic Notes</span>
        <textarea name="cosmeticNotes" rows="4" maxlength="1000"><%= formData.cosmeticNotes %></textarea>
        <small class="field-hint">
          Use this for current cosmetic notes until structured cosmetic issue rows are added.
        </small>
      </label>
    </div>
  </div>

  <template data-module-template="cosmeticIssue">
    <article class="workflow-item slate" data-module-row="cosmeticIssue">
      <span></span>
      <div style="width: 100%;">
        <div class="content-header" style="align-items: center; margin-bottom: 12px;">
          <div>
            <strong>Cosmetic Issue <span data-module-display-number>__DISPLAY__</span></strong>
            <p>Issue type, severity, location, and remarks.</p>
          </div>
          <button type="button" class="secondary-button" data-remove-module-row>Remove</button>
        </div>
        <div class="form-grid">
          <label class="form-field"><span>Issue Type</span><select name="cosmeticIssues[__INDEX__][issueTypeConfigValueId]" data-module-field><option value="">Select cosmetic issue</option><% cosmeticIssueTypes.forEach((issueType) => { %><option value="<%= issueType.id %>"><%= issueType.label %></option><% }) %></select></label>
          <label class="form-field"><span>Severity</span><select name="cosmeticIssues[__INDEX__][severityConfigValueId]" data-module-field><option value="">Select severity</option><% issueSeverities.forEach((severity) => { %><option value="<%= severity.id %>"><%= severity.label %></option><% }) %></select></label>
          <label class="form-field"><span>Location</span><select name="cosmeticIssues[__INDEX__][locationConfigValueId]" data-module-field><option value="">Select location</option><% issueLocations.forEach((location) => { %><option value="<%= location.id %>"><%= location.label %></option><% }) %></select></label>
          <label class="form-field"><span>Remarks</span><input type="text" name="cosmeticIssues[__INDEX__][issueRemark]" maxlength="500" placeholder="Short note explaining the issue" data-module-field /></label>
        </div>
      </div>
    </article>
  </template>

  <template data-module-template="hardwareIssue">
    <article class="workflow-item slate" data-module-row="hardwareIssue">
      <span></span>
      <div style="width: 100%;">
        <div class="content-header" style="align-items: center; margin-bottom: 12px;">
          <div>
            <strong>Hardware Issue <span data-module-display-number>__DISPLAY__</span></strong>
            <p>Configured issue or custom issue, location, and remarks.</p>
          </div>
          <button type="button" class="secondary-button" data-remove-module-row>Remove</button>
        </div>
        <div class="form-grid">
          <label class="form-field"><span>Configured Issue</span><select name="hardwareIssues[__INDEX__][issueTypeConfigValueId]" data-module-field><option value="">Select configured issue</option><% hardwareIssueTypes.forEach((issueType) => { %><option value="<%= issueType.id %>"><%= issueType.label %></option><% }) %></select><small class="field-hint">Use this when the issue exists in the configured list.</small></label>
          <label class="form-field"><span>Custom Issue</span><input type="text" name="hardwareIssues[__INDEX__][customIssueLabel]" maxlength="120" placeholder="Example: Cannot install OS" data-module-field /><small class="field-hint">Use this when the issue is not configured yet.</small></label>
          <label class="form-field"><span>Location</span><select name="hardwareIssues[__INDEX__][locationConfigValueId]" data-module-field><option value="">Select location</option><% issueLocations.forEach((location) => { %><option value="<%= location.id %>"><%= location.label %></option><% }) %></select></label>
          <label class="form-field"><span>Remarks</span><input type="text" name="hardwareIssues[__INDEX__][issueRemark]" maxlength="500" placeholder="Short note explaining the issue" data-module-field /></label>
        </div>
      </div>
    </article>
  </template>

  <template data-module-template="memory">
    <article class="workflow-item slate" data-module-row="memory">
      <span></span>
      <div style="width: 100%;">
        <div class="content-header" style="align-items: center; margin-bottom: 12px;">
          <div>
            <strong>RAM Module <span data-module-display-number>__DISPLAY__</span></strong>
            <p>Slot, size, type, speed, and module identifiers.</p>
          </div>
          <button type="button" class="secondary-button" data-remove-module-row>Remove</button>
        </div>

        <div class="form-grid">
          <label class="form-field"><span>Slot Label</span><input type="text" name="memoryModules[__INDEX__][slotLabel]" value="Slot __DISPLAY__" placeholder="Slot 1" maxlength="80" data-module-field /></label>
          <label class="form-field"><span>Size GB</span><input type="number" name="memoryModules[__INDEX__][sizeGb]" min="1" step="1" placeholder="Example: 8" data-memory-size-input data-module-field /></label>
          <label class="form-field"><span>RAM Type</span><select name="memoryModules[__INDEX__][ramTypeConfigValueId]" data-module-field><option value="">Select RAM type</option><% formOptions.ramTypes.forEach((ramType) => { %><option value="<%= ramType.id %>"><%= ramType.label %></option><% }) %></select></label>
          <label class="form-field"><span>Install Type</span><select name="memoryModules[__INDEX__][memoryInstallTypeCode]" data-module-field><% memoryInstallTypes.forEach((installType) => { %><option value="<%= installType.code %>" <%= installType.code === 'removable_module' ? 'selected' : '' %>><%= installType.label %></option><% }) %></select><small class="field-hint">Defaults to removable.</small></label>
          <label class="form-field"><span>Speed MHz</span><input type="number" name="memoryModules[__INDEX__][speedMhz]" min="1" step="1" placeholder="Example: 3200" data-module-field /></label>
          <label class="form-field"><span>Module Manufacturer</span><input type="text" name="memoryModules[__INDEX__][manufacturerName]" maxlength="120" placeholder="Example: Samsung" data-module-field /></label>
          <label class="form-field"><span>Part Number</span><input type="text" name="memoryModules[__INDEX__][partNumber]" maxlength="120" data-module-field /></label>
          <label class="form-field"><span>Serial Number</span><input type="text" name="memoryModules[__INDEX__][serialNumber]" maxlength="120" data-module-field /></label>
          <label class="form-field"><span>Change Notes</span><input type="text" name="memoryModules[__INDEX__][changeNotes]" maxlength="500" placeholder="Installed, replaced, upgraded, downgraded, etc." data-module-field /></label>
        </div>
      </div>
    </article>
  </template>

  <template data-module-template="storage">
    <article class="workflow-item slate" data-module-row="storage">
      <span></span>
      <div style="width: 100%;">
        <div class="content-header" style="align-items: center; margin-bottom: 12px;">
          <div>
            <strong>Storage Device <span data-module-display-number>__DISPLAY__</span></strong>
            <p>Drive slot, size, type, model, serial, firmware, and wipe status.</p>
          </div>
          <button type="button" class="secondary-button" data-remove-module-row>Remove</button>
        </div>

        <div class="form-grid">
          <label class="form-field"><span>Slot Label</span><input type="text" name="storageDevices[__INDEX__][slotLabel]" value="Drive __DISPLAY__" placeholder="Drive 1" maxlength="80" data-module-field /></label>
          <label class="form-field"><span>Size GB</span><input type="number" name="storageDevices[__INDEX__][sizeGb]" min="1" step="1" placeholder="Example: 256" data-storage-size-input data-module-field /></label>
          <label class="form-field"><span>Storage Type</span><select name="storageDevices[__INDEX__][storageTypeConfigValueId]" data-module-field><option value="">Select storage type</option><% formOptions.storageTypes.forEach((storageType) => { %><option value="<%= storageType.id %>"><%= storageType.label %></option><% }) %></select></label>
          <label class="form-field"><span>Wipe Status</span><select name="storageDevices[__INDEX__][wipeStatusConfigValueId]" data-module-field><option value="">Select wipe status</option><% (formOptions.storageWipeStatuses || []).forEach((wipeStatus) => { %><option value="<%= wipeStatus.id %>"><%= wipeStatus.label %></option><% }) %></select></label>
          <label class="form-field"><span>Drive Manufacturer</span><input type="text" name="storageDevices[__INDEX__][manufacturerName]" maxlength="120" placeholder="Example: Samsung" data-module-field /></label>
          <label class="form-field"><span>Model Number</span><input type="text" name="storageDevices[__INDEX__][modelNumber]" maxlength="120" data-module-field /></label>
          <label class="form-field"><span>Serial Number</span><input type="text" name="storageDevices[__INDEX__][serialNumber]" maxlength="120" data-module-field /></label>
          <label class="form-field"><span>Firmware Version</span><input type="text" name="storageDevices[__INDEX__][firmwareVersion]" maxlength="120" data-module-field /></label>
          <label class="form-field"><span>Change Notes</span><input type="text" name="storageDevices[__INDEX__][changeNotes]" maxlength="500" placeholder="Installed, replaced, upgraded, downgraded, wiped, etc." data-module-field /></label>
        </div>
      </div>
    </article>
  </template>

  <div class="form-actions">
    <button class="primary-button" type="submit">
      <%= isEditMode ? 'Update Unit' : 'Create Unit' %>
    </button>

    <% if (isModal) { %>
      <button type="button" class="secondary-button" data-modal-close>Cancel</button>
    <% } else { %>
      <a class="secondary-button" href="/tech/units">Cancel</a>
    <% } %>
  </div>
</form>
