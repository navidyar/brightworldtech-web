<%
  const isEditMode = mode === 'edit';
  const htmxAttrs = isModal ? `hx-post="${formAction}" hx-target="#modal-root" hx-swap="innerHTML"` : '';

  function selected(currentValue, optionValue) {
    return String(currentValue || '') === String(optionValue || '') ? 'selected' : '';
  }
%>

<% if (!formOptions.supported) { %>
  <div class="message error">
    <p><%= formOptions.message %></p>
  </div>
<% } %>

<% if (errorMessages.length > 0) { %>
  <div class="message error">
    <% errorMessages.forEach((errorMessage) => { %>
      <p><%= errorMessage %></p>
    <% }) %>
  </div>
<% } %>

<form class="app-form tech-unit-form" method="post" action="<%= formAction %>" data-tech-unit-form <%- htmxAttrs %>>
  <div class="form-section">
    <div class="form-section-header">
      <div>
        <p class="eyebrow">Identity</p>
        <h3>Unit Identity</h3>
      </div>
      <p>
        These fields help identify the physical unit and prevent duplicate records. Asset tags are the strongest match;
        unit serial and BIOS serial are used when an asset tag is missing, removed, or not yet attached.
      </p>
    </div>

    <div class="form-grid">
      <label class="form-field">
        <span>Asset Tag</span>
        <input
          type="text"
          name="assetTag"
          value="<%= formData.assetTag %>"
          placeholder="<%= isEditMode ? '' : `${formOptions.assetTagPrefix || 'BWT'}2300001 or blank for auto-generate` %>"
          autocomplete="off"
          spellcheck="false"
          <%= isEditMode ? 'disabled' : '' %>
        />
        <small class="field-hint">
          Enter <%= formOptions.assetTagPrefix || 'BWT' %>2300001 or 2300001. Leave blank on create to auto-generate the next asset tag.
        </small>
      </label>

      <label class="form-field">
        <span>Unit Serial Number</span>
        <input
          type="text"
          name="unitSerialNumber"
          value="<%= formData.unitSerialNumber %>"
          placeholder="Physical serial from the unit"
          autocomplete="off"
          spellcheck="false"
          maxlength="150"
        />
        <small class="field-hint">
          Usually copied from the device label or chassis. This is used for duplicate detection.
        </small>
      </label>

      <label class="form-field">
        <span>BIOS Serial Number</span>
        <input
          type="text"
          name="biosSerialNumber"
          value="<%= formData.biosSerialNumber %>"
          placeholder="Serial reported by BIOS or ScanTool"
          autocomplete="off"
          spellcheck="false"
          maxlength="150"
        />
        <small class="field-hint">
          BIOS serial is a stronger confirmation than the physical serial alone.
        </small>
      </label>
    </div>
  </div>

  <div class="form-section">
    <div class="form-section-header">
      <div>
        <p class="eyebrow">Assignment</p>
        <h3>Lot and Workflow Status</h3>
      </div>
      <p>
        Assign the unit to the child lot the tech is working on. Parent/container lots are not assignable.
        If an existing unit is confirmed during duplicate matching, changing the lot records a lot-movement history entry.
      </p>
    </div>

    <div class="form-grid">
      <label class="form-field">
        <span>Assignable Lot</span>
        <select name="lotId" required>
          <option value="">Select assignable lot</option>
          <% formOptions.lots.forEach((lot) => { %>
            <option value="<%= lot.lot_id %>" <%= selected(formData.lotId, lot.lot_id) %>>
              <%= lot.lot_name %>
              <% if (lot.lot_number) { %>
                - Lot #<%= lot.lot_number %>
              <% } %>
            </option>
          <% }) %>
        </select>
        <small class="field-hint">
          Lots with child lots are containers and cannot receive units directly.
        </small>
      </label>

      <label class="form-field">
        <span>Unit Category</span>
        <select name="unitCategoryConfigValueId" required data-unit-category-select>
          <option value="">Select category</option>
          <% formOptions.unitCategories.forEach((category) => { %>
            <option value="<%= category.id %>" <%= selected(formData.unitCategoryConfigValueId, category.id) %>>
              <%= category.label %>
            </option>
          <% }) %>
        </select>
        <small class="field-hint">
          Required. Selecting a model can auto-fill this if the model has a category.
        </small>
      </label>

      <label class="form-field">
        <span>Unit Status</span>
        <select name="currentUnitStatusConfigValueId" required>
          <option value="">Select status</option>
          <% formOptions.unitStatuses.forEach((status) => { %>
            <option value="<%= status.id %>" <%= selected(formData.currentUnitStatusConfigValueId, status.id) %>>
              <%= status.label %>
            </option>
          <% }) %>
        </select>
        <small class="field-hint">Required. New units default to Received when that status exists.</small>
      </label>
    </div>
  </div>

  <div class="form-section">
    <div class="form-section-header">
      <div>
        <p class="eyebrow">Model</p>
        <h3>Manufacturer and Model</h3>
      </div>
      <p>
        Model selection is separated from identity so techs can first confirm the physical unit, then record the make/model details.
        The model dropdown filters by selected manufacturer and unit category.
      </p>
    </div>

    <div class="form-grid">
      <label class="form-field">
        <span>Manufacturer</span>
        <select name="manufacturerId" data-manufacturer-select>
          <option value="">Select manufacturer</option>
          <% formOptions.manufacturers.forEach((manufacturer) => { %>
            <option value="<%= manufacturer.id %>" <%= selected(formData.manufacturerId, manufacturer.id) %>>
              <%= manufacturer.label %>
            </option>
          <% }) %>
        </select>
        <small class="field-hint">
          Selecting a manufacturer filters the model dropdown.
        </small>
      </label>

      <label class="form-field">
        <span>Unit Model</span>
        <select name="unitModelId" data-unit-model-select>
          <option value="">Select model</option>
          <% formOptions.unitModels.forEach((unitModel) => { %>
            <option
              value="<%= unitModel.id %>"
              data-manufacturer-id="<%= unitModel.manufacturerId || '' %>"
              data-category-id="<%= unitModel.unitCategoryConfigValueId || '' %>"
              <%= selected(formData.unitModelId, unitModel.id) %>
            >
              <%= unitModel.label %>
            </option>
          <% }) %>
        </select>
        <small class="field-hint" data-unit-model-hint>
          Models can be filtered by manufacturer and category.
        </small>
      </label>
    </div>
  </div>

  <div class="form-section">
    <div class="form-section-header">
      <div>
        <p class="eyebrow">CPU</p>
        <h3>Processor Information</h3>
      </div>
      <p>
        CPU details are used as a secondary confidence check when matching a unit by serial number.
        The expected display format is CPU manufacturer, CPU model, and speed.
      </p>
    </div>

    <div class="form-grid">
      <label class="form-field">
        <span>Processor Model</span>
        <select name="processorModelId" data-processor-model-select>
          <option value="">Select processor</option>
          <% formOptions.processorModels.forEach((processorModel) => { %>
            <option
              value="<%= processorModel.id %>"
              data-base-speed-ghz="<%= processorModel.baseSpeedGhz || '' %>"
              <%= selected(formData.processorModelId, processorModel.id) %>
            >
              <%= processorModel.label %>
            </option>
          <% }) %>
        </select>
        <small class="field-hint">
          Choosing a processor can auto-fill speed if the base speed exists in the processor list.
        </small>
      </label>

      <label class="form-field">
        <span>Processor Speed GHz</span>
        <input
          type="number"
          name="processorSpeedGhz"
          value="<%= formData.processorSpeedGhz %>"
          min="0"
          step="0.01"
          placeholder="Example: 2.40"
          data-processor-speed-input
        />
        <small class="field-hint">
          Store the numeric speed only. The frontend displays it with GHz.
        </small>
      </label>
    </div>
  </div>

  <div class="form-section">
    <div class="form-section-header">
      <div>
        <p class="eyebrow">Memory and Storage</p>
        <h3>Current Summary Fields</h3>
      </div>
      <p>
        These are temporary summary fields for the current CRUD flow. Step 3e will move RAM and storage into individual module/device rows while still displaying totals in the frontend.
      </p>
    </div>

    <div class="form-grid">
      <label class="form-field">
        <span>RAM GB</span>
        <input
          type="number"
          name="ramGb"
          value="<%= formData.ramGb %>"
          min="1"
          step="1"
          placeholder="Example: 16"
        />
        <small class="field-hint">
          Current total RAM summary. Individual RAM modules come in Step 3e.
        </small>
      </label>

      <label class="form-field">
        <span>RAM Type</span>
        <select name="ramTypeConfigValueId">
          <option value="">Select RAM type</option>
          <% formOptions.ramTypes.forEach((ramType) => { %>
            <option value="<%= ramType.id %>" <%= selected(formData.ramTypeConfigValueId, ramType.id) %>>
              <%= ramType.label %>
            </option>
          <% }) %>
        </select>
        <small class="field-hint">
          Current RAM type summary. Mixed modules will be handled through module rows.
        </small>
      </label>

      <label class="form-field">
        <span>Storage GB</span>
        <input
          type="number"
          name="storageGb"
          value="<%= formData.storageGb %>"
          min="1"
          step="1"
          placeholder="Example: 256"
        />
        <small class="field-hint">
          Current storage summary. Individual storage devices come in Step 3e.
        </small>
      </label>

      <label class="form-field">
        <span>Storage Type</span>
        <select name="storageTypeConfigValueId">
          <option value="">Select storage type</option>
          <% formOptions.storageTypes.forEach((storageType) => { %>
            <option value="<%= storageType.id %>" <%= selected(formData.storageTypeConfigValueId, storageType.id) %>>
              <%= storageType.label %>
            </option>
          <% }) %>
        </select>
        <small class="field-hint">
          Current storage type summary. Multiple drives will be handled through device rows.
        </small>
      </label>
    </div>
  </div>

  <div class="form-section">
    <div class="form-section-header">
      <div>
        <p class="eyebrow">Operating System</p>
        <h3>OS Summary</h3>
      </div>
      <p>
        Operating system is kept separate from hardware because ELS intake may stop before OS installation, while full refurb lots may require OS details later.
      </p>
    </div>

    <div class="form-grid">
      <label class="form-field">
        <span>Operating System</span>
        <select name="operatingSystemConfigValueId">
          <option value="">Select OS</option>
          <% formOptions.operatingSystems.forEach((operatingSystem) => { %>
            <option value="<%= operatingSystem.id %>" <%= selected(formData.operatingSystemConfigValueId, operatingSystem.id) %>>
              <%= operatingSystem.label %>
            </option>
          <% }) %>
        </select>
        <small class="field-hint">
          OS build and diagnostics fields will be added after the expanded form foundation is ready.
        </small>
      </label>
    </div>
  </div>

  <div class="form-section">
    <div class="form-section-header">
      <div>
        <p class="eyebrow">Expanded Data</p>
        <h3>Upcoming Structured Fields</h3>
      </div>
      <p>
        This section documents where the next unit-data groups will appear. ScanTool-only values will not become normal editable fields unless we explicitly allow edits later.
      </p>
    </div>

    <div class="workflow-list">
      <div class="workflow-item slate">
        <span></span>
        <div>
          <strong>ScanTool-only specifications</strong>
          <p>
            LTE/WWAN details, supported networks, bands, firmware-level module details, some BIOS values, and other deep hardware values will be displayed when ScanTool sends them.
          </p>
        </div>
      </div>

      <div class="workflow-item slate">
        <span></span>
        <div>
          <strong>Manual expanded details</strong>
          <p>
            RAM modules, storage devices, graphics adapters, hardware issues, cosmetic issues, overall unit grade, and comments will be added in the next form steps.
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="form-section">
    <div class="form-section-header">
      <div>
        <p class="eyebrow">Notes</p>
        <h3>Current Notes</h3>
      </div>
      <p>
        These notes remain available for the current workflow. Step 3f will add structured hardware and cosmetic issue rows with dropdowns, custom issue text, locations, severity where needed, and remarks.
      </p>
    </div>

    <div class="form-grid">
      <label class="form-field">
        <span>Hardware Notes</span>
        <textarea name="hardwareNotes" rows="4" maxlength="1000"><%= formData.hardwareNotes %></textarea>
        <small class="field-hint">
          Use this for current hardware notes until structured hardware issue rows are added.
        </small>
      </label>

      <label class="form-field">
        <span>Cosmetic Notes</span>
        <textarea name="cosmeticNotes" rows="4" maxlength="1000"><%= formData.cosmeticNotes %></textarea>
        <small class="field-hint">
          Use this for current cosmetic notes until structured cosmetic issue rows are added.
        </small>
      </label>
    </div>
  </div>

  <div class="form-actions">
    <button class="primary-button" type="submit">
      <%= isEditMode ? 'Update Unit' : 'Create Unit' %>
    </button>

    <% if (isModal) { %>
      <button type="button" class="secondary-button" data-modal-close>Cancel</button>
    <% } else { %>
      <a class="secondary-button" href="/tech/units">Cancel</a>
    <% } %>
  </div>
</form>
