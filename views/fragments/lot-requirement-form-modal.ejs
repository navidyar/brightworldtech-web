<%
  const safeErrors = Array.isArray(errorMessages) ? errorMessages : [];
  const safeFormData = formData || {};
  const safeMode = mode === 'edit' ? 'edit' : 'create';
  const safeRequirement = requirement || null;
  const formAction = safeMode === 'edit' && safeRequirement
    ? `/management/lots/${lot.lot_id}/requirements/${safeRequirement.lot_requirement_id}/edit/modal`
    : `/management/lots/${lot.lot_id}/requirements`;
  const title = safeMode === 'edit' ? 'Edit Requirement' : 'Add Requirement';
  const submitLabel = safeMode === 'edit' ? 'Save Requirement' : 'Add Requirement';
%>

<div class="modal-backdrop" data-modal-backdrop>
  <section class="modal-panel site-clean-modal lot-modal lot-requirement-modal" role="dialog" aria-modal="true" aria-labelledby="lot-requirement-modal-title">
    <header class="modal-header">
      <div>
        <h2 id="lot-requirement-modal-title"><%= title %></h2>
      </div>

      <button type="button" class="modal-close-button" data-modal-close aria-label="Close modal">×</button>
    </header>

    <div class="modal-body">
      <% if (safeErrors.length > 0) { %>
        <div class="message error">
          <% safeErrors.forEach((errorMessage) => { %>
            <p><%= errorMessage %></p>
          <% }) %>
        </div>
      <% } %>

      <script type="application/json" data-requirement-value-options-json><%- JSON.stringify(requirementValueOptionsByKey || {}).replace(/</g, '\\u003c') %></script>

      <form class="app-form app-form-clean lot-requirement-modal-form" method="post" action="<%= formAction %>" hx-post="<%= formAction %>" hx-target="#modal-root" hx-swap="innerHTML" data-requirement-form>
        <div class="form-section">
          <div class="form-section-header">
            <div>
              <h3>Requirement Details</h3>
            </div>
          </div>

          <div class="form-grid lot-form-grid">
            <label class="form-field">
              <span>Requirement Field</span>
              <select name="requirementKey" required data-requirement-key>
                <option value="">Select requirement</option>
                <% requirementFieldOptions.forEach((option) => { %>
                  <option value="<%= option.value %>" <%= safeFormData.requirementKey === option.value ? 'selected' : '' %>>
                    <%= option.label %>
                  </option>
                <% }) %>
              </select>
            </label>

            <label class="form-field">
              <span>Rule</span>
              <select name="operatorCode" required data-requirement-operator>
                <% operatorOptions.forEach((option) => { %>
                  <option value="<%= option.value %>" data-operator-code="<%= option.value %>" <%= safeFormData.operatorCode === option.value ? 'selected' : '' %>>
                    <%= option.label %>
                  </option>
                <% }) %>
              </select>
            </label>

            <label class="form-field" data-required-value-select-wrap hidden>
              <span>Required Value</span>
              <select name="requiredValue" data-required-value-select disabled>
                <option value="">Select value</option>
              </select>
              <small class="field-hint" data-required-value-select-hint></small>
            </label>

            <label class="form-field" data-required-value-text-wrap>
              <span>Required Value</span>
              <input type="number" name="requiredValue" value="<%= safeFormData.requiredValue || '' %>" min="0.01" step="0.01" placeholder="Example: 16" required data-required-value-text />
            </label>

            <label class="form-field">
              <span>Notes</span>
              <input type="text" name="notes" value="<%= safeFormData.notes || '' %>" maxlength="500" placeholder="Optional internal note" />
            </label>
          </div>

          <p class="field-hint" data-requirement-field-hint>
            Select a requirement field to load its supported values and rules.
          </p>
        </div>

        <div class="form-actions">
          <button type="submit" class="primary-button"><%= submitLabel %></button>
          <button type="button" class="secondary-button" data-modal-close>Cancel</button>
        </div>
      </form>
    </div>
  </section>
</div>
