<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title><%= pageTitle ? `${pageTitle} | BWTDallas App` : 'BWTDallas App' %></title>

  
  <link rel="icon" href="/favicon.svg?v=20260716-refined-b-v7-final" type="image/svg+xml" sizes="any" />
  <link rel="icon" href="/favicon-16x16.png?v=20260716-refined-b-v7-final" type="image/png" sizes="16x16" />
  <link rel="icon" href="/favicon-32x32.png?v=20260716-refined-b-v7-final" type="image/png" sizes="32x32" />
  <link rel="icon" href="/favicon-48x48.png?v=20260716-refined-b-v7-final" type="image/png" sizes="48x48" />
  <link rel="shortcut icon" href="/favicon.ico?v=20260716-refined-b-v7-final" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=20260716-refined-b-v7-final" sizes="180x180" />
  <link rel="manifest" href="/site.webmanifest?v=20260716-refined-b-v7-final" />
  <meta name="theme-color" content="#C1E405" />
<script>
    (function () {
      const storageKey = 'bwtdallas-theme';
      const savedTheme = localStorage.getItem(storageKey);

      let theme = 'hybrid';

      if (savedTheme === 'light' || savedTheme === 'hybrid') {
        theme = savedTheme;
      }

      if (savedTheme === 'dark' || savedTheme === 'dim') {
        theme = 'hybrid';
        localStorage.setItem(storageKey, theme);
      }

      document.documentElement.setAttribute('data-theme', theme);
      document.documentElement.style.colorScheme = theme === 'light' ? 'light' : 'light';
    })();
  </script>

  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/theme.css?v=20260723-shared-ui-foundation" />
  <link rel="stylesheet" href="/css/work-area.css?v=20260708-stage-f5-18" />

  <% if (typeof stylesheets !== 'undefined' && Array.isArray(stylesheets)) { %>
    <% stylesheets.forEach((stylesheetHref) => { %>
      <link rel="stylesheet" href="<%= stylesheetHref %>" />
    <% }) %>
  <% } %>

  <!-- Shared visual rules load after legacy/page CSS. Feature mechanics remain
       in the page stylesheets and receive final safety guarantees in features.css. -->
  <link rel="stylesheet" href="/css/app.css?v=20260723-shared-ui-foundation" />
  <link rel="stylesheet" href="/css/features.css?v=20260723-shared-ui-foundation" />

  <script defer src="/js/theme.js"></script>
  <script defer src="/js/sidebar.js"></script>
  <script defer src="/js/date-picker-only.js?v=20260708-stage-f5-11-v2"></script>
  <script defer src="/js/management-reporting-controls.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.10/dist/htmx.min.js" integrity="sha384-H5SrcfygHmAuTDZphMHqBJLc3FhssKjG7w/CeCpFReSfwBWDTKpkzPP8c+cLsK+V" crossorigin="anonymous"></script>
</head>