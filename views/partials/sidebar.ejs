<%
  const accessibleDashboards =
    Array.isArray(dashboardDefinitions)
      ? dashboardDefinitions.filter((dashboard) => canAccessDashboard(dashboard.key))
      : [];

  const dashboardHref =
    accessibleDashboards.length === 1
      ? `/dashboards/${accessibleDashboards[0].key}`
      : '/';
%>

<aside class="sidebar">
  <div class="sidebar-brand">
    <a href="/" class="brand-card">
      <div class="brand-mark">BWT</div>
      <div>
        <p>Bright World</p>
        <strong>Technologies</strong>
      </div>
    </a>
  </div>

  <nav class="sidebar-nav">
    <a href="<%= dashboardHref %>" class="sidebar-link <%= currentNav === 'dashboard' || String(currentNav || '').startsWith('dashboard:') ? 'active' : '' %>">
      <span class="sidebar-icon">⌂</span>
      <span>Dashboard</span>
    </a>

    <% if (canAccessMenuArea('admin')) { %>
      <details class="sidebar-group">
        <summary>
          <span class="sidebar-icon">✦</span>
          <span>Admin</span>
        </summary>

        <div class="sidebar-subnav">
          <span class="sidebar-sublink sidebar-sublink-muted">
            <span class="submenu-dot purple"></span>
            <span>Admin tools planned</span>
          </span>
        </div>
      </details>
    <% } %>

    <% if (canAccessMenuArea('management')) { %>
      <details class="sidebar-group" <%= currentNav === 'management' || currentNav === 'management-config' || currentNav === 'management-lots' ? 'open' : '' %>>
        <summary>
          <span class="sidebar-icon">◎</span>
          <span>Management</span>
        </summary>

        <div class="sidebar-subnav">
          <a href="/management/users" class="sidebar-sublink <%= currentNav === 'management' ? 'active' : '' %>">
            <span class="submenu-dot blue"></span>
            <span>Users</span>
          </a>

          <a href="/management/lots" class="sidebar-sublink <%= currentNav === 'management-lots' ? 'active' : '' %>">
            <span class="submenu-dot green"></span>
            <span>Lots</span>
          </a>

          <a href="/management/config" class="sidebar-sublink <%= currentNav === 'management-config' ? 'active' : '' %>">
            <span class="submenu-dot slate"></span>
            <span>Config Values</span>
          </a>
        </div>
      </details>
    <% } %>

    <% if (canAccessMenuArea('tech')) { %>
      <details class="sidebar-group" <%= currentNav === 'tech-units' ? 'open' : '' %>>
        <summary>
          <span class="sidebar-icon">▣</span>
          <span>Tech</span>
        </summary>

        <div class="sidebar-subnav">
          <a href="/tech/units" class="sidebar-sublink <%= currentNav === 'tech-units' ? 'active' : '' %>">
            <span class="submenu-dot green"></span>
            <span>Units</span>
          </a>
        </div>
      </details>
    <% } %>

    <% if (canAccessMenuArea('warehouse')) { %>
      <details class="sidebar-group">
        <summary>
          <span class="sidebar-icon">◇</span>
          <span>Warehouse</span>
        </summary>

        <div class="sidebar-subnav">
          <span class="sidebar-sublink sidebar-sublink-muted">
            <span class="submenu-dot slate"></span>
            <span>Warehouse tools planned</span>
          </span>
        </div>
      </details>
    <% } %>

    <% if (canAccessMenuArea('sales')) { %>
      <details class="sidebar-group">
        <summary>
          <span class="sidebar-icon">◈</span>
          <span>Sales</span>
        </summary>

        <div class="sidebar-subnav">
          <span class="sidebar-sublink sidebar-sublink-muted">
            <span class="submenu-dot red"></span>
            <span>Sales tools planned</span>
          </span>
        </div>
      </details>
    <% } %>

    <% if (canAccessMenuArea('database')) { %>
      <a href="/database" class="sidebar-link <%= currentNav === 'database' ? 'active' : '' %>">
        <span class="sidebar-icon">⚙</span>
        <span>Database Check</span>
      </a>
    <% } %>
  </nav>
</aside>