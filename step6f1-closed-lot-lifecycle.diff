diff --git a/sql/2026-06-step-6f1-closed-lot-lifecycle.sql b/sql/2026-06-step-6f1-closed-lot-lifecycle.sql
new file mode 100644
index 0000000000000000000000000000000000000000..f0fa13a19fa1c87a099c4986f60289a1825d8294
--- /dev/null
+++ b/sql/2026-06-step-6f1-closed-lot-lifecycle.sql
@@ -0,0 +1,44 @@
+/*
+  Step 6f.1 — Closed Lot Lifecycle
+
+  Open and Closed are operational lot states.
+  Hidden remains a separate administrative visibility setting.
+*/
+
+SET @database_name = DATABASE();
+
+/* Add the reversible operational closed state. */
+SET @column_exists = (
+  SELECT COUNT(*)
+  FROM information_schema.COLUMNS
+  WHERE TABLE_SCHEMA = @database_name
+    AND TABLE_NAME = 'lots'
+    AND COLUMN_NAME = 'is_closed'
+);
+SET @sql = IF(
+  @column_exists = 0,
+  'ALTER TABLE lots ADD COLUMN is_closed TINYINT(1) NOT NULL DEFAULT 0 AFTER is_active',
+  'SELECT ''lots.is_closed already exists'' AS message'
+);
+PREPARE statement FROM @sql; EXECUTE statement; DEALLOCATE PREPARE statement;
+
+UPDATE lots
+SET is_closed = 0
+WHERE is_closed IS NULL;
+
+/* Supports open-lot destination lookups without changing hidden-lot behavior. */
+SET @index_exists = (
+  SELECT COUNT(*)
+  FROM information_schema.STATISTICS
+  WHERE TABLE_SCHEMA = @database_name
+    AND TABLE_NAME = 'lots'
+    AND INDEX_NAME = 'idx_lots_operational_state'
+);
+SET @sql = IF(
+  @index_exists = 0,
+  'ALTER TABLE lots ADD INDEX idx_lots_operational_state (is_active, is_closed)',
+  'SELECT ''idx_lots_operational_state already exists'' AS message'
+);
+PREPARE statement FROM @sql; EXECUTE statement; DEALLOCATE PREPARE statement;
+
+SELECT 'Step 6f.1 closed-lot lifecycle migration complete' AS message;
diff --git a/views/fragments/lot-closure-modal.ejs b/views/fragments/lot-closure-modal.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..fc36434321614f17c544f2ffdeb23b10b0791541
--- /dev/null
+++ b/views/fragments/lot-closure-modal.ejs
@@ -0,0 +1,78 @@
+<%
+  const safeSummary = closureSummary || {};
+  const safeLot = safeSummary.lot || null;
+  const lotName = safeLot && safeLot.lot_name ? safeLot.lot_name : 'Lot';
+  const isReopen = mode === 'reopen';
+  const actionLabel = isReopen ? 'Reopen Lot' : 'Close Lot';
+  const actionPath = safeLot ? `/management/lots/${safeLot.lot_id}/${isReopen ? 'reopen' : 'close'}` : '#';
+  const unitCount = Number(safeSummary.unitCount || 0);
+  const childLotCount = Number(safeSummary.childLotCount || 0);
+%>
+
+<div class="modal-overlay" data-modal-overlay>
+  <section class="modal-panel lot-modal lot-closure-modal" role="dialog" aria-modal="true" aria-labelledby="lot-closure-modal-title">
+    <div class="modal-header">
+      <div>
+        <p class="eyebrow"><%= actionLabel %></p>
+        <h2 id="lot-closure-modal-title"><%= actionLabel %>: <%= lotName %>?</h2>
+      </div>
+      <button type="button" class="modal-close" data-modal-close aria-label="Close modal">×</button>
+    </div>
+
+    <div class="modal-body">
+      <% if (errorMessages && errorMessages.length > 0) { %>
+        <div class="message error">
+          <% errorMessages.forEach((errorMessage) => { %>
+            <p><%= errorMessage %></p>
+          <% }) %>
+        </div>
+      <% } %>
+
+      <% if (safeLot) { %>
+        <div class="lot-delete-summary lot-closure-summary">
+          <% if (isReopen) { %>
+            <p>
+              Reopening makes this lot available again as an operational destination, provided it is visible and is not a parent/container lot.
+            </p>
+          <% } else { %>
+            <p>
+              Closing keeps this lot and its current units available for review and history, but prevents it from receiving new, moved, or override-handoff units.
+            </p>
+          <% } %>
+
+          <dl>
+            <div>
+              <dt>Units currently in lot</dt>
+              <dd><%= unitCount %></dd>
+            </div>
+            <div>
+              <dt>Direct child lots</dt>
+              <dd><%= childLotCount %></dd>
+            </div>
+          </dl>
+        </div>
+
+        <% if (!isReopen && childLotCount > 0) { %>
+          <div class="message warning">
+            <p>Child lots keep their own Open or Closed status. Closing this parent/container lot does not automatically close its children.</p>
+          </div>
+        <% } %>
+
+        <% if (!isReopen && unitCount > 0) { %>
+          <div class="message info">
+            <p>Existing units remain in this lot. They are not reassigned, deleted, or changed by closing the lot.</p>
+          </div>
+        <% } %>
+
+        <% if (safeSummary.canChangeClosure) { %>
+          <form method="post" action="<%= actionPath %>" hx-post="<%= actionPath %>" hx-target="#modal-root" hx-swap="innerHTML">
+            <div class="modal-actions">
+              <button type="button" class="secondary-button" data-modal-close>Cancel</button>
+              <button type="submit" class="<%= isReopen ? 'primary-button' : 'secondary-button' %>"><%= actionLabel %></button>
+            </div>
+          </form>
+        <% } %>
+      <% } %>
+    </div>
+  </section>
+</div>
