{
  "name": "bwtdallas-app",
  "version": "1.0.0",
  "description": "Bright World Technologies internal operations portal",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "create-admin-link": "node scripts/createAdminSetupLink.js",
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage",
    "validate:shared-css": "node scripts/validateSharedCssFoundation.js",
    "validate:unit-form-registry": "node scripts/validateUnitFormFieldRegistry.js",
