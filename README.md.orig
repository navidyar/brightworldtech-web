```bash
cd /home/bwtdallas-webserver/app

docker compose exec -T mysql sh -lc 'mysql -u"$MYSQL_USER" -p"$MYSQL_PASSWORD" "$MYSQL_DATABASE"' < sql/2026-06-step-6f1-closed-lot-lifecycle.sql
```

