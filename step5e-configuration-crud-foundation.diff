+  }
+
+  return `${baseUrl}${baseUrl.includes('?') ? '&' : '?'}${queryString}`;
+}
+
+function addCacheBuster(redirectUrl) {
+  const separator = redirectUrl.includes('?') ? '&' : '?';
+  return `${redirectUrl}${separator}refresh=${Date.now()}`;
